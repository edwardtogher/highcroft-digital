---
// ============================================================
// BADGER ELECTRICAL — Bespoke Preview Site
// ============================================================
// Light, warm, community-focused design for Bristol electrician
// Teal accent (#47c6c0) + Dark navy (#1e2a38) + Manrope font
// ============================================================
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Badger Electrical — Your Bristol Electrician Since 2007</title>
  <meta name="description" content="Community-focused electricians in Bristol since 2007. Domestic, commercial, and 24/7 emergency electrical services. BS7671 compliant, Part P certified." />

  <!-- OG Tags -->
  <meta property="og:title" content="Badger Electrical — Your New Site" />
  <meta property="og:description" content="Community-focused electricians in Bristol since 2007. Domestic, commercial, and 24/7 emergency electrical services." />
  <meta property="og:url" content="https://highcroftdigital.com/preview/badger-electrical" />
  <meta property="og:type" content="website" />

  <!-- Manrope from Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <!-- JSON-LD Schema -->
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "Electrician",
    "name": "Badger Electrical",
    "telephone": "+447967934029",
    "email": "sjones@badgerelectrical.co.uk",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Bristol",
      "addressRegion": "Bristol",
      "addressCountry": "GB"
    },
    "url": "https://highcroftdigital.com/preview/badger-electrical",
    "image": "http://badgerelectrical.co.uk/wp-content/uploads/2020/09/Screenshot-2020-09-29-at-08.43.15.png",
    "description": "Community-focused electricians in Bristol since 2007. Domestic, commercial, and 24/7 emergency electrical services.",
    "foundingDate": "2007",
    "areaServed": ["Bristol", "Clifton", "Redland", "Bedminster", "Filton", "Keynsham"],
    "openingHours": "Mo-Fr 07:00-21:00, Sa 08:00-17:00",
    "priceRange": "$$"
  }</script>

  <style>
    /* ===== RESET & BASE ===== */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --teal: #47c6c0;
      --teal-dark: #3aada8;
      --teal-light: #e8f8f7;
      --teal-mist: #f0faf9;
      --navy: #1e2a38;
      --navy-light: #2d3f52;
      --bg-white: #f8f9fa;
      --bg-cream: #fafbfc;
      --bg-teal-tint: #f3f8f8;
      --text-body: #3a4a58;
      --text-muted: #637181;
      --text-light: #8a96a3;
      --border: #e2e8ec;
      --border-light: #edf1f4;
      --card-shadow: 0 2px 16px rgba(30, 42, 56, 0.06);
      --card-shadow-hover: 0 8px 32px rgba(30, 42, 56, 0.10);
      --radius: 12px;
      --radius-sm: 8px;
      --radius-lg: 16px;
    }

    html { scroll-behavior: smooth; scroll-padding-top: 80px; }

    body {
      font-family: 'Manrope', -apple-system, BlinkMacSystemFont, sans-serif;
      color: var(--text-body);
      background: var(--bg-white);
      line-height: 1.65;
      font-weight: 400;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }

    .container {
      width: 100%;
      max-width: 1120px;
      margin: 0 auto;
      padding: 0 clamp(1.25rem, 4vw, 2.5rem);
    }

    /* ===== SCROLL REVEAL ===== */
    .rv {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1), transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .rv.visible {
      opacity: 1;
      transform: translateY(0);
    }
    @media (prefers-reduced-motion: reduce) {
      .rv { opacity: 1; transform: none; transition: none; }
    }

    /* ===== NAV ===== */
    .nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(248, 249, 250, 0.92);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border-light);
      height: 72px;
    }
    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 72px;
    }
    .nav-logo {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    .nav-logo img {
      height: 44px;
      width: auto;
      border-radius: 6px;
    }
    .nav-right {
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .nav-phone {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-weight: 600;
      font-size: 0.95rem;
      color: var(--navy);
      padding: 0.5rem 1rem;
      border-radius: var(--radius-sm);
      background: var(--teal-light);
      transition: background 0.2s;
      min-height: 44px;
    }
    .nav-phone:hover { background: #d5f0ef; }
    .nav-phone svg { width: 18px; height: 18px; color: var(--teal); flex-shrink: 0; }

    .hamburger {
      display: none;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.5rem;
      min-width: 44px;
      min-height: 44px;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 5px;
    }
    .hamburger .bar {
      display: block;
      width: 24px;
      height: 2.5px;
      background: var(--navy);
      border-radius: 2px;
      transition: all 0.3s;
    }
    .hamburger.active .bar:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
    .hamburger.active .bar:nth-child(2) { opacity: 0; }
    .hamburger.active .bar:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 0.25rem;
    }
    .nav-links a {
      padding: 0.5rem 0.85rem;
      font-size: 0.9rem;
      font-weight: 500;
      color: var(--text-muted);
      border-radius: var(--radius-sm);
      transition: color 0.2s, background 0.2s;
      min-height: 44px;
      display: flex;
      align-items: center;
    }
    .nav-links a:hover {
      color: var(--navy);
      background: var(--teal-mist);
    }

    .mobile-menu {
      display: none;
      position: absolute;
      top: 72px;
      left: 0;
      right: 0;
      background: var(--bg-white);
      border-bottom: 1px solid var(--border);
      padding: 1rem;
      box-shadow: 0 8px 24px rgba(30, 42, 56, 0.08);
    }
    .mobile-menu.open { display: flex; flex-direction: column; gap: 0.25rem; }
    .mobile-menu a {
      padding: 0.85rem 1rem;
      font-weight: 500;
      color: var(--text-body);
      border-radius: var(--radius-sm);
      min-height: 44px;
      display: flex;
      align-items: center;
    }
    .mobile-menu a:hover { background: var(--teal-mist); color: var(--navy); }

    @media (max-width: 768px) {
      .nav-links { display: none; }
      .hamburger { display: flex; }
      .nav-phone span { display: none; }
      .nav-phone { padding: 0.5rem; background: transparent; }
    }

    /* ===== HERO ===== */
    .hero {
      padding: clamp(3rem, 8vw, 6rem) 0 clamp(2.5rem, 6vw, 4.5rem);
      background: linear-gradient(170deg, var(--bg-white) 0%, var(--teal-mist) 100%);
      position: relative;
      overflow: hidden;
    }
    .hero::after {
      content: '';
      position: absolute;
      right: -5%;
      top: 10%;
      width: 420px;
      height: 420px;
      background: radial-gradient(circle, rgba(71, 198, 192, 0.08) 0%, transparent 70%);
      border-radius: 50%;
      pointer-events: none;
    }
    .hero-content {
      max-width: 640px;
      position: relative;
      z-index: 1;
    }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--teal-light);
      color: var(--teal-dark);
      font-weight: 600;
      font-size: 0.82rem;
      padding: 0.45rem 1rem;
      border-radius: 50px;
      margin-bottom: 1.5rem;
      letter-spacing: 0.02em;
      text-transform: uppercase;
    }
    .hero-badge svg { width: 16px; height: 16px; }
    .hero h1 {
      font-size: clamp(2.2rem, 5.5vw, 3.4rem);
      font-weight: 700;
      color: var(--navy);
      line-height: 1.15;
      margin-bottom: 1.25rem;
      letter-spacing: -0.02em;
    }
    .hero h1 .accent { color: var(--teal); }
    .hero-sub {
      font-size: clamp(1.05rem, 2vw, 1.2rem);
      color: var(--text-muted);
      line-height: 1.7;
      margin-bottom: 2rem;
      max-width: 540px;
    }
    .hero-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.65rem;
      background: var(--teal);
      color: #fff;
      font-weight: 600;
      font-size: 1.05rem;
      padding: 0.9rem 2rem;
      border-radius: var(--radius-sm);
      transition: background 0.2s, transform 0.15s;
      min-height: 50px;
      box-shadow: 0 4px 16px rgba(71, 198, 192, 0.3);
    }
    .hero-cta:hover { background: var(--teal-dark); transform: translateY(-1px); }
    .hero-cta svg { width: 20px; height: 20px; }
    .hero-micro {
      margin-top: 1rem;
      font-size: 0.88rem;
      color: var(--text-light);
      font-weight: 500;
    }

    /* ===== TRUST STRIP ===== */
    .trust-strip {
      padding: clamp(1.5rem, 3vw, 2.5rem) 0;
      background: var(--bg-white);
      border-bottom: 1px solid var(--border-light);
    }
    .trust-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
    }
    .trust-item {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 1rem;
      border-radius: var(--radius);
      background: var(--teal-mist);
      border: 1px solid rgba(71, 198, 192, 0.12);
    }
    .trust-icon {
      width: 40px;
      height: 40px;
      border-radius: 10px;
      background: var(--teal-light);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      color: var(--teal);
    }
    .trust-icon svg { width: 20px; height: 20px; }
    .trust-label {
      font-weight: 600;
      font-size: 0.88rem;
      color: var(--navy);
      line-height: 1.3;
    }
    @media (max-width: 768px) {
      .trust-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 480px) {
      .trust-grid { grid-template-columns: 1fr; }
    }

    /* ===== SECTION HELPERS ===== */
    .section { padding: clamp(3rem, 7vw, 5.5rem) 0; }
    .section-alt { background: var(--bg-teal-tint); }
    .section-label {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.78rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--teal);
      margin-bottom: 0.75rem;
    }
    .section-title {
      font-size: clamp(1.65rem, 4vw, 2.4rem);
      font-weight: 700;
      color: var(--navy);
      line-height: 1.2;
      margin-bottom: 0.75rem;
      letter-spacing: -0.015em;
    }
    .section-subtitle {
      font-size: clamp(0.98rem, 1.6vw, 1.1rem);
      color: var(--text-muted);
      max-width: 560px;
      line-height: 1.65;
      margin-bottom: 2.5rem;
    }

    /* ===== STATS ===== */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.25rem;
    }
    .stat-card {
      text-align: center;
      padding: clamp(1.5rem, 3vw, 2rem) 1rem;
      border: 2px solid var(--border);
      border-radius: var(--radius);
      background: var(--bg-white);
      transition: border-color 0.3s, box-shadow 0.3s;
    }
    .stat-card:hover {
      border-color: var(--teal);
      box-shadow: var(--card-shadow);
    }
    .stat-num {
      font-size: clamp(1.8rem, 4vw, 2.6rem);
      font-weight: 700;
      color: var(--teal);
      line-height: 1.1;
      margin-bottom: 0.35rem;
    }
    .stat-label {
      font-size: 0.88rem;
      font-weight: 500;
      color: var(--text-muted);
    }
    @media (max-width: 768px) {
      .stats-grid { grid-template-columns: repeat(2, 1fr); }
    }

    /* ===== SERVICES ===== */
    .services-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }
    .service-card {
      padding: clamp(1.5rem, 3vw, 2rem);
      background: var(--bg-white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      transition: box-shadow 0.3s, border-color 0.3s, transform 0.2s;
    }
    .service-card:hover {
      box-shadow: var(--card-shadow-hover);
      border-color: rgba(71, 198, 192, 0.3);
      transform: translateY(-2px);
    }
    .service-icon {
      width: 48px;
      height: 48px;
      border-radius: var(--radius);
      background: var(--teal-light);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--teal);
      margin-bottom: 1.25rem;
    }
    .service-icon svg { width: 24px; height: 24px; }
    .service-card h3 {
      font-size: 1.15rem;
      font-weight: 700;
      color: var(--navy);
      margin-bottom: 0.6rem;
    }
    .service-card p {
      font-size: 0.95rem;
      color: var(--text-muted);
      line-height: 1.65;
    }
    @media (max-width: 640px) {
      .services-grid { grid-template-columns: 1fr; }
    }

    /* ===== PROCESS ===== */
    .process-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
      position: relative;
    }
    .process-grid::before {
      content: '';
      position: absolute;
      top: 32px;
      left: 12.5%;
      width: 75%;
      height: 2px;
      background: linear-gradient(90deg, var(--teal), rgba(71, 198, 192, 0.2));
      z-index: 0;
    }
    .process-step {
      text-align: center;
      position: relative;
      z-index: 1;
    }
    .process-num {
      width: 64px;
      height: 64px;
      border-radius: 50%;
      background: var(--teal);
      color: #fff;
      font-weight: 700;
      font-size: 1.25rem;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1rem;
      box-shadow: 0 4px 16px rgba(71, 198, 192, 0.25);
    }
    .process-step h3 {
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--navy);
      margin-bottom: 0.35rem;
    }
    .process-step p {
      font-size: 0.9rem;
      color: var(--text-muted);
      line-height: 1.5;
    }
    @media (max-width: 768px) {
      .process-grid { grid-template-columns: repeat(2, 1fr); }
      .process-grid::before { display: none; }
    }
    @media (max-width: 480px) {
      .process-grid { grid-template-columns: 1fr; max-width: 320px; margin-left: auto; margin-right: auto; }
    }

    /* ===== REVIEWS ===== */
    .reviews-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
    .review-card {
      background: var(--bg-white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: clamp(1.5rem, 3vw, 2rem);
      transition: box-shadow 0.3s, transform 0.2s;
      display: flex;
      flex-direction: column;
    }
    .review-card:hover {
      box-shadow: var(--card-shadow-hover);
      transform: translateY(-2px);
    }
    .review-stars {
      display: flex;
      gap: 2px;
      margin-bottom: 1rem;
    }
    .review-stars svg { width: 18px; height: 18px; }
    .review-text {
      font-size: 0.98rem;
      color: var(--text-body);
      line-height: 1.7;
      flex: 1;
      margin-bottom: 1.25rem;
      font-style: italic;
    }
    .review-author {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding-top: 1rem;
      border-top: 1px solid var(--border-light);
    }
    .review-avatar {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: var(--teal-light);
      color: var(--teal);
      font-weight: 700;
      font-size: 0.85rem;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .review-name {
      font-weight: 600;
      color: var(--navy);
      font-size: 0.92rem;
    }
    .review-loc {
      font-size: 0.82rem;
      color: var(--text-light);
    }
    @media (max-width: 768px) {
      .reviews-grid { grid-template-columns: 1fr; max-width: 480px; }
    }

    /* ===== FAQ ===== */
    .faq-list {
      max-width: 700px;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .faq-item {
      border: 1px solid var(--border);
      border-radius: var(--radius);
      background: var(--bg-white);
      overflow: hidden;
      transition: border-color 0.2s;
    }
    .faq-item[open] { border-color: rgba(71, 198, 192, 0.35); }
    .faq-item summary {
      padding: 1.15rem 1.5rem;
      font-weight: 600;
      font-size: 1rem;
      color: var(--navy);
      cursor: pointer;
      list-style: none;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      min-height: 52px;
      user-select: none;
      transition: background 0.2s;
    }
    .faq-item summary:hover { background: var(--teal-mist); }
    .faq-item summary::-webkit-details-marker { display: none; }
    .faq-item summary::marker { display: none; content: ''; }
    .faq-chevron {
      flex-shrink: 0;
      width: 28px;
      height: 28px;
      border-radius: 50%;
      background: var(--teal-light);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--teal);
      transition: transform 0.3s;
    }
    .faq-item[open] .faq-chevron { transform: rotate(180deg); }
    .faq-chevron svg { width: 16px; height: 16px; }
    .faq-body {
      padding: 0 1.5rem 1.25rem;
      font-size: 0.95rem;
      color: var(--text-muted);
      line-height: 1.7;
    }

    /* ===== CTA CARD ===== */
    .cta-section { padding: clamp(2rem, 5vw, 4rem) 0; }
    .cta-card {
      background: linear-gradient(135deg, var(--teal) 0%, #3bb8b3 100%);
      border-radius: var(--radius-lg);
      padding: clamp(2.5rem, 5vw, 4rem);
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .cta-card::before {
      content: '';
      position: absolute;
      top: -40%;
      right: -10%;
      width: 300px;
      height: 300px;
      background: rgba(255, 255, 255, 0.08);
      border-radius: 50%;
      pointer-events: none;
    }
    .cta-card::after {
      content: '';
      position: absolute;
      bottom: -30%;
      left: -5%;
      width: 200px;
      height: 200px;
      background: rgba(255, 255, 255, 0.05);
      border-radius: 50%;
      pointer-events: none;
    }
    .cta-card > * { position: relative; z-index: 1; }
    .cta-card h2 {
      font-size: clamp(1.6rem, 4vw, 2.2rem);
      font-weight: 700;
      color: var(--navy);
      margin-bottom: 0.5rem;
      letter-spacing: -0.01em;
    }
    .cta-card .cta-sub {
      font-size: 1.05rem;
      color: rgba(30, 42, 56, 0.75);
      margin-bottom: 2rem;
      font-weight: 500;
    }
    .cta-phone-big {
      font-size: clamp(1.8rem, 4.5vw, 2.8rem);
      font-weight: 700;
      color: var(--navy);
      margin-bottom: 0.5rem;
      letter-spacing: -0.01em;
    }
    .cta-email {
      font-size: 1rem;
      color: rgba(30, 42, 56, 0.7);
      margin-bottom: 2rem;
      font-weight: 500;
    }
    .cta-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      background: var(--navy);
      color: #fff;
      font-weight: 600;
      font-size: 1.05rem;
      padding: 0.9rem 2.25rem;
      border-radius: var(--radius-sm);
      transition: background 0.2s, transform 0.15s;
      min-height: 50px;
      box-shadow: 0 4px 16px rgba(30, 42, 56, 0.2);
    }
    .cta-btn:hover { background: var(--navy-light); transform: translateY(-1px); }
    .cta-btn svg { width: 20px; height: 20px; }

    /* ===== FOOTER ===== */
    .footer {
      background: var(--navy);
      color: rgba(255, 255, 255, 0.65);
      padding: clamp(2rem, 4vw, 3rem) 0;
    }
    .footer-inner {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: center;
      gap: 1.5rem;
    }
    .footer-info h4 {
      color: #fff;
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: 0.4rem;
    }
    .footer-info p {
      font-size: 0.9rem;
      line-height: 1.6;
    }
    .footer-info a { color: var(--teal); transition: opacity 0.2s; }
    .footer-info a:hover { opacity: 0.8; }
    .footer-credit {
      font-size: 0.82rem;
      color: rgba(255, 255, 255, 0.4);
