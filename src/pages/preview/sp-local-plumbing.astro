const icons: Record<string, string> = {
  phone: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`,
  starFill: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="#fad26e" stroke="#fad26e" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
  check: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`,
  plus: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>`,
  minus: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/></svg>`,
  bath: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12h16a1 1 0 0 1 1 1v3a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4v-3a1 1 0 0 1 1-1z"/><path d="M6 12V5a2 2 0 0 1 2-2h1a2 2 0 0 1 2 2v1"/><line x1="6" y1="20" x2="6" y2="22"/><line x1="18" y1="20" x2="18" y2="22"/></svg>`,
  refresh: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>`,
  pencil: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>`,
  grid: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>`,
  shield: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  quote: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" opacity="0.15"><path d="M3 21c3-3 4.5-6 4.5-9H3V3h9v9c0 4.5-3 9-6 12l-3-3zm12 0c3-3 4.5-6 4.5-9H15V3h9v9c0 4.5-3 9-6 12l-3-3z"/></svg>`,
  droplet: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg>`,
  tag: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>`,
  mapPin: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
  star: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
};

const serviceIconMap: Record<string, string> = {
  bath: icons.bath,
  refresh: icons.refresh,
  pencil: icons.pencil,
  grid: icons.grid,
};

function renderStars(count: number): string {
  return Array.from({ length: count }, () => icons.starFill).join("");
}

function getInitials(name: string): string {
  return name.slice(0, 2).toUpperCase();
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{config.business_name} | Bathroom Installations Bristol & Bath</title>
  <meta name="description" content={`${config.business_name} - bathroom installation specialists in Bristol & Bath. Fixed labour pricing, no hidden costs. Full fit-outs, refurbishments, and custom designs. Call ${config.phone_display}.`} />

  {/* OG Meta Tags */}
  <meta property="og:title" content={`${config.business_name} | Bathroom Installations Bristol & Bath`} />
  <meta property="og:description" content="Full bathroom installations across Bristol & Bath. Fixed labour pricing, no hidden costs. 5-star rated on Google." />
  <meta property="og:type" content="website" />
  <meta property="og:image" content={config.logo_url} />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={`${config.business_name} | Bathroom Installations Bristol & Bath`} />
  <meta name="twitter:description" content="Full bathroom installations across Bristol & Bath. Fixed labour pricing, no hidden costs." />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  {/* LocalBusiness JSON-LD */}
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": config.schema_type,
    "name": config.business_name,
    "telephone": config.phone,
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Bristol",
      "addressRegion": "Somerset",
      "addressCountry": "GB",
    },
    "areaServed": config.areas_served.map(a => ({ "@type": "Place", "name": a })),
    "openingHours": config.hours,
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5.0",
      "reviewCount": "20",
    },
    "image": config.logo_url,
    "priceRange": "$$",
  })} />

  {/* FAQPage JSON-LD */}
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": config.faqs.map(faq => ({
      "@type": "Question",
      "name": faq.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.a,
      }
    })),
  })} />
</head>

<body>

  {/* ============================================================ */}
  {/* STICKY HEADER                                                 */}
  {/* ============================================================ */}
  <header class="site-header" id="site-header">
    <nav class="header-inner">
      <div class="header-left">
        <a href="#" class="logo-link">
          <img src={config.logo_url} alt={`${config.business_name} logo`} class="logo-img" width="160" height="44" />
          <span class="logo-name">SP Local</span>
        </a>
      </div>
      <div class="header-right">
        <a href={`tel:${config.phone}`} class="header-phone-link">
          <span class="header-phone-icon" set:html={icons.phone} />
          <span class="header-phone-number">{config.phone_display}</span>
        </a>
        <button class="nav-toggle" id="nav-toggle" aria-label="Open menu" aria-expanded="false">
          <span class="bar"></span>
          <span class="bar"></span>
          <span class="bar"></span>
        </button>
      </div>
      <div class="nav-dropdown" id="nav-dropdown">
        <a href="#services" class="nav-dropdown-link">Services</a>
        <a href="#process" class="nav-dropdown-link">How It Works</a>
        <a href="#reviews" class="nav-dropdown-link">Reviews</a>
        <a href="#faq" class="nav-dropdown-link">FAQ</a>
        <a href={`tel:${config.phone}`} class="nav-dropdown-cta">
          <span set:html={icons.phone} /> Call {config.phone_display}
        </a>
      </div>
    </nav>
  </header>

  <main>

    {/* ============================================================ */}
    {/* HERO                                                         */}
    {/* ============================================================ */}
    <section class="hero">
      <div class="hero-glow"></div>
      <div class="hero-glow-2"></div>
      <div class="container">
        <div class="hero-content">
          <div class="hero-badge">
            <span class="hero-badge-icon" set:html={icons.shield} />
            <span>5-Star Rated Bathroom Specialists</span>
          </div>
          <h1 class="hero-title">
            <span class="hero-title-line">Bathroom Installations</span>
            <span class="hero-title-accent">Done Right.</span>
          </h1>
          <p class="hero-subtitle">{config.hero_subtitle}</p>
          <div class="hero-cta-group">
            <a href={`tel:${config.phone}`} class="btn btn-gold btn-lg">
              <span set:html={icons.phone} />
              Call {config.phone_display}
            </a>
            <span class="hero-microcopy">Free quote, no obligation</span>
          </div>
        </div>
      </div>
    </section>

    {/* ============================================================ */}
    {/* TRUST STRIP                                                  */}
    {/* ============================================================ */}
    <section class="trust-strip" aria-label="Credentials">
      <div class="container">
        <div class="trust-strip-inner">
          {config.trust_signals.map((signal) => (
            <div class="trust-item">
              <span class="trust-item-icon" set:html={icons.check} />
              <span class="trust-item-label">{signal}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ============================================================ */}
    {/* STATS                                                        */}
    {/* ============================================================ */}
    <section class="stats reveal" aria-label="Key statistics">
      <div class="container">
        <div class="stats-grid">
          {config.stats.map((stat, i) => (
            <div class="stat-item" style={`--delay: ${i * 0.1}s`}>
              <span class="stat-num">{stat.num}</span>
              <span class="stat-label">{stat.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ============================================================ */}
    {/* FIXED PRICING CALLOUT                                        */}
    {/* ============================================================ */}
    <section class="pricing-callout reveal">
      <div class="container">
        <div class="pricing-card">
          <div class="pricing-card-inner">
            <div class="pricing-icon" set:html={icons.tag} />
            <div class="pricing-text">
              <h2 class="pricing-title">Fixed Labour Pricing</h2>
              <p class="pricing-desc">You get a clear, fixed price for all labour before work starts. No hourly rates, no surprises, no hidden costs. What we quote is what you pay.</p>
            </div>
            <a href={`tel:${config.phone}`} class="btn btn-gold btn-md pricing-btn">Get a Fixed Quote</a>
          </div>
        </div>
      </div>
    </section>

    {/* ============================================================ */}
    {/* SERVICES                                                     */}
    {/* ============================================================ */}
    <section class="services reveal" id="services">
      <div class="container">
        <div class="section-header">
          <span class="section-label">Our Services</span>
          <h2 class="section-title">Everything Your Bathroom Needs</h2>
          <p class="section-subtitle">From a full fit-out to a simple refresh - we handle the lot.</p>
        </div>
        <div class="services-grid">
          {config.services.map((service, i) => (
            <div class="service-card" style={`--delay: ${i * 0.1}s`}>
              <div class="service-icon" set:html={serviceIconMap[service.icon]} />
              <h3 class="service-title">{service.title}</h3>
              <p class="service-desc">{service.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ============================================================ */}
    {/* HOW IT WORKS                                                 */}
    {/* ============================================================ */}
    <section class="process reveal" id="process">
      <div class="container">
        <div class="section-header">
          <span class="section-label">How It Works</span>
          <h2 class="section-title">From First Call to Finished Bathroom</h2>
          <p class="section-subtitle">Simple, transparent, stress-free.</p>
        </div>
        <div class="process-grid">
          {config.process.map((step, i) => (
            <div class="process-step" style={`--delay: ${i * 0.12}s`}>
              <div class="process-number">{step.step}</div>
              <div class="process-line"></div>
              <h3 class="process-title">{step.title}</h3>
              <p class="process-desc">{step.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ============================================================ */}
    {/* REVIEWS                                                      */}
    {/* ============================================================ */}
    <section class="reviews reveal" id="reviews">
      <div class="container">
        <div class="section-header">
          <span class="section-label">Reviews</span>
          <h2 class="section-title">What Our Customers Say</h2>
          <p class="section-subtitle">Real reviews from real people across Bristol & Bath.</p>
        </div>
        <div class="reviews-grid">
          {config.reviews.map((review, i) => (
            <div class="review-card" style={`--delay: ${i * 0.1}s`}>
              <div class="review-quote-mark" set:html={icons.quote} />
              <div class="review-stars" set:html={renderStars(review.stars)} />
              <blockquote class="review-text">&ldquo;{review.text}&rdquo;</blockquote>
              <div class="review-author">
                <div class="review-avatar">{getInitials(review.name)}</div>
                <div class="review-meta">
                  <span class="review-name">{review.name}</span>
                  <span class="review-location">{review.location}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ============================================================ */}
    {/* FAQ                                                          */}
    {/* ============================================================ */}
    <section class="faq reveal" id="faq">
      <div class="container">
        <div class="section-header">
          <span class="section-label">FAQ</span>
          <h2 class="section-title">Frequently Asked Questions</h2>
        </div>
        <div class="faq-list">
          {config.faqs.map((faq, i) => (
            <details class="faq-item" style={`--delay: ${i * 0.08}s`}>
              <summary class="faq-question">
                <span>{faq.q}</span>
                <span class="faq-icon faq-icon-plus" set:html={icons.plus} />
                <span class="faq-icon faq-icon-minus" set:html={icons.minus} />
              </summary>
              <div class="faq-answer">
                <p>{faq.a}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    {/* ============================================================ */}
    {/* FINAL CTA                                                    */}
    {/* ============================================================ */}
    <section class="final-cta reveal">
      <div class="container">
        <div class="final-cta-card">
          <div class="final-cta-glow"></div>
          <h2 class="final-cta-title">Ready for Your New Bathroom?</h2>
          <p class="final-cta-subtitle">Get a free, fixed-price quote. No obligation, no hidden costs.</p>
          <a href={`tel:${config.phone}`} class="btn btn-gold btn-lg">
            <span set:html={icons.phone} />
            Call {config.phone_display}
          </a>
          <p class="final-cta-areas">Serving {config.areas_served.join(", ")}</p>
        </div>
      </div>
    </section>

  </main>

  {/* ============================================================ */}
  {/* FOOTER                                                       */}
  {/* ============================================================ */}
  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-col">
          <img src={config.logo_url} alt={`${config.business_name} logo`} class="footer-logo" width="140" height="38" />
          <p class="footer-text">Bathroom installation specialists in Bristol & Bath. Fixed labour pricing, no hidden costs.</p>
        </div>
        <div class="footer-col">
          <h4 class="footer-heading">Contact</h4>
          <ul class="footer-list">
            <li><a href={`tel:${config.phone}`}>{config.phone_display}</a></li>
            <li>{config.address}</li>
          </ul>
        </div>
        <div class="footer-col">
          <h4 class="footer-heading">Services</h4>
          <ul class="footer-list">
            <li>Full Bathroom Installations</li>
            <li>Bathroom Refurbishment</li>
            <li>Custom Design & Planning</li>
            <li>Plumbing & Tiling</li>
          </ul>
        </div>
        <div class="footer-col">
          <h4 class="footer-heading">Hours</h4>
          <p class="footer-text">Mon - Fri: 8am - 6pm</p>
          <p class="footer-text">Sat: 9am - 4pm</p>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; {new Date().getFullYear()} {config.business_name}. All rights reserved.</p>
        <p class="footer-credit">Website by <a href="https://highcroftdigital.com" target="_blank" rel="noopener">Highcroft Digital</a></p>
      </div>
    </div>
  </footer>

  {/* ============================================================ */}
  {/* FLOATING PHONE BUTTON - mobile only                          */}
  {/* ============================================================ */}
  <a href={`tel:${config.phone}`} class="floating-phone" aria-label={`Call ${config.business_name}`}>
    <span set:html={icons.phone} />
  </a>

</body>
</html>

<style>
  /* ============================================================
     RESET & BASE
     ============================================================ */
  *, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
    scroll-padding-top: 72px;
  }

  body {
    font-family: "Outfit", sans-serif;
    font-size: 1rem;
    line-height: 1.6;
    color: #c8ccd4;
    background: #111115;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  img {
    max-width: 100%;
    height: auto;
    display: block;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  ul {
    list-style: none;
  }

  /* ============================================================
     LAYOUT
     ============================================================ */
  .container {
    width: 100%;
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 20px;
  }

  @media (min-width: 768px) {
    .container {
      padding: 0 32px;
    }
  }

  /* ============================================================
     STICKY HEADER
     ============================================================ */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(17, 17, 21, 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 20px;
    height: 64px;
    position: relative;
  }

  @media (min-width: 768px) {
    .header-inner {
      padding: 0 32px;
      height: 72px;
    }
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .logo-link {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }

  .logo-name {
    font-size: 1rem;
    font-weight: 700;
    color: #fad26e;
    letter-spacing: 0.02em;
  }

  .logo-img {
    height: 34px;
    width: auto;
    object-fit: contain;
  }

  @media (min-width: 768px) {
    .logo-img {
      height: 40px;
    }
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .header-phone-link {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    color: #fad26e;
    transition: color 0.2s;
    padding: 8px 0;
  }

  .header-phone-link:hover {
    color: #fff;
  }

  .header-phone-icon {
    display: flex;
    align-items: center;
  }

  .header-phone-icon svg {
    width: 18px;
    height: 18px;
  }

  .header-phone-number {
    display: none;
  }

  @media (min-width: 480px) {
    .header-phone-number {
      display: inline;
    }
  }

  /* Nav toggle (hamburger) */
  .nav-toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    width: 44px;
    height: 44px;
  }

  @media (min-width: 768px) {
    .nav-toggle {
      display: none;
    }
  }

  .bar {
    display: block;
    width: 22px;
    height: 2px;
    background: #e0e4ec;
    border-radius: 2px;
    transition: transform 0.25s, opacity 0.25s;
  }

  .nav-toggle.is-active .bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .nav-toggle.is-active .bar:nth-child(2) {
    opacity: 0;
  }

  .nav-toggle.is-active .bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Nav dropdown (mobile) */
  .nav-dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: #19191f;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4);
    z-index: 200;
    flex-direction: column;
    padding: 8px 0;
  }

  .nav-dropdown.is-open {
    display: flex;
  }

  @media (min-width: 768px) {
    .nav-dropdown {
      display: none !important;
    }
  }

  .nav-dropdown-link {
    padding: 14px 24px;
    font-weight: 500;
    font-size: 1rem;
    color: #c8ccd4;
    transition: background 0.15s, color 0.15s;
  }

  .nav-dropdown-link:hover {
    background: rgba(250, 210, 110, 0.06);
    color: #fad26e;
  }

  .nav-dropdown-cta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin: 8px 16px;
    padding: 14px 20px;
    background: #fad26e;
    color: #111115;
    border-radius: 10px;
    font-weight: 700;
    font-size: 1rem;
    justify-content: center;
    transition: background 0.2s;
  }

  .nav-dropdown-cta:hover {
    background: #f5c33a;
  }

  .nav-dropdown-cta svg {
    width: 18px;
    height: 18px;
  }

  /* ============================================================
     HERO
     ============================================================ */
  .hero {
    background: #111115;
    padding: 80px 0 64px;
    position: relative;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .hero {
      padding: 110px 0 90px;
    }
  }

  .hero-glow {
    position: absolute;
    top: -30%;
    right: -15%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(250, 210, 110, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-glow-2 {
    position: absolute;
    bottom: -40%;
    left: -10%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(250, 210, 110, 0.04) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-content {
    max-width: 680px;
    text-align: center;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(250, 210, 110, 0.08);
    border: 1px solid rgba(250, 210, 110, 0.15);
    color: #fad26e;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 8px 16px;
    border-radius: 100px;
    margin-bottom: 28px;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .hero-badge-icon {
    display: flex;
    align-items: center;
  }

  .hero-badge-icon svg {
    width: 14px;
    height: 14px;
    stroke: #fad26e;
  }

  .hero-title {
    font-size: clamp(2.2rem, 7vw, 3.6rem);
    font-weight: 700;
    color: #fff;
    line-height: 1.1;
    margin-bottom: 20px;
    letter-spacing: -0.03em;
  }

  .hero-title-line {
    display: block;
  }

  .hero-title-accent {
    display: block;
    color: #fad26e;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2.5vw, 1.15rem);
    color: #8b8f9a;
    line-height: 1.7;
    margin-bottom: 36px;
    max-width: 540px;
    margin-left: auto;
    margin-right: auto;
    font-weight: 400;
  }

  .hero-cta-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
  }

  .hero-microcopy {
    font-size: 0.85rem;
    color: #5c5f69;
    font-weight: 400;
  }

  /* ============================================================
     BUTTONS
     ============================================================ */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-family: inherit;
    font-weight: 600;
    font-size: 1rem;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    text-decoration: none;
    line-height: 1;
  }

  .btn:active {
    transform: scale(0.97);
  }

  .btn svg {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .btn-gold {
    background: #fad26e;
    color: #111115;
    box-shadow: 0 2px 12px rgba(250, 210, 110, 0.2);
  }

  .btn-gold:hover {
    background: #f5c33a;
    box-shadow: 0 4px 20px rgba(250, 210, 110, 0.3);
  }

  .btn-lg {
    padding: 16px 32px;
    font-size: 1.05rem;
    min-height: 56px;
  }

  .btn-md {
    padding: 12px 24px;
    font-size: 0.95rem;
    min-height: 48px;
  }

  /* ============================================================
     TRUST STRIP
     ============================================================ */
  .trust-strip {
    background: #19191f;
    border-top: 1px solid rgba(250, 210, 110, 0.08);
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    padding: 18px 0;
  }

  .trust-strip-inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px 28px;
  }

  @media (min-width: 768px) {
    .trust-strip-inner {
      gap: 12px 48px;
    }
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 0;
  }

  .trust-item-icon {
    display: flex;
    align-items: center;
    color: #fad26e;
  }

  .trust-item-icon svg {
    width: 16px;
    height: 16px;
  }

  .trust-item-label {
    font-size: 0.85rem;
    font-weight: 500;
    color: #a0a4ae;
    white-space: nowrap;
  }

  /* ============================================================
     STATS
     ============================================================ */
  .stats {
    padding: 56px 0;
    background: #111115;
  }

  @media (min-width: 768px) {
    .stats {
      padding: 72px 0;
    }
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  @media (min-width: 640px) {
    .stats-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 32px;
    }
  }

  .stat-item {
    text-align: center;
    padding: 20px 8px;
    background: #19191f;
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.04);
  }

  .stat-num {
    display: block;
    font-size: clamp(1.8rem, 5vw, 2.4rem);
    font-weight: 700;
    color: #fad26e;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .stat-label {
    display: block;
    font-size: 0.85rem;
    font-weight: 400;
    color: #6b6f7a;
    margin-top: 6px;
  }

  /* ============================================================
     PRICING CALLOUT
     ============================================================ */
  .pricing-callout {
    padding: 0 0 64px;
    background: #111115;
  }

  @media (min-width: 768px) {
    .pricing-callout {
      padding: 0 0 80px;
    }
  }

  .pricing-card {
    background: linear-gradient(135deg, rgba(250, 210, 110, 0.06) 0%, rgba(250, 210, 110, 0.02) 100%);
    border: 1px solid rgba(250, 210, 110, 0.12);
    border-radius: 18px;
    padding: 2px;
  }

  .pricing-card-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 20px;
    padding: 36px 24px;
  }

  @media (min-width: 768px) {
    .pricing-card-inner {
      flex-direction: row;
      text-align: left;
      gap: 28px;
      padding: 40px 40px;
    }
  }

  .pricing-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    background: rgba(250, 210, 110, 0.1);
    border-radius: 14px;
    color: #fad26e;
    flex-shrink: 0;
  }

  .pricing-icon svg {
    width: 26px;
    height: 26px;
  }

  .pricing-text {
    flex: 1;
  }

  .pricing-title {
    font-size: 1.3rem;
    font-weight: 700;
    color: #fad26e;
    margin-bottom: 6px;
  }

  .pricing-desc {
    font-size: 0.95rem;
    color: #8b8f9a;
    line-height: 1.6;
  }

  .pricing-btn {
    flex-shrink: 0;
    white-space: nowrap;
  }

  /* ============================================================
     SECTION HEADERS
     ============================================================ */
  .section-header {
    text-align: center;
    margin-bottom: 44px;
  }

  @media (min-width: 768px) {
    .section-header {
      margin-bottom: 56px;
    }
  }

  .section-label {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    color: #fad26e;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 12px;
  }

  .section-title {
    font-size: clamp(1.5rem, 4vw, 2.1rem);
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.02em;
    margin-bottom: 12px;
  }

  .section-subtitle {
    font-size: 1rem;
    color: #6b6f7a;
    max-width: 520px;
    margin: 0 auto;
    font-weight: 400;
  }

  /* ============================================================
     SERVICES
     ============================================================ */
  .services {
    padding: 72px 0;
    background: #19191f;
  }

  @media (min-width: 768px) {
    .services {
      padding: 96px 0;
    }
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  @media (min-width: 600px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
  }

  .service-card {
    background: #111115;
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 16px;
    padding: 32px 28px;
    transition: border-color 0.25s, box-shadow 0.25s;
  }

  .service-card:hover {
    border-color: rgba(250, 210, 110, 0.2);
    box-shadow: 0 4px 24px rgba(250, 210, 110, 0.04);
  }

  .service-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: rgba(250, 210, 110, 0.08);
    border-radius: 12px;
    color: #fad26e;
    margin-bottom: 20px;
  }

  .service-icon svg {
    width: 24px;
    height: 24px;
  }

  .service-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: #fff;
    margin-bottom: 8px;
  }

  .service-desc {
    font-size: 0.92rem;
    color: #6b6f7a;
    line-height: 1.6;
  }

  /* ============================================================
     PROCESS
     ============================================================ */
  .process {
    padding: 72px 0;
    background: #111115;
  }

  @media (min-width: 768px) {
    .process {
      padding: 96px 0;
    }
  }

  .process-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media (min-width: 640px) {
    .process-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }
  }

  @media (min-width: 900px) {
    .process-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
    }
  }

  .process-step {
    text-align: center;
    padding: 32px 20px;
    position: relative;
  }

  .process-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(250, 210, 110, 0.1);
    border: 2px solid rgba(250, 210, 110, 0.2);
    color: #fad26e;
    font-size: 0.9rem;
    font-weight: 700;
    margin-bottom: 20px;
  }

  .process-line {
    display: none;
  }

  @media (min-width: 900px) {
    .process-line {
      display: block;
      position: absolute;
      top: 55px;
      left: calc(50% + 36px);
      width: calc(100% - 72px);
      height: 1px;
      background: rgba(250, 210, 110, 0.12);
    }

    .process-step:last-child .process-line {
      display: none;
    }
  }

  .process-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: #fff;
    margin-bottom: 6px;
  }

  .process-desc {
    font-size: 0.9rem;
    color: #6b6f7a;
    line-height: 1.6;
  }

  /* ============================================================
     REVIEWS
     ============================================================ */
  .reviews {
    padding: 72px 0;
    background: #19191f;
  }

  @media (min-width: 768px) {
    .reviews {
      padding: 96px 0;
    }
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  @media (min-width: 640px) {
    .reviews-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 900px) {
    .reviews-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .review-card {
    background: #111115;
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 16px;
    padding: 32px 28px;
    position: relative;
    overflow: hidden;
  }

  .review-quote-mark {
    position: absolute;
    top: 20px;
    right: 20px;
    color: #fad26e;
  }

  .review-quote-mark svg {
    width: 36px;
    height: 36px;
  }

  .review-stars {
    display: flex;
    gap: 2px;
    margin-bottom: 18px;
  }

  .review-text {
    font-size: 0.95rem;
    color: #a0a4ae;
    line-height: 1.7;
    margin-bottom: 24px;
    font-style: normal;
  }

  .review-author {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .review-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(250, 210, 110, 0.12);
    color: #fad26e;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
    flex-shrink: 0;
    letter-spacing: 0.03em;
  }

  .review-meta {
    display: flex;
    flex-direction: column;
  }

  .review-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: #e0e4ec;
  }

  .review-location {
    font-size: 0.8rem;
    color: #5c5f69;
  }

  /* ============================================================
     FAQ
     ============================================================ */
  .faq {
    padding: 72px 0;
    background: #111115;
  }

  @media (min-width: 768px) {
    .faq {
      padding: 96px 0;
    }
  }

  .faq-list {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .faq-item {
    background: #19191f;
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .faq-item[open] {
    border-color: rgba(250, 210, 110, 0.2);
  }

  .faq-question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 20px;
    font-weight: 600;
    font-size: 1rem;
    color: #e0e4ec;
    cursor: pointer;
    list-style: none;
    user-select: none;
    min-height: 44px;
    transition: color 0.2s;
  }

  .faq-question:hover {
    color: #fad26e;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-question::marker {
    content: "";
  }

  .faq-icon {
    flex-shrink: 0;
    color: #5c5f69;
    display: flex;
    align-items: center;
    transition: color 0.2s;
  }

  .faq-item[open] .faq-icon {
    color: #fad26e;
  }

  .faq-icon-minus {
    display: none;
  }

  .faq-item[open] .faq-icon-plus {
    display: none;
  }

  .faq-item[open] .faq-icon-minus {
    display: flex;
  }

  .faq-answer {
    padding: 0 20px 20px;
    font-size: 0.95rem;
    color: #6b6f7a;
    line-height: 1.7;
  }

  /* ============================================================
     FINAL CTA
     ============================================================ */
  .final-cta {
    padding: 72px 0;
    background: #19191f;
  }

  @media (min-width: 768px) {
    .final-cta {
      padding: 96px 0;
    }
  }

  .final-cta-card {
    background: #111115;
    border: 1px solid rgba(250, 210, 110, 0.1);
    border-radius: 24px;
    padding: 56px 24px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .final-cta-card {
      padding: 72px 48px;
    }
  }

  .final-cta-glow {
    position: absolute;
    top: -50%;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(250, 210, 110, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .final-cta-title {
    font-size: clamp(1.5rem, 5vw, 2.2rem);
    font-weight: 700;
    color: #fff;
    margin-bottom: 12px;
    letter-spacing: -0.02em;
    position: relative;
    z-index: 1;
  }

  .final-cta-subtitle {
    font-size: 1rem;
    color: #6b6f7a;
    margin-bottom: 32px;
    max-width: 440px;
    margin-left: auto;
    margin-right: auto;
    position: relative;
    z-index: 1;
  }

  .final-cta .btn {
    position: relative;
    z-index: 1;
  }

  .final-cta-areas {
    margin-top: 20px;
    font-size: 0.85rem;
    color: #4a4d56;
    position: relative;
    z-index: 1;
  }

  /* ============================================================
     FOOTER
     ============================================================ */
  .site-footer {
    background: #0c0c10;
    color: #6b6f7a;
    padding: 56px 0 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
  }

  @media (min-width: 768px) {
    .site-footer {
      padding: 72px 0 32px;
    }
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    margin-bottom: 48px;
  }

  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 900px) {
    .footer-grid {
      grid-template-columns: 1.5fr 1fr 1fr 1fr;
    }
  }

  .footer-logo {
    height: 34px;
    width: auto;
    object-fit: contain;
    margin-bottom: 16px;
    opacity: 0.8;
  }

  .footer-heading {
    font-size: 0.85rem;
    font-weight: 600;
    color: #a0a4ae;
    margin-bottom: 14px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .footer-text {
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .footer-list li {
    font-size: 0.9rem;
    margin-bottom: 8px;
  }

  .footer-list a {
    transition: color 0.15s;
  }

  .footer-list a:hover {
    color: #fad26e;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.04);
    padding-top: 20px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    text-align: center;
    font-size: 0.82rem;
    color: #4a4d56;
  }

  @media (min-width: 640px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .footer-credit a {
    color: #fad26e;
    font-weight: 600;
    transition: color 0.15s;
  }

  .footer-credit a:hover {
    color: #fff;
  }

  /* ============================================================
     FLOATING PHONE BUTTON (mobile only)
     ============================================================ */
  .floating-phone {
    display: flex;
    align-items: center;
    justify-content: center;
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #fad26e;
    color: #111115;
    box-shadow: 0 4px 20px rgba(250, 210, 110, 0.3), 0 0 0 4px rgba(250, 210, 110, 0.1);
    z-index: 90;
    transition: background 0.2s, transform 0.15s;
  }

  .floating-phone:hover {
    background: #f5c33a;
  }

  .floating-phone:active {
    transform: scale(0.92);
  }

  .floating-phone svg {
    width: 24px;
    height: 24px;
  }

  @media (min-width: 768px) {
    .floating-phone {
      display: none;
    }
  }

  /* ============================================================
     SCROLL REVEAL ANIMATIONS
     ============================================================ */
  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }

  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Staggered children */
  .reveal.is-visible .stat-item,
  .reveal.is-visible .service-card,
  .reveal.is-visible .process-step,
  .reveal.is-visible .review-card,
  .reveal.is-visible .faq-item {
    animation: revealUp 0.5s ease forwards;
    animation-delay: var(--delay, 0s);
    opacity: 0;
  }

  @keyframes revealUp {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .reveal.is-visible .stat-item,
    .reveal.is-visible .service-card,
    .reveal.is-visible .process-step,
    .reveal.is-visible .review-card,
    .reveal.is-visible .faq-item {
      animation: none;
      opacity: 1;
    }
  }
</style>

<script>
  // ============================================================
  // NAV TOGGLE
  // ============================================================
  const navToggle = document.getElementById("nav-toggle");
  const navDropdown = document.getElementById("nav-dropdown");

  if (navToggle && navDropdown) {
    navToggle.addEventListener("click", () => {
      const isOpen = navDropdown.classList.toggle("is-open");
      navToggle.classList.toggle("is-active", isOpen);
      navToggle.setAttribute("aria-expanded", String(isOpen));
    });

    navDropdown.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        navDropdown.classList.remove("is-open");
        navToggle.classList.remove("is-active");
        navToggle.setAttribute("aria-expanded", "false");
      });
    });

    document.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      if (!navToggle.contains(target) && !navDropdown.contains(target)) {
        navDropdown.classList.remove("is-open");
        navToggle.classList.remove("is-active");
        navToggle.setAttribute("aria-expanded", "false");
      }
    });
  }

  // ============================================================
  // SCROLL REVEAL
  // ============================================================
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!prefersReducedMotion) {
    const revealElements = document.querySelectorAll(".reveal");

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        });
      },
      {
        threshold: 0.1,
        rootMargin: "0px 0px -40px 0px",
      }
    );

    revealElements.forEach((el) => observer.observe(el));
  } else {
    document.querySelectorAll(".reveal").forEach((el) => {
      el.classList.add("is-visible");
    });
  }

  // ============================================================
  // HEADER BLUR ON SCROLL
  // ============================================================
  const header = document.getElementById("site-header");

  if (header) {
    const onScroll = () => {
      if (window.scrollY > 8) {
        header.style.boxShadow = "0 2px 20px rgba(0, 0, 0, 0.3)";
      } else {
        header.style.boxShadow = "none";
      }
    };

    window.addEventListener("scroll", onScroll, { passive: true });
  }
</script>
