  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --indigo: #1a1836;
      --indigo-deep: #13112a;
      --indigo-mid: #23204a;
      --coral: #e8744a;
      --coral-hover: #d4633b;
      --coral-glow: rgba(232, 116, 74, 0.1);
      --text: #e8e6f0;
      --text-mid: #a09cb8;
      --text-dim: #6e6a86;
      --border: rgba(255, 255, 255, 0.06);
      --amber: #f0b429;
      --font: 'Sora', system-ui, sans-serif;
    }

    html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }
    body { font-family: var(--font); background: var(--indigo-deep); color: var(--text); line-height: 1.6; overflow-x: hidden; }
    a { color: inherit; }

    .nav { position: sticky; top: 0; z-index: 100; background: rgba(19,17,42,0.9); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border-bottom: 1px solid var(--border); padding: 0 clamp(20px,5vw,48px); height: 72px; display: flex; align-items: center; justify-content: space-between; }
    .logo-text { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.28em; text-transform: uppercase; }
    .logo-img { height: 44px; width: auto; object-fit: contain; }
    .nav-right { display: flex; align-items: center; gap: 8px; }
    .nav-links { display: flex; gap: 4px; list-style: none; }
    .nav-links a { color: var(--text-mid); text-decoration: none; font-size: 0.8rem; font-weight: 400; padding: 6px 14px; border-radius: 6px; transition: color 0.15s; letter-spacing: 0.02em; }
    .nav-links a:hover { color: var(--text); }
    .nav-cta { display: flex; align-items: center; gap: 6px; color: var(--coral); font-size: 0.82rem; font-weight: 600; text-decoration: none; padding: 8px 16px; border: 1px solid rgba(232,116,74,0.3); border-radius: 8px; transition: background 0.15s, border-color 0.15s; letter-spacing: 0.02em; }
    .nav-cta:hover { background: var(--coral-glow); border-color: rgba(232,116,74,0.5); }
    .nav-cta svg { width: 14px; height: 14px; }
    .nav-toggle { display: none; background: none; border: 1px solid var(--border); border-radius: 6px; cursor: pointer; width: 40px; height: 40px; align-items: center; justify-content: center; }
    .nav-toggle span { display: block; width: 18px; height: 1.5px; background: var(--text-mid); margin: 4px auto; transition: 0.2s; }

    .hero { padding: clamp(72px,14vw,140px) clamp(20px,5vw,48px) clamp(56px,10vw,100px); max-width: 640px; }
    .hero-tag { font-size: 0.68rem; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; color: var(--coral); margin-bottom: 24px; }
    .hero h1 { font-size: clamp(2rem,5.5vw,3.2rem); font-weight: 300; line-height: 1.12; letter-spacing: -0.02em; margin-bottom: 20px; }
    .hero h1 strong { font-weight: 600; color: var(--coral); }
    .hero-sub { font-size: clamp(0.9rem,1.5vw,1rem); color: var(--text-mid); max-width: 460px; line-height: 1.7; font-weight: 300; margin-bottom: 32px; }
    .hero-cta { display: inline-flex; align-items: center; gap: 8px; background: var(--coral); color: var(--indigo-deep); padding: 14px 28px; border-radius: 8px; font-size: 0.88rem; font-weight: 600; text-decoration: none; transition: transform 0.15s, box-shadow 0.15s; letter-spacing: 0.01em; }
    .hero-cta:hover { transform: translateY(-1px); box-shadow: 0 6px 24px rgba(232,116,74,0.2); }
    .hero-cta:active { transform: scale(0.97); }
    .hero-cta svg { width: 16px; height: 16px; }

    .creds { display: flex; gap: clamp(24px,5vw,48px); padding: clamp(24px,4vw,32px) clamp(20px,5vw,48px); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); flex-wrap: wrap; }
    .cred { font-size: 0.7rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-dim); display: flex; align-items: center; gap: 8px; }
    .cred::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--coral); flex-shrink: 0; }

    .about { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(32px,6vw,80px); padding: clamp(56px,10vw,100px) clamp(20px,5vw,48px); align-items: start; }
    .about-tag { font-size: 0.68rem; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; color: var(--coral); margin-bottom: 16px; }
    .about h2 { font-size: clamp(1.4rem,3vw,2rem); font-weight: 300; line-height: 1.2; letter-spacing: -0.01em; margin-bottom: 20px; }
    .about h2 strong { font-weight: 600; }
    .about p { font-size: 0.88rem; color: var(--text-mid); line-height: 1.7; font-weight: 300; }
    .about-right { padding-top: 48px; }
    .about-right p + p { margin-top: 16px; }

    .services { padding: clamp(56px,10vw,100px) clamp(20px,5vw,48px); border-top: 1px solid var(--border); }
    .stag { font-size: 0.68rem; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; color: var(--coral); margin-bottom: 16px; }
    .sh2 { font-size: clamp(1.4rem,3vw,2rem); font-weight: 300; letter-spacing: -0.01em; margin-bottom: clamp(32px,5vw,48px); }
    .services-list { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--border); }
    .svc { background: var(--indigo-deep); padding: clamp(24px,4vw,40px); transition: background 0.2s; }
    .svc:hover { background: var(--indigo); }
    .svc-num { font-size: 0.65rem; color: var(--coral); font-weight: 600; letter-spacing: 0.1em; margin-bottom: 12px; }
    .svc h3 { font-size: 1rem; font-weight: 500; margin-bottom: 8px; letter-spacing: -0.01em; }
    .svc p { font-size: 0.82rem; color: var(--text-mid); line-height: 1.55; font-weight: 300; }

    .process { padding: clamp(56px,10vw,100px) clamp(20px,5vw,48px); background: var(--indigo); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
    .steps { display: grid; grid-template-columns: repeat(4,1fr); gap: 2px; }
    .step { padding: 20px; text-align: center; }
    .step-num { font-size: 2rem; font-weight: 200; color: var(--coral); line-height: 1; margin-bottom: 12px; opacity: 0.7; }
    .step h4 { font-size: 0.85rem; font-weight: 500; margin-bottom: 4px; }
    .step p { font-size: 0.75rem; color: var(--text-dim); font-weight: 300; }

    .reviews { padding: clamp(56px,10vw,100px) clamp(20px,5vw,48px); }
    .reviews-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .review { border: 1px solid var(--border); border-radius: 8px; padding: clamp(20px,3vw,28px); transition: border-color 0.2s; }
    .review:hover { border-color: rgba(255,255,255,0.1); }
    .review-stars { display: flex; gap: 2px; color: var(--amber); margin-bottom: 12px; }
    .review-stars svg { width: 13px; height: 13px; }
    .review q { display: block; font-size: 0.85rem; color: var(--text-mid); line-height: 1.6; font-style: normal; font-weight: 300; margin-bottom: 16px; }
    .review-author { display: flex; align-items: center; gap: 8px; }
    .review-dot { width: 28px; height: 28px; border-radius: 50%; background: var(--coral-glow); border: 1px solid rgba(232,116,74,0.2); display: flex; align-items: center; justify-content: center; font-size: 0.6rem; font-weight: 600; color: var(--coral); }
    .review-name { font-size: 0.78rem; font-weight: 500; }
    .review-loc { font-size: 0.68rem; color: var(--text-dim); }

    .faq { padding: clamp(56px,10vw,100px) clamp(20px,5vw,48px); max-width: 640px; border-top: 1px solid var(--border); }
    .faq details { border-bottom: 1px solid var(--border); }
    .faq summary { display: flex; justify-content: space-between; align-items: center; padding: 18px 0; cursor: pointer; font-size: 0.88rem; font-weight: 400; list-style: none; letter-spacing: 0.01em; -webkit-tap-highlight-color: transparent; }
    .faq summary::-webkit-details-marker { display: none; }
    .faq summary::after { content: '+'; font-size: 1.1rem; color: var(--text-dim); font-weight: 300; }
    .faq details[open] summary::after { content: '-'; }
    .faq-a { padding: 0 0 18px; font-size: 0.82rem; color: var(--text-mid); line-height: 1.65; font-weight: 300; }

    .cta { margin: clamp(24px,4vw,48px) clamp(20px,5vw,48px); border: 1px solid rgba(232,116,74,0.15); border-radius: 16px; padding: clamp(40px,7vw,64px); text-align: center; background: var(--indigo); }
    .cta h2 { font-size: clamp(1.4rem,3.5vw,2rem); font-weight: 300; letter-spacing: -0.01em; margin-bottom: 8px; }
    .cta-sub { color: var(--text-mid); font-size: 0.88rem; font-weight: 300; max-width: 380px; margin: 0 auto 24px; }
    .cta-phone { display: block; font-size: clamp(1.6rem,4vw,2.2rem); font-weight: 600; color: var(--coral); text-decoration: none; letter-spacing: -0.02em; margin-bottom: 6px; transition: opacity 0.15s; }
    .cta-phone:hover { opacity: 0.8; }
    .cta-email { color: var(--text-dim); text-decoration: none; font-size: 0.82rem; font-weight: 400; display: inline-block; margin-bottom: 24px; transition: color 0.15s; }
    .cta-email:hover { color: var(--text-mid); }
    .cta-btn { display: inline-flex; align-items: center; gap: 8px; background: var(--coral); color: var(--indigo-deep); padding: 12px 24px; border-radius: 8px; font-size: 0.85rem; font-weight: 600; text-decoration: none; transition: transform 0.15s, box-shadow 0.15s; }
    .cta-btn:hover { transform: translateY(-1px); box-shadow: 0 4px 16px rgba(232,116,74,0.2); }
    .cta-btn svg { width: 15px; height: 15px; }
    .cta-areas { margin-top: 16px; font-size: 0.7rem; color: var(--text-dim); letter-spacing: 0.08em; text-transform: uppercase; }

    .footer { padding: clamp(32px,5vw,48px) clamp(20px,5vw,48px); border-top: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; font-size: 0.7rem; color: var(--text-dim); }
    .footer a { color: var(--text-dim); text-decoration: none; transition: color 0.15s; }
    .footer a:hover { color: var(--coral); }

    .float-phone { display: none; position: fixed; bottom: 20px; right: 20px; z-index: 90; width: 52px; height: 52px; border-radius: 50%; background: var(--coral); color: var(--indigo-deep); align-items: center; justify-content: center; text-decoration: none; box-shadow: 0 4px 20px rgba(232,116,74,0.3); }
    .float-phone svg { width: 20px; height: 20px; }

    .rv { opacity: 0; transform: translateY(14px); transition: opacity 0.6s cubic-bezier(0.16,1,0.3,1), transform 0.6s cubic-bezier(0.16,1,0.3,1); }
    .rv.vis { opacity: 1; transform: none; }
    .rv-d1 { transition-delay: 0.06s; }
    .rv-d2 { transition-delay: 0.12s; }
    .rv-d3 { transition-delay: 0.18s; }

    @media (max-width: 768px) {
      .nav-links { display: none; }
      .nav-links.open { display: flex; flex-direction: column; position: absolute; top: 72px; left: 0; right: 0; background: var(--indigo-deep); padding: 12px 20px; border-bottom: 1px solid var(--border); box-shadow: 0 16px 40px rgba(0,0,0,0.3); z-index: 200; gap: 2px; }
      .nav-links.open a { padding: 12px 8px; font-size: 0.92rem; }
      .nav-toggle { display: flex; }
      .about { grid-template-columns: 1fr; }
      .about-right { padding-top: 0; }
      .services-list { grid-template-columns: 1fr; }
      .steps { grid-template-columns: repeat(2, 1fr); }
      .reviews-grid { grid-template-columns: 1fr; }
      .footer { flex-direction: column; gap: 6px; text-align: center; }
      .float-phone { display: flex; }
    }

    @media (max-width: 480px) {
      .steps { grid-template-columns: 1fr; }
      .creds { flex-direction: column; gap: 12px; }
    }

    @media (prefers-reduced-motion: reduce) {
      .rv { opacity: 1; transform: none; transition: none; }
      html { scroll-behavior: auto; }
    }
  </style>
</head>
