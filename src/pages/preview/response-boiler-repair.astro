const config = {
  business_name: "Response - Boiler Repair",
  phone: "+447856297070",
  phone_display: "07856 297070",
  email: "response@boiler-repair-liverpool.com",
  address: "The Plaza, 100 Old Hall St, Liverpool L3 9QJ",
  town: "Liverpool",
  areas_served: ["Allerton", "Aigburth", "Rainhill", "Sefton Park", "Mossley Hill", "Crosby", "Childwall", "Woolton", "Bootle", "West Derby", "Garston", "Anfield", "Prescot"],
  logo_url: "https://boiler-repair-liverpool.com/wp-content/uploads/2023/02/2-Orange-boiler-bold-1.png",
  brand_color: "#FF8B00",
  brand_color_hover: "#e67d00",
  brand_color_soft: "rgba(255, 139, 0, 0.12)",
  hero_title: "Boiler Broken Down?",
  hero_subtitle: "24/7 emergency boiler repair across Liverpool. No call-out charge. Gas Safe registered. BAXI approved. We aim to be with you the same day.",
  certification: "BAXI Approved Installer",
  stats: [
    { num: "24/7", label: "Availability" },
    { num: "\u00A30", label: "Call-Out Fee" },
    { num: "Gas Safe", label: "Registered" },
    { num: "BAXI", label: "Approved" },
  ],
  services: [
    { title: "Emergency Boiler Repair", desc: "Same-day call-outs, no call-out charge, all boiler brands. Your boiler breaks, we fix it -- day or night." },
    { title: "Boiler Servicing", desc: "Annual maintenance to prevent breakdowns and keep your warranties valid. All major brands covered." },
    { title: "Boiler Installation", desc: "New boiler installations with 0% finance available. BAXI approved installer for reliable, efficient systems." },
    { title: "Central Heating", desc: "Radiator repairs, powerflush, full system installations. One reliable team for all your heating needs." },
  ],
  process: [
    { step: "1", title: "Call Us", desc: "24/7 emergency line, no call-out charge" },
    { step: "2", title: "Same Day", desc: "We aim to be with you the same day" },
    { step: "3", title: "Diagnose & Fix", desc: "Honest assessment, fair pricing" },
    { step: "4", title: "Guaranteed", desc: "12-month parts and labour guarantee" },
  ],
  reviews: [
    { name: "Chic_by_design", location: "Liverpool", initials: "CD", text: "Would totally recommend to all. Professional, clean, efficient, honest and on time.", stars: 5 },
    { name: "Allison Blacklin", location: "Liverpool", initials: "AB", text: "Geoff came out same day for emergency. Great communication, very friendly and reliable.", stars: 5 },
    { name: "Marius Adam", location: "Liverpool", initials: "MA", text: "Fast and efficient. Prompt reply, came out same day. Very professional.", stars: 5 },
  ],
  trust_signals: ["Gas Safe Registered", "BAXI Approved Installer", "No Call-Out Charge", "24/7 Emergency Service"],
  faqs: [
    { q: "Do you charge for call-outs?", a: "No -- there's no call-out charge. You only pay for the work we do." },
    { q: "Are you Gas Safe registered?", a: "Yes -- fully Gas Safe registered and BAXI approved. All work comes with certification." },
    { q: "Do you offer finance on new boilers?", a: "Yes -- we offer 0% finance options on new boiler installations. Ask us for details." },
    { q: "What areas of Liverpool do you cover?", a: "We cover all Liverpool postcodes and surrounding areas including Prescot, Rainhill, Crosby, and Halewood." },
  ],
  hours: "24/7, 365 days",
  schema_type: "Plumber",
};

// Icon map -- inline SVGs for zero external dependencies
const icons: Record<string, string> = {
  wrench: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
  check: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`,
  home: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  shield: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  clock: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  star: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
  flame: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>`,
  bolt: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
  phone: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`,
  starFill: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="#FF8B00" stroke="#FF8B00" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
  plus: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>`,
  minus: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/></svg>`,
  chevron: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>`,
  radiator: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="6" width="18" height="12" rx="2"/><line x1="7" y1="6" x2="7" y2="18"/><line x1="11" y1="6" x2="11" y2="18"/><line x1="15" y1="6" x2="15" y2="18"/><line x1="5" y1="20" x2="5" y2="18"/><line x1="19" y1="20" x2="19" y2="18"/></svg>`,
  tools: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
};

// Service icons
const serviceIcons = [icons.bolt, icons.wrench, icons.flame, icons.radiator];

// Trust signal icon map
const trustIconMap: Record<string, string> = {
  "Gas Safe": icons.flame,
  "BAXI": icons.shield,
  "Call-Out": icons.check,
  "24/7": icons.clock,
};

function getTrustIcon(signal: string): string {
  for (const [key, icon] of Object.entries(trustIconMap)) {
    if (signal.includes(key)) return icon;
  }
  return icons.check;
}

function renderStars(count: number): string {
  return Array.from({ length: count }, () => icons.starFill).join("");
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{config.business_name} | 24/7 Emergency Boiler Repair Liverpool</title>
  <meta name="description" content={`24/7 emergency boiler repair in Liverpool. No call-out charge. Gas Safe registered, BAXI approved. Call ${config.phone_display} now.`} />

  {/* OG Meta */}
  <meta property="og:title" content={`${config.business_name} | 24/7 Emergency Boiler Repair Liverpool`} />
  <meta property="og:description" content={`Emergency boiler repair across Liverpool. No call-out charge. Gas Safe registered & BAXI approved. Call ${config.phone_display}.`} />
  <meta property="og:image" content={config.logo_url} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${config.business_name} | 24/7 Emergency Boiler Repair Liverpool`} />
  <meta name="twitter:description" content={`Emergency boiler repair across Liverpool. No call-out charge. Call ${config.phone_display}.`} />
  <meta name="twitter:image" content={config.logo_url} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700&display=swap" rel="stylesheet" />

  {/* LocalBusiness JSON-LD */}
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": config.schema_type,
    "name": config.business_name,
    "telephone": config.phone,
    "email": config.email,
    "url": "https://boiler-repair-liverpool.com",
    "image": config.logo_url,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "The Plaza, 100 Old Hall St",
      "addressLocality": "Liverpool",
      "postalCode": "L3 9QJ",
      "addressCountry": "GB",
    },
    "areaServed": config.areas_served.map(a => ({ "@type": "Place", "name": a })),
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
      "opens": "00:00",
      "closes": "23:59",
    },
    "priceRange": "$$",
  })} />

  {/* FAQPage JSON-LD */}
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": config.faqs.map(faq => ({
      "@type": "Question",
      "name": faq.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.a,
      }
    })),
  })} />
</head>

<body>

  {/* ============================================================ */}
  {/* STICKY HEADER                                                 */}
  {/* ============================================================ */}
  <header class="site-header" id="site-header">
    <nav class="header-inner">
      <div class="header-left">
        <a href="#" class="logo-link">
          <img src={config.logo_url} alt={`${config.business_name} logo`} class="logo-img" width="160" height="44" />
        </a>
      </div>
      <div class="header-right">
        <a href={`tel:${config.phone}`} class="header-phone-link">
          <span class="header-phone-icon" set:html={icons.phone} />
          <span class="header-phone-number">{config.phone_display}</span>
        </a>
        <button class="nav-toggle" id="nav-toggle" aria-label="Open menu" aria-expanded="false">
          <span class="bar"></span>
          <span class="bar"></span>
          <span class="bar"></span>
        </button>
      </div>
      <div class="nav-dropdown" id="nav-dropdown">
        <a href="#services" class="nav-dropdown-link">Services</a>
        <a href="#process" class="nav-dropdown-link">How It Works</a>
        <a href="#reviews" class="nav-dropdown-link">Reviews</a>
        <a href="#faq" class="nav-dropdown-link">FAQ</a>
        <a href={`tel:${config.phone}`} class="nav-dropdown-cta">
          <span set:html={icons.phone} /> Call Now
        </a>
      </div>
    </nav>
  </header>

  <main>

    {/* ============================================================ */}
    {/* HERO                                                         */}
    {/* ============================================================ */}
    <section class="hero">
      <div class="hero-glow"></div>
      <div class="hero-glow-2"></div>
      <div class="container">
        <div class="hero-content">
          <div class="hero-urgency-bar">
            <span class="pulse-dot"></span>
            Available Now -- 24/7 Emergency Line
          </div>
          <span class="hero-badge">
            <span class="hero-badge-icon" set:html={icons.shield} />
            {config.certification} &bull; Gas Safe Registered
          </span>
          <h1 class="hero-title">{config.hero_title}</h1>
          <p class="hero-subtitle">{config.hero_subtitle}</p>
          <div class="hero-cta-group">
            <a href={`tel:${config.phone}`} class="btn btn-primary btn-lg btn-pulse">
              <span set:html={icons.phone} />
              Call {config.phone_display}
            </a>
            <p class="hero-microcopy">No call-out fee. Same-day service. 365 days a year.</p>
          </div>
        </div>
      </div>
    </section>

    {/* ============================================================ */}
    {/* TRUST STRIP                                                  */}
    {/* ============================================================ */}
    <section class="trust-strip" aria-label="Credentials">
      <div class="container">
        <div class="trust-strip-inner">
          {config.trust_signals.map((signal) => (
            <div class="trust-item">
              <span class="trust-item-icon" set:html={getTrustIcon(signal)} />
              <span class="trust-item-label">{signal}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ============================================================ */}
    {/* STATS                                                        */}
    {/* ============================================================ */}
    <section class="stats reveal" aria-label="Key statistics">
      <div class="container">
        <div class="stats-grid">
          {config.stats.map((stat, i) => (
            <div class="stat-item" style={`--delay: ${i * 0.1}s`}>
              <span class="stat-num">{stat.num}</span>
              <span class="stat-label">{stat.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ============================================================ */}
    {/* SERVICES                                                     */}
    {/* ============================================================ */}
    <section class="services reveal" id="services">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">What We Do</h2>
          <p class="section-subtitle">Emergency repairs, servicing, installations and central heating across {config.town}.</p>
        </div>
        <div class="services-grid">
          {config.services.map((service, i) => (
            <div class="service-card" style={`--delay: ${i * 0.1}s`}>
              <div class="service-icon" set:html={serviceIcons[i % serviceIcons.length]} />
              <h3 class="service-title">{service.title}</h3>
              <p class="service-desc">{service.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ============================================================ */}
    {/* HOW IT WORKS                                                 */}
    {/* ============================================================ */}
    <section class="process reveal" id="process">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">How It Works</h2>
          <p class="section-subtitle">From first call to job done. Simple, fast, guaranteed.</p>
        </div>
        <div class="timeline">
          {config.process.map((step, i) => (
            <div class="timeline-step" style={`--delay: ${i * 0.15}s`}>
              <div class="timeline-marker">
                <span class="timeline-number">{step.step}</span>
              </div>
              <div class="timeline-content">
                <h3 class="timeline-title">{step.title}</h3>
                <p class="timeline-desc">{step.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ============================================================ */}
    {/* TESTIMONIALS                                                 */}
    {/* ============================================================ */}
    <section class="reviews reveal" id="reviews">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">What Our Customers Say</h2>
          <p class="section-subtitle">Real reviews from real customers in Liverpool.</p>
        </div>
        <div class="reviews-grid">
          {config.reviews.map((review, i) => (
            <div class="review-card" style={`--delay: ${i * 0.1}s`}>
              <div class="review-stars" set:html={renderStars(review.stars)} />
              <blockquote class="review-text">&ldquo;{review.text}&rdquo;</blockquote>
              <div class="review-author">
                <div class="review-avatar">{review.initials}</div>
                <div class="review-meta">
                  <span class="review-name">{review.name}</span>
                  <span class="review-location">{review.location}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ============================================================ */}
    {/* FAQ                                                          */}
    {/* ============================================================ */}
    <section class="faq reveal" id="faq">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">Frequently Asked Questions</h2>
        </div>
        <div class="faq-list">
          {config.faqs.map((faq, i) => (
            <details class="faq-item" style={`--delay: ${i * 0.08}s`}>
              <summary class="faq-question">
                <span>{faq.q}</span>
                <span class="faq-icon faq-icon-plus" set:html={icons.plus} />
                <span class="faq-icon faq-icon-minus" set:html={icons.minus} />
              </summary>
              <div class="faq-answer">
                <p>{faq.a}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    {/* ============================================================ */}
    {/* FINAL CTA                                                    */}
    {/* ============================================================ */}
    <section class="final-cta reveal">
      <div class="container">
        <div class="final-cta-card">
          <div class="final-cta-glow"></div>
          <h2 class="final-cta-title">Boiler Emergency?<br/>Call Us Now.</h2>
          <p class="final-cta-subtitle">No call-out charge. Same-day service. 24 hours a day, 365 days a year.</p>
          <a href={`tel:${config.phone}`} class="btn btn-primary btn-lg btn-pulse">
            <span set:html={icons.phone} />
            {config.phone_display}
          </a>
          <p class="final-cta-areas">Serving {config.areas_served.join(" \u00B7 ")}</p>
        </div>
      </div>
    </section>

  </main>

  {/* ============================================================ */}
  {/* FOOTER                                                       */}
  {/* ============================================================ */}
  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-col">
          <h4 class="footer-heading">{config.business_name}</h4>
          <p class="footer-text">24/7 emergency boiler repair across Liverpool. Gas Safe registered, BAXI approved. No call-out charge.</p>
        </div>
        <div class="footer-col">
          <h4 class="footer-heading">Contact</h4>
          <ul class="footer-list">
            <li><a href={`tel:${config.phone}`}>{config.phone_display}</a></li>
            <li><a href={`mailto:${config.email}`}>{config.email}</a></li>
            <li>{config.address}</li>
          </ul>
        </div>
        <div class="footer-col">
          <h4 class="footer-heading">Hours</h4>
          <p class="footer-text">{config.hours}</p>
          <div class="footer-areas">
            <h4 class="footer-heading footer-heading-areas">Areas We Cover</h4>
            <p class="footer-text">{config.areas_served.join(", ")}</p>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; {new Date().getFullYear()} {config.business_name}. All rights reserved.</p>
        <p class="footer-credit">Website by <a href="https://highcroftdigital.com" target="_blank" rel="noopener">Highcroft Digital</a></p>
      </div>
    </div>
  </footer>

  {/* ============================================================ */}
  {/* FLOATING PHONE BUTTON -- mobile only                         */}
  {/* ============================================================ */}
  <a href={`tel:${config.phone}`} class="floating-phone" aria-label={`Call ${config.business_name}`}>
    <span set:html={icons.phone} />
  </a>

</body>
</html>

<style>
  /* ============================================================
     RESET & BASE
     ============================================================ */
  *, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
    scroll-padding-top: 72px;
  }

  body {
    font-family: "Barlow", sans-serif;
    font-size: 1rem;
    line-height: 1.6;
    color: #c8d6e5;
    background: #0a1628;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  img {
    max-width: 100%;
    height: auto;
    display: block;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  ul {
    list-style: none;
  }

  /* ============================================================
     LAYOUT
     ============================================================ */
  .container {
    width: 100%;
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 20px;
  }

  @media (min-width: 768px) {
    .container {
      padding: 0 32px;
    }
  }

  /* ============================================================
     STICKY HEADER
     ============================================================ */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10, 22, 40, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 139, 0, 0.15);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 20px;
    height: 64px;
    position: relative;
  }

  @media (min-width: 768px) {
    .header-inner {
      padding: 0 32px;
      height: 72px;
    }
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .logo-link {
    display: flex;
    align-items: center;
  }

  .logo-img {
    height: 38px;
    width: auto;
    object-fit: contain;
  }

  @media (min-width: 768px) {
    .logo-img {
      height: 44px;
    }
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .header-phone-link {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 700;
    font-size: 0.95rem;
    color: #FF8B00;
    transition: color 0.2s;
    padding: 8px 0;
  }

  .header-phone-link:hover {
    color: #ffac40;
  }

  .header-phone-icon {
    display: flex;
    align-items: center;
  }

  .header-phone-icon svg {
    width: 18px;
    height: 18px;
  }

  .header-phone-number {
    display: none;
  }

  @media (min-width: 480px) {
    .header-phone-number {
      display: inline;
    }
  }

  /* Nav toggle (hamburger) */
  .nav-toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    width: 44px;
    height: 44px;
  }

  @media (min-width: 768px) {
    .nav-toggle {
      display: none;
    }
  }

  .bar {
    display: block;
    width: 22px;
    height: 2px;
    background: #c8d6e5;
    border-radius: 2px;
    transition: transform 0.25s, opacity 0.25s;
  }

  .nav-toggle.is-active .bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .nav-toggle.is-active .bar:nth-child(2) {
    opacity: 0;
  }

  .nav-toggle.is-active .bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Nav dropdown (mobile) */
  .nav-dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: #0d1d33;
    border-top: 1px solid rgba(255, 139, 0, 0.12);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4);
    z-index: 200;
    flex-direction: column;
    padding: 8px 0;
  }

  .nav-dropdown.is-open {
    display: flex;
  }

  @media (min-width: 768px) {
    .nav-dropdown {
      display: none !important;
    }
  }

  .nav-dropdown-link {
    padding: 14px 24px;
    font-weight: 500;
    font-size: 1rem;
    color: #c8d6e5;
    transition: background 0.15s, color 0.15s;
  }

  .nav-dropdown-link:hover {
    background: rgba(255, 139, 0, 0.08);
    color: #FF8B00;
  }

  .nav-dropdown-cta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin: 8px 16px;
    padding: 14px 20px;
    background: #FF8B00;
    color: #fff;
    border-radius: 10px;
    font-weight: 700;
    font-size: 1rem;
    justify-content: center;
    transition: background 0.2s;
  }

  .nav-dropdown-cta:hover {
    background: #e67d00;
  }

  .nav-dropdown-cta svg {
    width: 18px;
    height: 18px;
  }

  /* ============================================================
     HERO
     ============================================================ */
  .hero {
    background: #0a1628;
    padding: 80px 0 64px;
    position: relative;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    top: -200px;
    right: -100px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(255, 139, 0, 0.15) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-glow-2 {
    position: absolute;
    bottom: -150px;
    left: -80px;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(255, 139, 0, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  @media (min-width: 768px) {
    .hero {
      padding: 110px 0 90px;
    }
  }

  .hero-content {
    max-width: 680px;
    text-align: center;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  /* Urgency bar - pulsing green dot */
  .hero-urgency-bar {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #4ade80;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 20px;
  }

  .pulse-dot {
    width: 8px;
    height: 8px;
    background: #4ade80;
    border-radius: 50%;
    display: inline-block;
    animation: pulse 2s ease-in-out infinite;
    box-shadow: 0 0 8px rgba(74, 222, 128, 0.5);
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255, 139, 0, 0.1);
    border: 1px solid rgba(255, 139, 0, 0.25);
    color: #FF8B00;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 6px 16px;
    border-radius: 100px;
    margin-bottom: 24px;
    letter-spacing: 0.02em;
  }

  .hero-badge-icon {
    display: flex;
    align-items: center;
  }

  .hero-badge-icon svg {
    width: 14px;
    height: 14px;
    stroke: #FF8B00;
  }

  .hero-title {
    font-size: clamp(2.2rem, 8vw, 3.6rem);
    font-weight: 700;
    color: #fff;
    line-height: 1.1;
    margin-bottom: 18px;
    letter-spacing: -0.02em;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2.5vw, 1.2rem);
    color: #8fa3bf;
    line-height: 1.65;
    margin-bottom: 36px;
    max-width: 540px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-cta-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
  }

  .hero-microcopy {
    font-size: 0.85rem;
    color: #5a7a9a;
    font-weight: 500;
  }

  /* ============================================================
     BUTTONS
     ============================================================ */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-family: inherit;
    font-weight: 700;
    font-size: 1rem;
    border: none;
    border-radius: 12px;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    text-decoration: none;
    line-height: 1;
  }

  .btn:active {
    transform: scale(0.97);
  }

  .btn svg {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .btn-primary {
    background: #FF8B00;
    color: #fff;
    box-shadow: 0 4px 16px rgba(255, 139, 0, 0.3);
  }

  .btn-primary:hover {
    background: #e67d00;
    box-shadow: 0 6px 24px rgba(255, 139, 0, 0.4);
  }

  .btn-lg {
    padding: 16px 36px;
    font-size: 1.1rem;
    min-height: 56px;
  }

  /* Subtle pulse animation on CTA */
  .btn-pulse {
    animation: btnPulse 3s ease-in-out infinite;
  }

  @keyframes btnPulse {
    0%, 100% { box-shadow: 0 4px 16px rgba(255, 139, 0, 0.3); }
    50% { box-shadow: 0 4px 24px rgba(255, 139, 0, 0.5), 0 0 0 6px rgba(255, 139, 0, 0.08); }
  }

  /* ============================================================
     TRUST STRIP
     ============================================================ */
  .trust-strip {
    background: #0d1d33;
    border-top: 1px solid rgba(255, 139, 0, 0.1);
    border-bottom: 1px solid rgba(255, 139, 0, 0.1);
    padding: 18px 0;
  }

  .trust-strip-inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px 28px;
  }

  @media (min-width: 768px) {
    .trust-strip-inner {
      gap: 12px 48px;
    }
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 0;
  }

  .trust-item-icon {
    display: flex;
    align-items: center;
    color: #FF8B00;
  }

  .trust-item-icon svg {
    width: 18px;
    height: 18px;
  }

  .trust-item-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: #e0e8f0;
    white-space: nowrap;
  }

  /* ============================================================
     STATS
     ============================================================ */
  .stats {
    padding: 48px 0;
    background: #0a1628;
  }

  @media (min-width: 768px) {
    .stats {
      padding: 64px 0;
    }
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  @media (min-width: 640px) {
    .stats-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 32px;
    }
  }

  .stat-item {
    text-align: center;
    padding: 20px 8px;
    background: rgba(255, 139, 0, 0.04);
    border: 1px solid rgba(255, 139, 0, 0.1);
    border-radius: 14px;
  }

  .stat-num {
    display: block;
    font-size: clamp(1.8rem, 5vw, 2.4rem);
    font-weight: 700;
    color: #FF8B00;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .stat-label {
    display: block;
    font-size: 0.85rem;
    font-weight: 500;
    color: #7a90a8;
    margin-top: 6px;
  }

  /* ============================================================
     SECTION HEADERS (shared)
     ============================================================ */
  .section-header {
    text-align: center;
    margin-bottom: 40px;
  }

  @media (min-width: 768px) {
    .section-header {
      margin-bottom: 48px;
    }
  }

  .section-title {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.02em;
    margin-bottom: 10px;
  }

  .section-subtitle {
    font-size: 1rem;
    color: #7a90a8;
    max-width: 520px;
    margin: 0 auto;
  }

  /* ============================================================
     SERVICES
     ============================================================ */
  .services {
    padding: 64px 0;
    background: #0d1d33;
  }

  @media (min-width: 768px) {
    .services {
      padding: 80px 0;
    }
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  @media (min-width: 600px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
  }

  .service-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 14px;
    padding: 28px 24px;
    transition: border-color 0.25s, background 0.25s;
  }

  .service-card:hover {
    border-color: rgba(255, 139, 0, 0.3);
    background: rgba(255, 139, 0, 0.04);
  }

  .service-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: rgba(255, 139, 0, 0.1);
    border-radius: 12px;
    color: #FF8B00;
    margin-bottom: 16px;
  }

  .service-icon svg {
    width: 24px;
    height: 24px;
  }

  .service-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 8px;
  }

  .service-desc {
    font-size: 0.92rem;
    color: #7a90a8;
    line-height: 1.6;
  }

  /* ============================================================
     TIMELINE / PROCESS
     ============================================================ */
  .process {
    padding: 64px 0;
    background: #0a1628;
  }

  @media (min-width: 768px) {
    .process {
      padding: 80px 0;
    }
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
    position: relative;
    padding-left: 28px;
  }

  /* Vertical line (mobile) */
  .timeline::before {
    content: "";
    position: absolute;
    left: 15px;
    top: 24px;
    bottom: 24px;
    width: 2px;
    background: rgba(255, 139, 0, 0.2);
  }

  .timeline-step {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    padding: 20px 0;
    position: relative;
  }

  .timeline-marker {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #FF8B00;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 2;
    margin-left: -28px;
    box-shadow: 0 0 12px rgba(255, 139, 0, 0.3);
  }

  .timeline-number {
    font-size: 0.85rem;
    font-weight: 700;
    color: #fff;
  }

  .timeline-content {
    padding-top: 4px;
  }

  .timeline-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 2px;
  }

  .timeline-desc {
    font-size: 0.92rem;
    color: #7a90a8;
  }

  /* Desktop: horizontal timeline */
  @media (min-width: 768px) {
    .timeline {
      flex-direction: row;
      padding-left: 0;
      justify-content: space-between;
    }

    .timeline::before {
      left: calc(18px + 12px);
      right: calc(18px + 12px);
      top: 18px;
      bottom: auto;
      height: 2px;
      width: auto;
    }

    .timeline-step {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 16px;
      flex: 1;
      padding: 0 12px;
    }

    .timeline-marker {
      margin-left: 0;
    }

    .timeline-content {
      padding-top: 0;
    }
  }

  /* ============================================================
     REVIEWS
     ============================================================ */
  .reviews {
    padding: 64px 0;
    background: #0d1d33;
  }

  @media (min-width: 768px) {
    .reviews {
      padding: 80px 0;
    }
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  @media (min-width: 640px) {
    .reviews-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 900px) {
    .reviews-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .review-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 14px;
    padding: 28px 24px;
  }

  .review-stars {
    display: flex;
    gap: 2px;
    margin-bottom: 16px;
  }

  .review-text {
    font-size: 0.95rem;
    color: #b8c8da;
    line-height: 1.65;
    margin-bottom: 20px;
    font-style: normal;
  }

  .review-author {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .review-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #FF8B00;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight: 700;
    flex-shrink: 0;
    letter-spacing: 0.02em;
  }

  .review-meta {
    display: flex;
    flex-direction: column;
  }

  .review-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: #e0e8f0;
  }

  .review-location {
    font-size: 0.8rem;
    color: #5a7a9a;
  }

  /* ============================================================
     FAQ
     ============================================================ */
  .faq {
    padding: 64px 0;
    background: #0a1628;
  }

  @media (min-width: 768px) {
    .faq {
      padding: 80px 0;
    }
  }

  .faq-list {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .faq-item {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.25s;
  }

  .faq-item[open] {
    border-color: rgba(255, 139, 0, 0.3);
  }

  .faq-question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 20px;
    font-weight: 600;
    font-size: 1rem;
    color: #e0e8f0;
    cursor: pointer;
    list-style: none;
    user-select: none;
    min-height: 44px;
    transition: color 0.2s;
  }

  .faq-question:hover {
    color: #FF8B00;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-question::marker {
    content: "";
  }

  .faq-icon {
    flex-shrink: 0;
    color: #FF8B00;
    display: flex;
    align-items: center;
  }

  .faq-icon-minus {
    display: none;
  }

  .faq-item[open] .faq-icon-plus {
    display: none;
  }

  .faq-item[open] .faq-icon-minus {
    display: flex;
  }

  .faq-answer {
    padding: 0 20px 20px;
    font-size: 0.95rem;
    color: #7a90a8;
    line-height: 1.65;
  }

  /* ============================================================
     FINAL CTA
     ============================================================ */
  .final-cta {
    padding: 64px 0;
    background: #0d1d33;
  }

  @media (min-width: 768px) {
    .final-cta {
      padding: 80px 0;
    }
  }

  .final-cta-card {
    background: linear-gradient(135deg, #12243d 0%, #0a1628 100%);
    border: 1px solid rgba(255, 139, 0, 0.15);
    border-radius: 20px;
    padding: 52px 24px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .final-cta-card {
      padding: 72px 48px;
    }
  }

  .final-cta-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(255, 139, 0, 0.12) 0%, transparent 60%);
    pointer-events: none;
  }

  .final-cta-title {
    font-size: clamp(1.6rem, 5vw, 2.4rem);
    font-weight: 700;
    color: #fff;
    margin-bottom: 14px;
    letter-spacing: -0.02em;
    position: relative;
    z-index: 1;
    line-height: 1.2;
  }

  .final-cta-subtitle {
    font-size: 1rem;
    color: #7a90a8;
    margin-bottom: 32px;
    max-width: 460px;
    margin-left: auto;
    margin-right: auto;
    position: relative;
    z-index: 1;
  }

  .final-cta .btn {
    position: relative;
    z-index: 1;
  }

  .final-cta-areas {
    margin-top: 24px;
    font-size: 0.82rem;
    color: #5a7a9a;
    position: relative;
    z-index: 1;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }

  /* ============================================================
     FOOTER
     ============================================================ */
  .site-footer {
    background: #060e1a;
    color: #6b829e;
    padding: 48px 0 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
  }

  @media (min-width: 768px) {
    .site-footer {
      padding: 64px 0 32px;
    }
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    margin-bottom: 40px;
  }

  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .footer-heading {
    font-size: 0.95rem;
    font-weight: 700;
    color: #e0e8f0;
    margin-bottom: 12px;
  }

  .footer-heading-areas {
    margin-top: 20px;
  }

  .footer-text {
    font-size: 0.9rem;
    line-height: 1.55;
  }

  .footer-list li {
    font-size: 0.9rem;
    margin-bottom: 6px;
  }

  .footer-list a {
    transition: color 0.15s;
  }

  .footer-list a:hover {
    color: #FF8B00;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding-top: 20px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    text-align: center;
    font-size: 0.82rem;
  }

  @media (min-width: 640px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .footer-credit a {
    color: #FF8B00;
    font-weight: 600;
    transition: color 0.15s;
  }

  .footer-credit a:hover {
    color: #ffac40;
  }

  /* ============================================================
     FLOATING PHONE BUTTON (mobile only)
     ============================================================ */
  .floating-phone {
    display: flex;
    align-items: center;
    justify-content: center;
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #FF8B00;
    color: #fff;
    box-shadow: 0 4px 20px rgba(255, 139, 0, 0.4), 0 0 0 4px rgba(255, 139, 0, 0.15);
    z-index: 90;
    transition: background 0.2s, transform 0.15s;
    animation: floatPulse 3s ease-in-out infinite;
  }

  @keyframes floatPulse {
    0%, 100% { box-shadow: 0 4px 20px rgba(255, 139, 0, 0.4), 0 0 0 4px rgba(255, 139, 0, 0.15); }
    50% { box-shadow: 0 4px 28px rgba(255, 139, 0, 0.6), 0 0 0 8px rgba(255, 139, 0, 0.1); }
  }

  .floating-phone:hover {
    background: #e67d00;
  }

  .floating-phone:active {
    transform: scale(0.92);
  }

  .floating-phone svg {
    width: 24px;
    height: 24px;
  }

  @media (min-width: 768px) {
    .floating-phone {
      display: none;
    }
  }

  /* ============================================================
     SCROLL REVEAL ANIMATIONS
     ============================================================ */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Staggered children */
  .reveal.is-visible .stat-item,
  .reveal.is-visible .service-card,
  .reveal.is-visible .timeline-step,
  .reveal.is-visible .review-card,
  .reveal.is-visible .faq-item {
    animation: revealUp 0.5s ease forwards;
    animation-delay: var(--delay, 0s);
    opacity: 0;
  }

  @keyframes revealUp {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .reveal.is-visible .stat-item,
    .reveal.is-visible .service-card,
    .reveal.is-visible .timeline-step,
    .reveal.is-visible .review-card,
    .reveal.is-visible .faq-item {
      animation: none;
      opacity: 1;
    }

    .pulse-dot {
      animation: none;
    }

    .btn-pulse {
      animation: none;
    }

    .floating-phone {
      animation: none;
    }
  }
</style>

<script>
  // ============================================================
  // NAV TOGGLE
  // ============================================================
  const navToggle = document.getElementById("nav-toggle");
  const navDropdown = document.getElementById("nav-dropdown");

  if (navToggle && navDropdown) {
    navToggle.addEventListener("click", () => {
      const isOpen = navDropdown.classList.toggle("is-open");
      navToggle.classList.toggle("is-active", isOpen);
      navToggle.setAttribute("aria-expanded", String(isOpen));
    });

    // Close dropdown when a link is clicked
    navDropdown.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        navDropdown.classList.remove("is-open");
        navToggle.classList.remove("is-active");
        navToggle.setAttribute("aria-expanded", "false");
      });
    });

    // Close dropdown on outside click
    document.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      if (!navToggle.contains(target) && !navDropdown.contains(target)) {
        navDropdown.classList.remove("is-open");
        navToggle.classList.remove("is-active");
        navToggle.setAttribute("aria-expanded", "false");
      }
    });
  }

  // ============================================================
  // SCROLL REVEAL -- IntersectionObserver
  // ============================================================
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!prefersReducedMotion) {
    const revealElements = document.querySelectorAll(".reveal");

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        });
      },
      {
        threshold: 0.12,
        rootMargin: "0px 0px -40px 0px",
      }
    );

    revealElements.forEach((el) => observer.observe(el));
  } else {
    // If reduced motion preferred, show everything
    document.querySelectorAll(".reveal").forEach((el) => {
      el.classList.add("is-visible");
    });
  }

  // ============================================================
  // HEADER SHADOW ON SCROLL
  // ============================================================
  const header = document.getElementById("site-header");

  if (header) {
    const onScroll = () => {
      if (window.scrollY > 8) {
        header.style.boxShadow = "0 4px 20px rgba(0, 0, 0, 0.3)";
      } else {
        header.style.boxShadow = "none";
      }
    };

    window.addEventListener("scroll", onScroll, { passive: true });
  }
</script>
