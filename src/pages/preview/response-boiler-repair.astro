---
// Response - Boiler Repair (Liverpool) — Preview Page
// Built by Highcroft Digital
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Response Boiler Repair — Liverpool</title>
  <meta name="description" content="Gas Safe registered boiler repair engineers in Liverpool. Boiler servicing, installations, central heating & emergency plumbing. 12 month guarantee on all work." />
  <meta property="og:title" content="Response Boiler Repair — Your New Site" />
  <meta property="og:description" content="A modern, professional website for Response Boiler Repair Liverpool. Gas Safe registered engineers for boiler repairs, servicing & installations." />
  <meta property="og:image" content="https://boiler-repair-liverpool.com/wp-content/uploads/2023/03/TP_logo_dark_blue_bg.jpg" />
  <meta property="og:url" content="https://highcroftdigital.com/preview/response-boiler-repair" />
  <meta property="og:type" content="website" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=DM+Serif+Display&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --orange: #FF8B00;
      --orange-light: #FFA033;
      --navy: #0a1628;
      --charcoal: #131820;
      --slate: #3a424d;
      --gray: #687279;
      --silver: #9ca6ad;
      --mist: #f0f2f4;
      --cloud: #f7f8f9;
      --white: #fefefe;
      --font-display: 'DM Serif Display', Georgia, serif;
      --font-body: 'DM Sans', -apple-system, sans-serif;
    }

    html {
      scroll-behavior: smooth;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    body {
      font-family: var(--font-body);
      color: var(--slate);
      background: var(--white);
      line-height: 1.6;
      overflow-x: hidden;
    }

    /* --- NAV --- */
    .nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      padding: 1.25rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: rgba(254,254,254,0.92);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(0,0,0,0.04);
      transition: padding 0.3s ease;
    }

    .nav.scrolled { padding: 0.75rem 2rem; }

    .nav-logo {
      height: 44px;
      width: auto;
      object-fit: contain;
    }

    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
      align-items: center;
    }

    .nav-links a {
      color: var(--slate);
      text-decoration: none;
      font-size: 0.875rem;
      font-weight: 500;
      letter-spacing: 0.02em;
      transition: color 0.2s;
    }

    .nav-links a:hover { color: var(--charcoal); }

    .nav-cta {
      background: var(--navy) !important;
      color: var(--white) !important;
      padding: 0.6rem 1.5rem !important;
      border-radius: 2px;
      font-size: 0.8rem !important;
      letter-spacing: 0.06em !important;
      text-transform: uppercase;
      font-weight: 600 !important;
      transition: background 0.2s !important;
    }

    .nav-cta:hover { background: var(--orange) !important; }

    .nav-toggle {
      display: none;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.5rem;
    }

    .nav-toggle span {
      display: block;
      width: 24px;
      height: 2px;
      background: var(--charcoal);
      margin: 5px 0;
      transition: 0.3s;
    }

    /* --- HERO --- */
    .hero {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
      position: relative;
    }

    .hero-content {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: clamp(4rem, 8vw, 8rem);
      padding-top: 7rem;
    }

    .hero-est {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--orange);
      margin-bottom: 2rem;
    }

    .hero-est::before {
      content: '';
      display: block;
      width: 32px;
      height: 2px;
      background: var(--orange);
    }

    .hero h1 {
      font-family: var(--font-display);
      font-size: clamp(2.5rem, 5vw, 4.2rem);
      color: var(--charcoal);
      line-height: 1.1;
      margin-bottom: 1.5rem;
      font-weight: 400;
    }

    .hero p {
      font-size: clamp(1rem, 1.2vw, 1.15rem);
      color: var(--gray);
      max-width: 420px;
      line-height: 1.7;
      margin-bottom: 2.5rem;
    }

    .hero-actions {
      display: flex;
      gap: 1rem;
      align-items: center;
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--orange);
      color: var(--white);
      padding: 1rem 2rem;
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      border-radius: 2px;
      transition: background 0.25s ease, transform 0.2s ease;
    }

    .btn-primary:hover {
      background: var(--orange-light);
      transform: translateY(-1px);
    }

    .btn-secondary {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      color: var(--charcoal);
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      padding: 1rem 0;
      transition: color 0.2s;
    }

    .btn-secondary:hover { color: var(--orange); }

    .btn-secondary svg {
      transition: transform 0.2s;
    }

    .btn-secondary:hover svg {
      transform: translateX(3px);
    }

    .hero-image {
      position: relative;
      overflow: hidden;
      background: var(--navy);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .hero-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .hero-image::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 30%;
      background: linear-gradient(to top, rgba(10,22,40,0.15), transparent);
    }

    /* --- STATS BAR --- */
    .stats {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      background: var(--navy);
    }

    .stat {
      padding: 2.5rem 2rem;
      text-align: center;
      position: relative;
    }

    .stat:not(:last-child)::after {
      content: '';
      position: absolute;
      right: 0;
      top: 25%;
      height: 50%;
      width: 1px;
      background: rgba(255,255,255,0.1);
    }

    .stat-number {
      font-family: var(--font-display);
      font-size: clamp(1.8rem, 3vw, 2.5rem);
      color: var(--white);
      margin-bottom: 0.25rem;
    }

    .stat-label {
      font-size: 0.75rem;
      color: var(--silver);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-weight: 500;
    }

    /* --- SERVICES --- */
    .services {
      padding: clamp(4rem, 10vw, 8rem) clamp(2rem, 6vw, 6rem);
    }

    .section-label {
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--orange);
      margin-bottom: 1rem;
    }

    .section-heading {
      font-family: var(--font-display);
      font-size: clamp(2rem, 4vw, 3.2rem);
      color: var(--charcoal);
      line-height: 1.15;
      max-width: 560px;
      margin-bottom: 1.25rem;
      font-weight: 400;
    }

    .section-sub {
      color: var(--gray);
      font-size: 1.05rem;
      max-width: 480px;
      margin-bottom: 4rem;
      line-height: 1.7;
    }

    .services-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1px;
      background: var(--mist);
      border: 1px solid var(--mist);
    }

    .service-card {
      background: var(--white);
      padding: clamp(2rem, 4vw, 3.5rem);
      position: relative;
      transition: background 0.3s ease;
    }

    .service-card:hover {
      background: var(--cloud);
    }

    .service-icon {
      width: 48px;
      height: 48px;
      margin-bottom: 1.75rem;
      color: var(--orange);
    }

    .service-card h3 {
      font-family: var(--font-display);
      font-size: 1.35rem;
      color: var(--charcoal);
      margin-bottom: 1rem;
      font-weight: 400;
    }

    .service-card p {
      color: var(--gray);
      font-size: 0.925rem;
      line-height: 1.7;
    }

    .service-number {
      position: absolute;
      top: clamp(1.5rem, 3vw, 2.5rem);
      right: clamp(1.5rem, 3vw, 2.5rem);
      font-family: var(--font-display);
      font-size: 3rem;
      color: var(--mist);
      line-height: 1;
      user-select: none;
    }

    /* --- WHY CHOOSE --- */
    .why {
      background: var(--navy);
      padding: clamp(4rem, 10vw, 7rem) clamp(2rem, 6vw, 6rem);
      display: grid;
      grid-template-columns: 1fr 1.2fr;
      gap: clamp(3rem, 6vw, 6rem);
      align-items: center;
    }

    .why .section-label { color: var(--orange); }

    .why .section-heading {
      color: var(--white);
      margin-bottom: 1.5rem;
    }

    .why-text {
      color: var(--silver);
      font-size: 1rem;
      line-height: 1.8;
      max-width: 400px;
    }

    .trust-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }

    .trust-card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.06);
      padding: 2rem 1.75rem;
      border-radius: 2px;
      transition: background 0.3s;
    }

    .trust-card:hover {
      background: rgba(255,255,255,0.07);
    }

    .trust-icon {
      width: 32px;
      height: 32px;
      color: var(--orange);
      margin-bottom: 1rem;
    }

    .trust-card h4 {
      color: var(--white);
      font-size: 0.95rem;
      font-weight: 500;
      line-height: 1.4;
    }

    /* --- TESTIMONIALS --- */
    .testimonials {
      padding: clamp(4rem, 10vw, 7rem) clamp(2rem, 6vw, 6rem);
      background: var(--cloud);
    }

    .testimonials .section-heading {
      max-width: 100%;
      text-align: center;
      margin-left: auto;
      margin-right: auto;
      margin-bottom: 3.5rem;
    }

    .testimonials .section-label {
      text-align: center;
    }

    .testimonials-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      max-width: 1100px;
      margin: 0 auto;
    }

    .testimonial-card {
      background: var(--white);
      padding: 2.25rem;
      border: 1px solid var(--mist);
      border-radius: 2px;
      position: relative;
    }

    .testimonial-card::before {
      content: '\201C';
      font-family: var(--font-display);
      font-size: 4rem;
      color: var(--orange);
      opacity: 0.2;
      position: absolute;
      top: 0.5rem;
      left: 1.5rem;
      line-height: 1;
    }

    .testimonial-card p {
      color: var(--gray);
      font-size: 0.9rem;
      line-height: 1.75;
      margin-bottom: 1.5rem;
      position: relative;
      z-index: 1;
    }

    .testimonial-author {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .testimonial-avatar {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: var(--orange);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--white);
      font-weight: 600;
      font-size: 0.8rem;
      flex-shrink: 0;
    }

    .testimonial-name {
      font-weight: 600;
      color: var(--charcoal);
      font-size: 0.85rem;
    }

    .testimonial-role {
      color: var(--silver);
      font-size: 0.75rem;
    }

    .testimonial-stars {
      color: var(--orange);
      font-size: 0.8rem;
      letter-spacing: 2px;
      margin-bottom: 1rem;
    }

    /* --- ABOUT --- */
    .about {
      display: grid;
      grid-template-columns: 1.1fr 1fr;
      min-height: 70vh;
    }

    .about-image {
      background: var(--navy);
      min-height: 400px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .about-image img {
      max-width: 70%;
      max-height: 60%;
      object-fit: contain;
    }

    .about-content {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: clamp(3rem, 6vw, 6rem);
    }

    .about-content .section-heading {
      margin-bottom: 1.5rem;
    }

    .about-content p {
      color: var(--gray);
      font-size: 1rem;
      line-height: 1.8;
      margin-bottom: 1.25rem;
      max-width: 460px;
    }

    .about-sig {
      margin-top: 1.5rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--mist);
    }

    .about-sig strong {
      display: block;
      color: var(--charcoal);
      font-size: 1rem;
    }

    .about-sig span {
      color: var(--gray);
      font-size: 0.85rem;
    }

    /* --- CONTACT CTA --- */
    .contact {
      background: var(--cloud);
      padding: clamp(4rem, 10vw, 7rem) clamp(2rem, 6vw, 6rem);
      text-align: center;
    }

    .contact .section-heading {
      max-width: 100%;
      margin-left: auto;
      margin-right: auto;
      margin-bottom: 1rem;
    }

    .contact-sub {
      color: var(--gray);
      font-size: 1.05rem;
      margin-bottom: 3rem;
      max-width: 500px;
      margin-left: auto;
      margin-right: auto;
      line-height: 1.7;
    }

    .contact-phone {
      font-family: var(--font-display);
      font-size: clamp(2rem, 4.5vw, 3.5rem);
      color: var(--charcoal);
      text-decoration: none;
      display: block;
      margin-bottom: 0.5rem;
      transition: color 0.2s;
    }

    .contact-phone:hover { color: var(--orange); }

    .contact-email {
      color: var(--gray);
      font-size: 1.1rem;
      margin-bottom: 2.5rem;
    }

    .contact-email a {
      color: var(--gray);
      text-decoration: none;
      transition: color 0.2s;
    }

    .contact-email a:hover { color: var(--orange); }

    .contact-areas {
      color: var(--silver);
      font-size: 0.85rem;
      letter-spacing: 0.04em;
      margin-top: 2rem;
    }

    .contact-address {
      color: var(--silver);
      font-size: 0.9rem;
      margin-top: 1.25rem;
      line-height: 1.6;
    }

    /* --- FOOTER --- */
    .footer {
      padding: 2rem clamp(2rem, 6vw, 6rem);
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-top: 1px solid var(--mist);
      font-size: 0.8rem;
      color: var(--silver);
    }

    .footer a {
      color: var(--silver);
      text-decoration: none;
      transition: color 0.2s;
    }

    .footer a:hover { color: var(--orange); }

    /* --- ANIMATIONS --- */
    .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
                  transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .reveal-delay-1 { transition-delay: 0.1s; }
    .reveal-delay-2 { transition-delay: 0.2s; }
    .reveal-delay-3 { transition-delay: 0.3s; }
    .reveal-delay-4 { transition-delay: 0.4s; }

    /* --- RESPONSIVE --- */
    @media (max-width: 1024px) {
      .hero { grid-template-columns: 1fr; min-height: auto; }
      .hero-image { height: 50vh; order: -1; }
      .hero-content { padding: 3rem 2rem 4rem; }
      .why { grid-template-columns: 1fr; }
      .about { grid-template-columns: 1fr; }
      .about-image { height: 50vh; }
      .testimonials-grid { grid-template-columns: 1fr; }
    }

    @media (max-width: 768px) {
      .nav-links { display: none; }
      .nav-links.open {
        display: flex;
        flex-direction: column;
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: var(--white);
        padding: 1.5rem 2rem;
        border-bottom: 1px solid var(--mist);
        gap: 1rem;
      }
      .nav-toggle { display: block; }
      .stats { grid-template-columns: repeat(2, 1fr); }
      .stat:nth-child(2)::after { display: none; }
      .services-grid { grid-template-columns: 1fr; }
      .trust-grid { grid-template-columns: 1fr; }
      .footer { flex-direction: column; gap: 0.75rem; text-align: center; }
    }

    @media (max-width: 480px) {
      .stats { grid-template-columns: 1fr; }
      .stat::after { display: none !important; }
      .stat {
        padding: 1.5rem;
        border-bottom: 1px solid rgba(255,255,255,0.05);
      }
      .hero-actions { flex-direction: column; align-items: flex-start; }
    }

    @media (prefers-reduced-motion: reduce) {
      .reveal { opacity: 1; transform: none; transition: none; }
      html { scroll-behavior: auto; }
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav class="nav" id="nav">
    <img
      src="https://boiler-repair-liverpool.com/wp-content/uploads/2026/01/Boiler-repair-liverpool-Logo-1.png"
      alt="Response Boiler Repair Liverpool"
      class="nav-logo"
    />
    <ul class="nav-links" id="navLinks">
      <li><a href="#services">Services</a></li>
      <li><a href="#reviews">Reviews</a></li>
      <li><a href="#about">About</a></li>
      <li><a href="#contact" class="nav-cta">Get a Quote</a></li>
    </ul>
    <button class="nav-toggle" id="navToggle" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-content">
      <span class="hero-est reveal">Gas Safe Registered</span>
      <h1 class="reveal reveal-delay-1">Boiler repair engineers you can&nbsp;trust</h1>
      <p class="reveal reveal-delay-2">
        Reliable, Gas Safe registered heating engineers in Liverpool.
        From emergency repairs to full installations, with a 12 month guarantee
        on every job. No pressure, no hidden costs.
      </p>
      <div class="hero-actions reveal reveal-delay-3">
        <a href="tel:07856297070" class="btn-primary">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          Call Now
        </a>
        <a href="#services" class="btn-secondary">
          Our services
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
    <div class="hero-image">
      <img
        src="https://boiler-repair-liverpool.com/wp-content/uploads/2023/03/TP_logo_dark_blue_bg.jpg"
        alt="Response Boiler Repair - professional heating engineers in Liverpool"
        loading="eager"
      />
    </div>
  </section>

  <!-- STATS -->
  <div class="stats">
    <div class="stat reveal">
      <div class="stat-number">24/7</div>
      <div class="stat-label">Availability</div>
    </div>
    <div class="stat reveal reveal-delay-1">
      <div class="stat-number">12</div>
      <div class="stat-label">Month Guarantee</div>
    </div>
    <div class="stat reveal reveal-delay-2">
      <div class="stat-number">5&#9733;</div>
      <div class="stat-label">Rated Service</div>
    </div>
    <div class="stat reveal reveal-delay-3">
      <div class="stat-number">Gas Safe</div>
      <div class="stat-label">Registered Engineers</div>
    </div>
  </div>

  <!-- SERVICES -->
  <section class="services" id="services">
    <div class="section-label reveal">What We Do</div>
    <h2 class="section-heading reveal reveal-delay-1">Services without limits for every&nbsp;home</h2>
    <p class="section-sub reveal reveal-delay-2">No job too big or small. From emergency boiler repairs to full installations, we cover Liverpool and the surrounding areas with genuine parts and Gas Safe registered work.</p>

    <div class="services-grid">
      <div class="service-card reveal">
        <span class="service-number">01</span>
        <svg class="service-icon" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 48 48">
          <rect x="12" y="8" width="24" height="32" rx="2" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="24" cy="20" r="5"/>
          <path d="M20 32h8" stroke-linecap="round"/>
          <path d="M22 28h4" stroke-linecap="round"/>
          <path d="M24 15v-2" stroke-linecap="round"/>
          <path d="M24 27v-2" stroke-linecap="round"/>
        </svg>
        <h3>Boiler Repair &amp; Diagnostics</h3>
        <p>Expert fault-finding and repair across all major brands including Baxi, Worcester, Vaillant, Ideal and Glow-worm. Same-day callouts available with genuine parts.</p>
      </div>

      <div class="service-card reveal reveal-delay-1">
