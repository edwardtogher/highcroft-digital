---
// Secure Gas 247 — Preview Page
// Built by Highcroft Digital
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Secure Gas 247 — Boiler Repair Leeds</title>
  <meta name="description" content="Gas Safe registered boiler repair, servicing and installations in Leeds. 24/7 emergency callouts. 15 years experience." />
  <meta property="og:title" content="Secure Gas 247 — Your New Site" />
  <meta property="og:description" content="Professional boiler repair, servicing and installations in Leeds. 24/7 emergency callouts." />
  <meta property="og:image" content="https://securegas247.co.uk/wp-content/uploads/2021/03/1SecureGas247.png" />
  <meta property="og:url" content="https://highcroftdigital.com/preview/secure-gas-247" />
  <meta property="og:type" content="website" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --navy: #0b1522;
      --navy-light: #142133;
      --blue: #2483c7;
      --blue-soft: #e6f2fb;
      --text: #1e293b;
      --text-mid: #475569;
      --text-light: #94a3b8;
      --border: #e2e8f0;
      --bg: #fafbfc;
      --white: #ffffff;
      --amber: #f59e0b;
      --green: #10b981;
      --radius: 12px;
      --font: 'Outfit', system-ui, -apple-system, sans-serif;
    }

    html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }
    body { font-family: var(--font); color: var(--text); background: var(--white); line-height: 1.6; overflow-x: hidden; }

    /* ── NAV ── */
    .nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(255,255,255,0.92);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
      padding: 0 clamp(1.25rem, 4vw, 3rem);
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .nav-logo { height: 36px; }

    .nav-right { display: flex; align-items: center; gap: 0.5rem; }

    .nav-links { display: flex; gap: 0.25rem; list-style: none; }

    .nav-links a {
      color: var(--text-mid);
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 500;
      padding: 0.5rem 0.75rem;
      border-radius: 8px;
      transition: all 0.15s;
    }

    .nav-links a:hover { color: var(--text); background: var(--bg); }

    .nav-cta {
      background: var(--blue);
      color: var(--white) !important;
      padding: 0.5rem 1rem !important;
      border-radius: 8px !important;
      font-weight: 600 !important;
      font-size: 0.85rem !important;
      text-decoration: none;
      transition: opacity 0.15s !important;
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
    }

    .nav-cta:hover { opacity: 0.9; }

    .nav-toggle {
      display: none;
      background: none;
      border: 1px solid var(--border);
      border-radius: 8px;
      cursor: pointer;
      padding: 0.5rem;
      width: 40px;
      height: 40px;
      align-items: center;
      justify-content: center;
    }

    .nav-toggle svg { color: var(--text); }

    /* ── HERO ── */
    .hero {
      padding: clamp(3rem, 8vw, 6rem) clamp(1.25rem, 4vw, 3rem);
      max-width: 680px;
      margin: 0 auto;
      text-align: center;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      background: var(--blue-soft);
      color: var(--blue);
      padding: 0.35rem 0.85rem;
      border-radius: 100px;
      font-size: 0.78rem;
      font-weight: 600;
      margin-bottom: 1.5rem;
    }

    .hero-badge svg { flex-shrink: 0; }

    .hero h1 {
      font-size: clamp(2.2rem, 6vw, 3.5rem);
      font-weight: 800;
      color: var(--navy);
      line-height: 1.08;
      letter-spacing: -0.03em;
      margin-bottom: 1.25rem;
    }

    .hero-sub {
      font-size: clamp(1rem, 2vw, 1.15rem);
      color: var(--text-mid);
      line-height: 1.6;
      max-width: 520px;
      margin: 0 auto 2rem;
    }

    .hero-btns {
      display: flex;
      gap: 0.75rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.85rem 1.5rem;
      border-radius: 10px;
      font-size: 0.9rem;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.15s;
      cursor: pointer;
      border: none;
    }

    .btn-primary { background: var(--navy); color: var(--white); }
    .btn-primary:hover { opacity: 0.9; transform: translateY(-1px); }
    .btn-outline { background: var(--white); color: var(--text); border: 1.5px solid var(--border); }
    .btn-outline:hover { border-color: var(--text-light); background: var(--bg); }

    .hero-trust {
      margin-top: 2.5rem;
      display: flex;
      justify-content: center;
      gap: 2rem;
      flex-wrap: wrap;
    }

    .hero-trust-item {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.8rem;
      color: var(--text-light);
      font-weight: 500;
    }

    .hero-trust-item svg { color: var(--green); flex-shrink: 0; }

    /* ── STATS ── */
    .stats {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      max-width: 900px;
      margin: 0 auto;
    }

    .stat {
      padding: 2rem 1rem;
      text-align: center;
      border-right: 1px solid var(--border);
    }

    .stat:last-child { border-right: none; }

    .stat-num {
      font-size: 1.75rem;
      font-weight: 800;
      color: var(--navy);
      line-height: 1;
    }

    .stat-label {
      font-size: 0.72rem;
      color: var(--text-light);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      font-weight: 600;
      margin-top: 0.35rem;
    }

    /* ── SERVICES ── */
    .services {
      padding: clamp(3rem, 8vw, 5rem) clamp(1.25rem, 4vw, 3rem);
      max-width: 1000px;
      margin: 0 auto;
    }

    .section-label {
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--blue);
      margin-bottom: 0.5rem;
    }

    .section-title {
      font-size: clamp(1.5rem, 3.5vw, 2.2rem);
      font-weight: 800;
      color: var(--navy);
      letter-spacing: -0.02em;
      margin-bottom: 0.5rem;
    }

    .section-desc {
      color: var(--text-mid);
      font-size: 0.95rem;
      max-width: 480px;
      margin-bottom: 2.5rem;
    }

    .services-list {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
    }

    .svc {
      background: var(--white);
      padding: 2rem 1.5rem;
      transition: background 0.15s;
      cursor: default;
    }

    .svc:hover { background: var(--bg); }

    .svc-icon {
      width: 40px;
      height: 40px;
      border-radius: 10px;
      background: var(--blue-soft);
      color: var(--blue);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1rem;
    }

    .svc h3 {
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--navy);
      margin-bottom: 0.5rem;
    }

    .svc p {
      font-size: 0.82rem;
      color: var(--text-mid);
      line-height: 1.55;
    }

    /* ── WHY ── */
    .why {
      background: var(--navy);
      padding: clamp(3rem, 8vw, 5rem) clamp(1.25rem, 4vw, 3rem);
    }

    .why-inner {
      max-width: 1000px;
      margin: 0 auto;
    }

    .why .section-label { color: var(--blue); }
    .why .section-title { color: var(--white); }
    .why .section-desc { color: var(--text-light); }

    .why-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
    }

    .why-item {
      background: var(--navy-light);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: var(--radius);
      padding: 1.5rem;
      transition: border-color 0.2s;
    }

    .why-item:hover { border-color: rgba(255,255,255,0.12); }

    .why-icon {
      width: 36px;
      height: 36px;
      border-radius: 8px;
      background: rgba(36,131,199,0.15);
      color: var(--blue);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 0.75rem;
    }

    .why-item h4 {
      color: var(--white);
      font-size: 0.85rem;
      font-weight: 600;
      margin-bottom: 0.3rem;
    }

    .why-item p {
      color: #64748b;
      font-size: 0.78rem;
      line-height: 1.5;
    }

    /* ── REVIEWS ── */
    .reviews {
      padding: clamp(3rem, 8vw, 5rem) clamp(1.25rem, 4vw, 3rem);
      max-width: 1000px;
      margin: 0 auto;
    }

    .reviews-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .review {
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.5rem;
    }

    .review-stars {
      display: flex;
      gap: 2px;
      color: var(--amber);
      margin-bottom: 0.75rem;
    }

    .review q {
      display: block;
      font-size: 0.88rem;
      color: var(--text-mid);
      line-height: 1.6;
      font-style: normal;
      margin-bottom: 1rem;
    }

    .review-footer {
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }

    .review-avatar {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: var(--blue-soft);
      color: var(--blue);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.7rem;
      font-weight: 700;
    }

    .review-name {
      font-size: 0.82rem;
      font-weight: 600;
      color: var(--navy);
    }

    .review-src {
      font-size: 0.72rem;
      color: var(--text-light);
    }

    /* ── CTA ── */
    .cta {
      margin: 0 clamp(1.25rem, 4vw, 3rem);
      background: var(--navy);
      border-radius: 16px;
      padding: clamp(2.5rem, 6vw, 4rem);
      text-align: center;
      margin-bottom: clamp(2rem, 4vw, 3rem);
    }

    .cta h2 {
      font-size: clamp(1.5rem, 3.5vw, 2.2rem);
      font-weight: 800;
      color: var(--white);
      letter-spacing: -0.02em;
      margin-bottom: 0.5rem;
    }

    .cta-desc {
      color: #94a3b8;
      font-size: 0.95rem;
      max-width: 440px;
      margin: 0 auto 1.5rem;
    }

    .cta-phone {
      display: block;
      font-size: clamp(1.8rem, 4vw, 2.5rem);
      font-weight: 800;
      color: var(--white);
      text-decoration: none;
      margin-bottom: 0.4rem;
      letter-spacing: -0.02em;
      transition: color 0.15s;
    }

    .cta-phone:hover { color: var(--blue); }

    .cta-email {
      color: var(--blue);
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 500;
      margin-bottom: 1.5rem;
      display: inline-block;
    }

    .cta .btn-primary {
      background: var(--blue);
      margin-top: 0.5rem;
    }

    .cta-areas {
      margin-top: 1.5rem;
      font-size: 0.75rem;
      color: #64748b;
      letter-spacing: 0.04em;
    }

    /* ── FOOTER ── */
    .footer {
      padding: 1.5rem clamp(1.25rem, 4vw, 3rem);
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 0.75rem;
      color: var(--text-light);
      border-top: 1px solid var(--border);
    }

    .footer a { color: var(--text-light); text-decoration: none; }
    .footer a:hover { color: var(--blue); }

    /* ── ANIMATIONS ── */
    .rv {
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                  transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .rv.vis { opacity: 1; transform: none; }
    .rv-d1 { transition-delay: 0.06s; }
    .rv-d2 { transition-delay: 0.12s; }
    .rv-d3 { transition-delay: 0.18s; }

    /* ── RESPONSIVE ── */
    @media (max-width: 768px) {
      .nav-links { display: none; }
      .nav { flex-wrap: wrap; }
      .nav-links.open {
        display: flex;
        flex-direction: column;
        width: 100%;
        order: 99;
        background: var(--white);
        padding: 0.75rem 0;
        gap: 0.25rem;
        border-top: 1px solid var(--border);
      }
      .nav-links.open a {
        padding: 0.75rem 0.5rem;
        font-size: 1rem;
        border-radius: 8px;
      }
      .nav-links.open a:hover { background: var(--bg); }
      .nav-toggle { display: flex; }
      .stats { grid-template-columns: repeat(2, 1fr); }
      .stat { border-bottom: 1px solid var(--border); }
      .stat:nth-child(odd) { border-right: 1px solid var(--border); }
      .stat:nth-child(even) { border-right: none; }
      .services-list { grid-template-columns: 1fr; }
      .why-grid { grid-template-columns: repeat(2, 1fr); }
      .reviews-grid { grid-template-columns: 1fr; }
      .footer { flex-direction: column; gap: 0.5rem; text-align: center; }
    }

    @media (max-width: 480px) {
      .stats { grid-template-columns: 1fr; }
      .stat { border-right: none !important; }
      .why-grid { grid-template-columns: 1fr; }
      .hero-btns { flex-direction: column; }
      .hero-trust { flex-direction: column; align-items: center; gap: 0.5rem; }
    }

    @media (prefers-reduced-motion: reduce) {
      .rv { opacity: 1; transform: none; transition: none; }
      html { scroll-behavior: auto; }
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav class="nav">
    <img src="https://securegas247.co.uk/wp-content/uploads/2021/03/1SecureGas247.png" alt="Secure Gas 247" class="nav-logo" />
    <div class="nav-right">
      <ul class="nav-links" id="navLinks">
        <li><a href="#services">Services</a></li>
        <li><a href="#reviews">Reviews</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
      <a href="tel:07515314131" class="nav-cta">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        07515 314 131
      </a>
      <button class="nav-toggle" id="navToggle" aria-label="Menu">
