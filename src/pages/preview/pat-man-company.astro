---
// PAT Man Company — Bespoke Preview
// Built by Highcroft Digital
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>PAT Man Company — PAT Testing Sheffield</title>
  <meta name="description" content="Yorkshire's only all-female PAT testing team. PAT testing, EICR, fire alarm testing in Sheffield, Rotherham, Barnsley & Doncaster. Call 0114 299 3148." />
  <meta property="og:title" content="PAT Man Company — Your New Site" />
  <meta property="og:description" content="PAT testing and electrical safety in Sheffield. Yorkshire's only all-female team." />
  <meta property="og:image" content="https://www.patmancompany.co.uk/wp-content/uploads/2024/08/pat-man-company-logo.webp" />
  <meta property="og:url" content="https://highcroftdigital.com/preview/pat-man-company" />
  <meta property="og:type" content="website" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Electrician",
    "name": "PAT Man Company",
    "telephone": "+441142993148",
    "email": "info@patmancompany.co.uk",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Suite 6, Fortuna House, 88 Queen Street",
      "addressLocality": "Sheffield",
      "addressRegion": "South Yorkshire",
      "postalCode": "S1 2FW",
      "addressCountry": "GB"
    },
    "url": "https://highcroftdigital.com/preview/pat-man-company",
    "areaServed": ["Sheffield", "Rotherham", "Barnsley", "Doncaster"]
  }
  </script>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg: #0e0e14;
      --bg-raised: #16161f;
      --bg-card: #1c1c28;
      --bg-hover: #22222f;
      /* Logo palette */
      --pink: #d0a8d0;
      --blue: #30a0d8;
      --cyan: #78d0e0;
      --red: #f03028;
      --yellow: #ffd41d;
      /* Functional */
      --accent: var(--blue);
      --accent-glow: rgba(48, 160, 216, 0.12);
      --accent-soft: rgba(48, 160, 216, 0.08);
      --text: #e4e4e8;
      --text-mid: #9ca3af;
      --text-dim: #6b7280;
      --border: rgba(255, 255, 255, 0.06);
      --border-hover: rgba(255, 255, 255, 0.1);
      --amber: #f59e0b;
      --font: 'Space Grotesk', system-ui, sans-serif;
    }

    html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }

    body {
      font-family: var(--font);
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
      overflow-x: hidden;
    }

    a { color: inherit; }

    /* ── NAV ── */
    .nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(14, 14, 20, 0.92);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
      padding: 0 clamp(16px, 4vw, 32px);
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .nav-logo { height: 38px; width: auto; }

    .nav-right { display: flex; align-items: center; gap: 8px; }

    .nav-links { display: flex; gap: 4px; list-style: none; }

    .nav-links a {
      color: var(--text-mid);
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 500;
      padding: 6px 12px;
      border-radius: 6px;
      transition: color 0.15s, background 0.15s;
    }

    .nav-links a:hover { color: var(--text); background: var(--bg-raised); }

    .nav-phone {
      display: flex;
      align-items: center;
      gap: 6px;
      background: var(--blue);
      color: #0e0e14;
      padding: 8px 16px;
      border-radius: 8px;
      font-size: 0.85rem;
      font-weight: 700;
      text-decoration: none;
      transition: opacity 0.15s;
      -webkit-tap-highlight-color: transparent;
    }

    .nav-phone:hover { opacity: 0.9; }
    .nav-phone svg { width: 15px; height: 15px; flex-shrink: 0; }

    .nav-toggle {
      display: none;
      background: var(--bg-raised);
      border: none;
      border-radius: 8px;
      cursor: pointer;
      width: 40px;
      height: 40px;
      align-items: center;
      justify-content: center;
      -webkit-tap-highlight-color: transparent;
    }

    .nav-toggle span {
      display: block;
      width: 20px;
      height: 2px;
      background: var(--text);
      margin: 4px auto;
      border-radius: 2px;
      transition: 0.2s;
    }

    /* ── HERO ── */
    .hero {
      padding: clamp(48px, 10vw, 96px) clamp(16px, 4vw, 32px) clamp(40px, 8vw, 72px);
      max-width: 720px;
      margin: 0 auto;
      text-align: center;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(120, 208, 224, 0.1);
      color: var(--cyan);
      border: 1px solid rgba(120, 208, 224, 0.2);
      padding: 6px 14px;
      border-radius: 100px;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      margin-bottom: 28px;
    }

    .hero h1 {
      font-size: clamp(1.9rem, 6vw, 3.2rem);
      font-weight: 700;
      line-height: 1.08;
      letter-spacing: -0.03em;
      margin-bottom: 16px;
      color: var(--text);
    }

    .hero h1 .accent { color: var(--pink); }

    .hero-sub {
      font-size: clamp(0.95rem, 2vw, 1.1rem);
      color: var(--text-mid);
      max-width: 520px;
      margin: 0 auto 28px;
      line-height: 1.6;
    }

    .hero-cta {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--pink);
      color: #0e0e14;
      padding: 14px 28px;
      border-radius: 10px;
      font-size: 1rem;
      font-weight: 700;
      text-decoration: none;
      transition: transform 0.15s, box-shadow 0.15s;
      -webkit-tap-highlight-color: transparent;
    }

    .hero-cta:hover { transform: translateY(-1px); box-shadow: 0 4px 20px rgba(208, 168, 208, 0.3); }
    .hero-cta:active { transform: scale(0.97); }
    .hero-cta svg { width: 18px; height: 18px; }

    .hero-micro {
      font-size: 0.8rem;
      color: var(--text-dim);
      margin-top: 12px;
    }

    /* ── TRUST STRIP ── */
    .trust-strip {
      display: flex;
      justify-content: center;
      gap: clamp(16px, 4vw, 32px);
      flex-wrap: wrap;
      padding: 20px clamp(16px, 4vw, 32px);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }

    .trust-item {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 0.78rem;
      color: var(--text-mid);
      font-weight: 500;
    }

    .trust-item svg { width: 16px; height: 16px; color: var(--cyan); flex-shrink: 0; }

    /* ── CLIENTS ── */
    .clients {
      padding: clamp(32px, 6vw, 48px) clamp(16px, 4vw, 32px);
      text-align: center;
    }

    .clients-label {
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--text-dim);
      font-weight: 600;
      margin-bottom: 20px;
    }

    .clients-row {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: clamp(20px, 4vw, 40px);
      flex-wrap: wrap;
    }

    .client-name {
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--text-dim);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      transition: color 0.2s;
      white-space: nowrap;
    }

    .client-name:hover { color: var(--text-mid); }

    /* ── STATS ── */
    .stats {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      max-width: 800px;
      margin: 0 auto;
    }

    .stat {
      padding: clamp(20px, 3vw, 28px) 12px;
      text-align: center;
      border-right: 1px solid var(--border);
    }

    .stat:last-child { border-right: none; }

    .stat-num {
      font-size: clamp(1.4rem, 3vw, 1.8rem);
      font-weight: 700;
      color: var(--yellow);
      line-height: 1;
    }

    .stat-label {
      font-size: 0.68rem;
      color: var(--text-dim);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      font-weight: 500;
      margin-top: 4px;
    }

    /* ── SERVICES ── */
    .services {
      padding: clamp(48px, 8vw, 72px) clamp(16px, 4vw, 32px);
      max-width: 960px;
      margin: 0 auto;
    }

    .section-tag {
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--blue);
      margin-bottom: 8px;
    }

    .section-title {
      font-size: clamp(1.4rem, 3.5vw, 2rem);
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 8px;
    }

    .section-desc {
      color: var(--text-mid);
      font-size: 0.92rem;
      max-width: 480px;
      margin-bottom: clamp(28px, 5vw, 40px);
    }

    .services-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
    }

    .svc {
      background: var(--bg-raised);
      padding: clamp(20px, 3vw, 28px);
      transition: background 0.2s;
    }

    .svc:hover { background: var(--bg-hover); }

    .svc-icon {
      width: 36px;
      height: 36px;
      border-radius: 8px;
      background: rgba(48, 160, 216, 0.08);
      color: var(--blue);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 12px;
    }

    .svc-icon svg { width: 18px; height: 18px; }

    .svc h3 {
      font-size: 0.9rem;
      font-weight: 600;
      margin-bottom: 6px;
      color: var(--text);
    }

    .svc p {
      font-size: 0.8rem;
      color: var(--text-mid);
      line-height: 1.5;
    }

    /* ── PROCESS ── */
    .process {
      padding: clamp(48px, 8vw, 72px) clamp(16px, 4vw, 32px);
      background: var(--bg-raised);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }

    .process-inner {
      max-width: 960px;
      margin: 0 auto;
    }

    .process-steps {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 2px;
      margin-top: clamp(28px, 5vw, 40px);
    }

    .step {
      text-align: center;
      padding: 20px 12px;
      position: relative;
    }

    .step-num {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: var(--red);
      color: #fefefe;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.85rem;
      font-weight: 700;
      margin: 0 auto 12px;
    }

    .step h4 {
      font-size: 0.85rem;
      font-weight: 600;
      margin-bottom: 4px;
    }

    .step p {
      font-size: 0.78rem;
      color: var(--text-dim);
    }

    /* ── REVIEWS ── */
    .reviews {
      padding: clamp(48px, 8vw, 72px) clamp(16px, 4vw, 32px);
      max-width: 960px;
      margin: 0 auto;
    }

    .reviews-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .review {
      background: var(--bg-raised);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: clamp(16px, 3vw, 24px);
      transition: border-color 0.2s;
    }

    .review:hover { border-color: var(--border-hover); }

    .review-stars {
      display: flex;
      gap: 2px;
      color: var(--amber);
      margin-bottom: 10px;
    }

    .review-stars svg { width: 14px; height: 14px; }

    .review q {
      display: block;
      font-size: 0.85rem;
      color: var(--text-mid);
      line-height: 1.6;
      font-style: normal;
      margin-bottom: 12px;
    }

    .review-author {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .review-avatar {
      width: 28px;
      height: 28px;
      border-radius: 50%;
      background: rgba(208, 168, 208, 0.12);
      color: var(--pink);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.65rem;
      font-weight: 700;
    }

    .review-name { font-size: 0.8rem; font-weight: 600; }
    .review-loc { font-size: 0.7rem; color: var(--text-dim); }

    /* ── FAQ ── */
    .faq {
      padding: clamp(48px, 8vw, 72px) clamp(16px, 4vw, 32px);
      max-width: 680px;
      margin: 0 auto;
      border-top: 1px solid var(--border);
    }

    .faq details {
      border-bottom: 1px solid var(--border);
    }

    .faq summary {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 16px 0;
      cursor: pointer;
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--text);
      list-style: none;
      -webkit-tap-highlight-color: transparent;
    }

    .faq summary::-webkit-details-marker { display: none; }

    .faq summary::after {
      content: '+';
      font-size: 1.2rem;
      color: var(--text-dim);
      font-weight: 400;
      transition: transform 0.2s;
    }

    .faq details[open] summary::after {
      content: '-';
    }

    .faq .faq-answer {
      padding: 0 0 16px;
      font-size: 0.85rem;
      color: var(--text-mid);
      line-height: 1.6;
    }

    /* ── CTA ── */
    .cta {
      margin: clamp(24px, 4vw, 40px) clamp(16px, 4vw, 32px);
      background: var(--blue);
      border-radius: 16px;
      padding: clamp(36px, 6vw, 56px);
      text-align: center;
    }

    .cta h2 {
      font-size: clamp(1.4rem, 3.5vw, 2rem);
      font-weight: 700;
      color: #0e0e14;
      letter-spacing: -0.02em;
      margin-bottom: 8px;
    }

    .cta-desc {
      color: rgba(14, 14, 20, 0.7);
      font-size: 0.92rem;
      max-width: 400px;
      margin: 0 auto 20px;
    }

    .cta-phone {
      display: block;
      font-size: clamp(1.6rem, 4vw, 2.2rem);
      font-weight: 700;
      color: #0e0e14;
      text-decoration: none;
      margin-bottom: 6px;
      letter-spacing: -0.02em;
    }

    .cta-email {
      color: rgba(14, 14, 20, 0.6);
      text-decoration: none;
      font-size: 0.85rem;
      margin-bottom: 20px;
      display: inline-block;
    }

    .cta-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: #0e0e14;
      color: var(--cyan);
      padding: 12px 24px;
      border-radius: 10px;
      font-size: 0.9rem;
      font-weight: 700;
      text-decoration: none;
      transition: opacity 0.15s;
    }

    .cta-btn:hover { opacity: 0.9; }
    .cta-btn svg { width: 16px; height: 16px; }

    .cta-areas {
      margin-top: 16px;
      font-size: 0.72rem;
      color: rgba(14, 14, 20, 0.5);
      letter-spacing: 0.04em;
    }

    /* ── FOOTER ── */
    .footer {
      padding: clamp(32px, 5vw, 48px) clamp(16px, 4vw, 32px);
      border-top: 1px solid var(--border);
    }

    .footer-inner {
      max-width: 960px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1.5fr 1fr 1fr;
      gap: 32px;
    }

    .footer-brand { font-size: 0.85rem; color: var(--text-mid); line-height: 1.6; }
    .footer-brand strong { color: var(--text); display: block; margin-bottom: 4px; }

    .footer h4 { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-dim); margin-bottom: 12px; }

    .footer-links { list-style: none; }
    .footer-links li { margin-bottom: 6px; }
    .footer-links a { color: var(--text-mid); text-decoration: none; font-size: 0.82rem; transition: color 0.15s; }
    .footer-links a:hover { color: var(--cyan); }

    .footer-bottom {
      max-width: 960px;
      margin: 20px auto 0;
      padding-top: 16px;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      font-size: 0.72rem;
      color: var(--text-dim);
    }

    .footer-bottom a { color: var(--text-dim); text-decoration: none; }
    .footer-bottom a:hover { color: var(--cyan); }

    /* ── FLOATING PHONE ── */
    .float-phone {
      display: none;
      position: fixed;
      bottom: 20px;
      right: 20px;
      z-index: 90;
      width: 56px;
      height: 56px;
      border-radius: 50%;
      background: var(--blue);
      color: #0e0e14;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      box-shadow: 0 4px 16px rgba(48, 160, 216, 0.3);
      -webkit-tap-highlight-color: transparent;
    }

    .float-phone svg { width: 22px; height: 22px; }

    /* ── REVEAL ── */
    .rv {
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                  transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .rv.vis { opacity: 1; transform: none; }
    .rv-d1 { transition-delay: 0.06s; }
    .rv-d2 { transition-delay: 0.12s; }
    .rv-d3 { transition-delay: 0.18s; }

    /* ── RESPONSIVE ── */
    @media (max-width: 768px) {
      .nav-links { display: none; }
      .nav-links.open {
        display: flex;
        flex-direction: column;
        position: absolute;
        top: 64px;
        left: 0;
        right: 0;
        background: var(--bg);
        padding: 12px 16px;
        border-bottom: 1px solid var(--border);
        box-shadow: 0 12px 32px rgba(0,0,0,0.3);
        z-index: 200;
        gap: 2px;
      }
      .nav-links.open a { padding: 12px 8px; font-size: 0.95rem; }
      .nav-toggle { display: flex; }
      .stats { grid-template-columns: repeat(2, 1fr); }
      .stat:nth-child(2) { border-right: none; }
      .stat:nth-child(1), .stat:nth-child(2) { border-bottom: 1px solid var(--border); }
      .services-grid { grid-template-columns: 1fr; }
      .process-steps { grid-template-columns: repeat(2, 1fr); }
      .reviews-grid { grid-template-columns: 1fr; }
      .footer-inner { grid-template-columns: 1fr; gap: 24px; }
      .footer-bottom { flex-direction: column; gap: 4px; text-align: center; }
      .float-phone { display: flex; }
    }

    @media (max-width: 480px) {
      .stats { grid-template-columns: 1fr; }
      .stat { border-right: none !important; border-bottom: 1px solid var(--border); }
      .stat:last-child { border-bottom: none; }
      .process-steps { grid-template-columns: 1fr; }
      .client-name { font-size: 0.7rem; }
    }

    @media (prefers-reduced-motion: reduce) {
      .rv { opacity: 1; transform: none; transition: none; }
      html { scroll-behavior: auto; }
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav class="nav">
    <img src="https://www.patmancompany.co.uk/wp-content/uploads/2024/08/pat-man-company-logo.webp" alt="PAT Man Company" class="nav-logo" />
    <div class="nav-right">
      <ul class="nav-links" id="navLinks">
        <li><a href="#services">Services</a></li>
        <li><a href="#reviews">Reviews</a></li>
        <li><a href="#faq">FAQ</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
      <a href="tel:01142993148" class="nav-phone">
        <svg fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        0114 299 3148
      </a>
      <button class="nav-toggle" id="navToggle" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-badge rv">Yorkshire's Only All-Female PAT Testing Team</div>
    <h1 class="rv rv-d1">Electrical testing in Sheffield <span class="accent">done right</span></h1>
