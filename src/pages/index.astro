---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Sticky header - appears when you scroll past the hero logo -->
  <header class="sticky-header" id="stickyHeader">
    <div class="logo-mark">
      <span class="dot"></span><span class="dot"></span><span class="dot"></span>
      <span class="dot"></span><span class="dot"></span><span class="dot"></span>
      <span class="dot"></span><span class="dot"></span><span class="dot"></span>
    </div>
    <div class="wordmark">
      <span class="wordmark-main">HIGHCROFT</span>
      <span class="wordmark-sub">DIGITAL</span>
    </div>
  </header>

  <!-- Hero -->
  <section class="hero">
    <div class="accent-yellow"></div>
    <p class="hero-label fade-in">Digital Design Studio</p>
    <div class="hero-logo fade-in" id="heroLogo">
      <div class="logo-mark">
        <span class="dot"></span><span class="dot"></span><span class="dot"></span>
        <span class="dot"></span><span class="dot"></span><span class="dot"></span>
        <span class="dot"></span><span class="dot"></span><span class="dot"></span>
      </div>
      <div class="wordmark">
        <span class="wordmark-main">HIGHCROFT</span>
        <span class="wordmark-sub">DIGITAL</span>
      </div>
    </div>
    <p class="hero-sub fade-in">Modern websites, AI tools, and automation systems for businesses that want real results without the agency runaround. Based in Surrey, UK.</p>
  </section>

  <!-- Services -->
  <section class="services">
    <p class="services-label fade-in">What we build</p>
    <div class="services-grid">
      <div class="service">
        <div class="service-marker"></div>
        <h3>Modern Websites</h3>
        <p>Fast, responsive sites built with clean code. Designed to load quickly and convert visitors into customers.</p>
      </div>
      <div class="service">
        <div class="service-marker"></div>
        <h3>AI &amp; Automation</h3>
        <p>Custom AI tools and automated workflows that handle the repetitive work so your team doesn't have to.</p>
      </div>
      <div class="service">
        <div class="service-marker"></div>
        <h3>Ongoing Support</h3>
        <p>Hosting, updates, and maintenance handled. Your site stays fast, secure, and up to date.</p>
      </div>
    </div>
  </section>

  <!-- Approach -->
  <section class="approach fade-in">
    <div class="approach-left">
      <p class="approach-label">How we work</p>
      <h2 class="approach-heading">Direct. Fast. No filler.</h2>
    </div>
    <div class="approach-right">
      <p class="approach-text">You work directly with the person building your project. No account managers, no handoffs, no waiting. Just clear communication and real progress.</p>
      <p class="approach-text">We build in short cycles, stay close to the problem, and put working software in your hands fast.</p>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="footer-left">
      <span class="footer-copy">&copy; 2026 Highcroft Digital</span>
      <span class="footer-location">Surrey, UK</span>
    </div>
    <div class="footer-links">
      <a href="/privacy">Privacy Policy</a>
      <a href="/terms">Terms &amp; Conditions</a>
    </div>
  </footer>

  <script is:inline>
    (function() {
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      }, { threshold: 0.1 });

      document.querySelectorAll('.fade-in, .service').forEach(function(el) {
        observer.observe(el);
      });

      var heroLogo = document.getElementById('heroLogo');
      var stickyHeader = document.getElementById('stickyHeader');

      var logoObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            stickyHeader.classList.remove('show');
          } else {
            stickyHeader.classList.add('show');
          }
        });
      }, { threshold: 0, rootMargin: '0px 0px 0px 0px' });

      logoObserver.observe(heroLogo);
    })();
  </script>
</Layout>
