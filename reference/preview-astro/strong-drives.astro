---
// ============================================================
// STRONG DRIVES — Bespoke Preview Site
// ============================================================
// Dark, industrial, rugged design for Leicester driveway specialists
// Cool slate steel (#6d8fa5) + Dark bg (#111111) + Oswald font
// ============================================================
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Strong Drives — Driveways Built to Last | Leicester</title>
  <meta name="description" content="Leicester's 5-star rated driveway specialists. Block paving, resin bound, tarmac, and cobblecrete. Over 20 years experience." />

  <!-- OG Tags -->
  <meta property="og:title" content="Strong Drives — Your New Site" />
  <meta property="og:description" content="Leicester's 5-star rated driveway specialists. Block paving, resin bound, tarmac, and cobblecrete. Over 20 years experience." />
  <meta property="og:url" content="https://highcroftdigital.com/preview/strong-drives" />
  <meta property="og:type" content="website" />

  <!-- Oswald from Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  <!-- JSON-LD Schema -->
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "HomeAndConstructionBusiness",
    "name": "Strong Drives",
    "description": "Specialist in Driveways & Landscapes. Over 20 years experience in block paving, resin bound, tarmac, and cobblecrete driveways across Leicester and Leicestershire.",
    "telephone": "+447535687080",
    "email": "strongdrive55@gmail.com",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Newtown Linford Lane",
      "addressLocality": "Groby",
      "addressRegion": "Leicestershire",
      "postalCode": "LE6 0EA",
      "addressCountry": "GB"
    },
    "url": "https://highcroftdigital.com/preview/strong-drives",
    "image": "https://img1.wsimg.com/isteam/ip/6b1dae52-b14c-4034-b14e-4fcdf6efea56/jay%20logo%202.jpg",
    "areaServed": ["Leicester", "Groby", "Anstey", "Ratby", "Markfield", "Leicestershire"],
    "openingHours": "Mo-Fr 09:00-17:00",
    "priceRange": "$$",
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5.0",
      "reviewCount": "98"
    },
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Driveway Services",
      "itemListElement": [
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Block Paving" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Resin Bound Driveways" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Tarmac Driveways" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Cobblecrete / Concrete Driveways" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Landscaping" } }
      ]
    }
  }</script>

  <style>
    /* ===== RESET & BASE ===== */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --steel: #6d8fa5;
      --steel-dark: #5c7d91;
      --steel-light: rgba(109, 143, 165, 0.10);
      --steel-mist: rgba(109, 143, 165, 0.06);
      --steel-border: rgba(109, 143, 165, 0.18);
      --star-gold: #d4a74a;
      --bg-main: #111111;
      --bg-alt: #151719;
      --bg-card: #1a1d20;
      --bg-footer: #0c0d0e;
      --border: #262a2e;
      --border-light: #1e2225;
      --text-heading: #e8ecef;
      --text-body: #9aa3ab;
      --text-muted: #6b737b;
      --text-light: #4e555c;
      --card-shadow: 0 2px 20px rgba(0, 0, 0, 0.3);
      --card-shadow-hover: 0 8px 40px rgba(0, 0, 0, 0.4);
      --radius: 10px;
      --radius-sm: 6px;
      --radius-lg: 14px;
    }

    html { scroll-behavior: smooth; scroll-padding-top: 80px; }

    body {
      font-family: 'Oswald', -apple-system, BlinkMacSystemFont, sans-serif;
      color: var(--text-body);
      background: var(--bg-main);
      line-height: 1.65;
      font-weight: 400;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }

    .container {
      width: 100%;
      max-width: 1120px;
      margin: 0 auto;
      padding: 0 clamp(1.25rem, 4vw, 2.5rem);
    }

    /* ===== SCROLL REVEAL ===== */
    .rv {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.65s cubic-bezier(0.22, 1, 0.36, 1), transform 0.65s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .rv.visible {
      opacity: 1;
      transform: translateY(0);
    }
    @media (prefers-reduced-motion: reduce) {
      .rv { opacity: 1; transform: none; transition: none; }
    }

    /* ===== NAV ===== */
    .nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(17, 17, 17, 0.92);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border-light);
      height: 72px;
    }
    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 72px;
    }
    .nav-logo {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    .nav-logo img {
      height: 44px;
      width: auto;
      border-radius: 6px;
    }
    .nav-right {
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .nav-phone {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-weight: 600;
      font-size: 0.95rem;
      color: var(--text-heading);
      padding: 0.5rem 1rem;
      border-radius: var(--radius-sm);
      background: var(--steel-light);
      border: 1px solid var(--steel-border);
      transition: background 0.2s;
      min-height: 44px;
    }
    .nav-phone:hover { background: rgba(109, 143, 165, 0.14); }
    .nav-phone svg { width: 18px; height: 18px; color: var(--steel); flex-shrink: 0; }

    .hamburger {
      display: none;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.5rem;
      min-width: 44px;
      min-height: 44px;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 5px;
    }
    .hamburger .bar {
      display: block;
      width: 24px;
      height: 2.5px;
      background: var(--text-heading);
      border-radius: 2px;
      transition: all 0.3s;
    }
    .hamburger.active .bar:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
    .hamburger.active .bar:nth-child(2) { opacity: 0; }
    .hamburger.active .bar:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 0.25rem;
    }
    .nav-links a {
      padding: 0.5rem 0.85rem;
      font-size: 0.9rem;
      font-weight: 500;
      color: var(--text-muted);
      border-radius: var(--radius-sm);
      transition: color 0.2s, background 0.2s;
      min-height: 44px;
      display: flex;
      align-items: center;
    }
    .nav-links a:hover {
      color: var(--text-heading);
      background: var(--steel-mist);
    }

    .mobile-menu {
      display: none;
      position: absolute;
      top: 72px;
      left: 0;
      right: 0;
      background: var(--bg-alt);
      border-bottom: 1px solid var(--border);
      padding: 1rem;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
    }
    .mobile-menu.open { display: flex; flex-direction: column; gap: 0.25rem; }
    .mobile-menu a {
      padding: 0.85rem 1rem;
      font-weight: 500;
      color: var(--text-body);
      border-radius: var(--radius-sm);
      min-height: 44px;
      display: flex;
      align-items: center;
    }
    .mobile-menu a:hover { background: var(--steel-mist); color: var(--text-heading); }

    @media (max-width: 768px) {
      .nav-links { display: none; }
      .hamburger { display: flex; }
      .nav-phone span { display: none; }
      .nav-phone { padding: 0.5rem; background: transparent; border: none; }
    }

    /* ===== HERO ===== */
    .hero {
      padding: clamp(4rem, 10vw, 7rem) 0 clamp(3rem, 7vw, 5rem);
      background: var(--bg-main);
      position: relative;
      overflow: hidden;
      text-align: center;
    }
    .hero::before {
      content: '';
      position: absolute;
      top: -20%;
      left: 50%;
      transform: translateX(-50%);
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, rgba(109, 143, 165, 0.06) 0%, transparent 65%);
      border-radius: 50%;
      pointer-events: none;
    }
    .hero::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--steel-border), transparent);
    }
    .hero-content {
      max-width: 720px;
      margin: 0 auto;
      position: relative;
      z-index: 1;
    }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--steel-light);
      color: var(--steel);
      font-weight: 700;
      font-size: 0.78rem;
      padding: 0.5rem 1.25rem;
      border-radius: 50px;
      margin-bottom: 1.75rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      border: 1px solid var(--steel-border);
    }
    .hero-badge svg { width: 16px; height: 16px; }
    .hero h1 {
      font-size: clamp(2.4rem, 6vw, 3.8rem);
      font-weight: 700;
      color: var(--text-heading);
      line-height: 1.1;
      margin-bottom: 1.5rem;
      letter-spacing: -0.025em;
    }
    .hero h1 .accent { color: var(--steel); }
    .hero-sub {
      font-size: clamp(1.05rem, 2vw, 1.2rem);
      color: var(--text-muted);
      line-height: 1.7;
      margin-bottom: 2.5rem;
      max-width: 580px;
      margin-left: auto;
      margin-right: auto;
    }
    .hero-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.65rem;
      background: var(--steel);
      color: #f0f3f5;
      font-weight: 700;
      font-size: 1.05rem;
      padding: 0.95rem 2.25rem;
      border-radius: var(--radius-sm);
      transition: background 0.2s, transform 0.15s;
      min-height: 50px;
      box-shadow: 0 4px 20px rgba(109, 143, 165, 0.3);
      letter-spacing: 0.02em;
    }
    .hero-cta:hover { background: var(--steel-dark); transform: translateY(-2px); }
    .hero-cta svg { width: 20px; height: 20px; }
    .hero-micro {
      margin-top: 1rem;
      font-size: 0.88rem;
      color: var(--text-light);
      font-weight: 500;
    }

    /* ===== TRUST STRIP ===== */
    .trust-strip {
      padding: clamp(1.5rem, 3vw, 2.5rem) 0;
      background: var(--bg-alt);
      border-bottom: 1px solid var(--border-light);
    }
    .trust-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
    }
    .trust-item {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 1rem;
      border-radius: var(--radius);
      background: var(--steel-mist);
      border: 1px solid var(--steel-border);
    }
    .trust-icon {
      width: 40px;
      height: 40px;
      border-radius: 8px;
      background: var(--steel-light);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      color: var(--steel);
    }
    .trust-icon svg { width: 20px; height: 20px; }
    .trust-label {
      font-weight: 600;
      font-size: 0.88rem;
      color: var(--text-heading);
      line-height: 1.3;
      letter-spacing: 0.01em;
    }
    @media (max-width: 768px) {
      .trust-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 480px) {
      .trust-grid { grid-template-columns: 1fr; }
    }

    /* ===== SECTION HELPERS ===== */
    .section { padding: clamp(3.5rem, 8vw, 6rem) 0; }
    .section-snug { padding: clamp(2.5rem, 6vw, 4.5rem) 0; }
    .section-alt { background: var(--bg-alt); }
    .section-label {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--steel);
      margin-bottom: 0.75rem;
    }
    .section-title {
      font-size: clamp(1.7rem, 4.5vw, 2.6rem);
      font-weight: 700;
      color: var(--text-heading);
      line-height: 1.15;
      margin-bottom: 0.75rem;
      letter-spacing: -0.02em;
    }
    .section-subtitle {
      font-size: clamp(0.98rem, 1.6vw, 1.1rem);
      color: var(--text-muted);
      max-width: 560px;
      line-height: 1.65;
      margin-bottom: 2.5rem;
    }

    /* ===== STATS ===== */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.25rem;
    }
    .stat-card {
      text-align: center;
      padding: clamp(1.5rem, 3vw, 2.25rem) 1rem;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      background: var(--bg-card);
      transition: border-color 0.3s, box-shadow 0.3s;
    }
    .stat-card:hover {
      border-color: var(--steel-border);
      box-shadow: 0 0 24px rgba(109, 143, 165, 0.08);
    }
    .stat-num {
      font-size: clamp(1.8rem, 4vw, 2.6rem);
      font-weight: 700;
      color: var(--steel);
      line-height: 1.1;
      margin-bottom: 0.35rem;
    }
    .stat-label {
      font-size: 0.88rem;
      font-weight: 500;
      color: var(--text-muted);
    }
    @media (max-width: 768px) {
      .stats-grid { grid-template-columns: repeat(2, 1fr); }
    }

    /* ===== SERVICES ===== */
    .services-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }
    .services-grid .service-card:nth-child(4),
    .services-grid .service-card:nth-child(5) {
      /* Last two cards centered on bottom row */
    }
    .service-card {
      padding: clamp(1.5rem, 3vw, 2rem);
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      transition: box-shadow 0.3s, border-color 0.3s, transform 0.2s;
    }
    .service-card:hover {
      box-shadow: 0 0 32px rgba(109, 143, 165, 0.1);
      border-color: rgba(109, 143, 165, 0.3);
      transform: translateY(-3px);
    }
    .service-icon {
      width: 48px;
      height: 48px;
      border-radius: var(--radius);
      background: var(--steel-light);
      border: 1px solid var(--steel-border);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--steel);
      margin-bottom: 1.25rem;
    }
    .service-icon svg { width: 24px; height: 24px; }
    .service-card h3 {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--text-heading);
      margin-bottom: 0.6rem;
      letter-spacing: -0.01em;
    }
    .service-card p {
      font-size: 0.93rem;
      color: var(--text-muted);
      line-height: 1.65;
    }
    @media (max-width: 768px) {
      .services-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 540px) {
      .services-grid { grid-template-columns: 1fr; }
    }

    /* ===== PROCESS ===== */
    .process-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
      position: relative;
    }
    .process-grid::before {
      content: '';
      position: absolute;
      top: 32px;
      left: 12.5%;
      width: 75%;
      height: 2px;
      background: linear-gradient(90deg, var(--steel), rgba(109, 143, 165, 0.15));
      z-index: 0;
    }
    .process-step {
      text-align: center;
      position: relative;
      z-index: 1;
    }
    .process-num {
      width: 64px;
      height: 64px;
      border-radius: 50%;
      background: var(--steel);
      color: #f0f3f5;
      font-weight: 700;
      font-size: 1.25rem;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1rem;
      box-shadow: 0 4px 20px rgba(109, 143, 165, 0.3);
    }
    .process-step h3 {
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--text-heading);
      margin-bottom: 0.4rem;
    }
    .process-step p {
      font-size: 0.9rem;
      color: var(--text-muted);
      line-height: 1.55;
    }
    @media (max-width: 768px) {
      .process-grid { grid-template-columns: repeat(2, 1fr); }
      .process-grid::before { display: none; }
    }
    @media (max-width: 480px) {
      .process-grid { grid-template-columns: 1fr; max-width: 320px; margin-left: auto; margin-right: auto; }
    }

    /* ===== REVIEWS ===== */
    .reviews-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }
    .review-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: clamp(1.5rem, 3vw, 2rem);
      transition: box-shadow 0.3s, transform 0.2s, border-color 0.3s;
      display: flex;
      flex-direction: column;
    }
    .review-card:hover {
      box-shadow: 0 0 28px rgba(109, 143, 165, 0.08);
      border-color: var(--steel-border);
      transform: translateY(-2px);
    }
    .review-stars {
      display: flex;
      gap: 2px;
      margin-bottom: 1rem;
    }
    .review-stars svg { width: 18px; height: 18px; }
    .review-text {
      font-size: 0.96rem;
      color: var(--text-body);
      line-height: 1.7;
      flex: 1;
      margin-bottom: 1.25rem;
      font-style: italic;
    }
    .review-author {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding-top: 1rem;
      border-top: 1px solid var(--border);
    }
    .review-avatar {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: var(--steel-light);
      border: 1px solid var(--steel-border);
      color: var(--steel);
      font-weight: 700;
      font-size: 0.85rem;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .review-name {
      font-weight: 600;
      color: var(--text-heading);
      font-size: 0.92rem;
    }
    .review-loc {
      font-size: 0.82rem;
      color: var(--text-light);
    }
    @media (max-width: 768px) {
      .reviews-grid { grid-template-columns: 1fr; max-width: 480px; }
    }

    /* ===== FAQ ===== */
    .faq-list {
      max-width: 700px;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .faq-item {
      border: 1px solid var(--border);
      border-radius: var(--radius);
      background: var(--bg-card);
      overflow: hidden;
      transition: border-color 0.2s;
    }
    .faq-item[open] { border-color: rgba(109, 143, 165, 0.35); }
    .faq-item summary {
      padding: 1.15rem 1.5rem;
      font-weight: 600;
      font-size: 1rem;
      color: var(--text-heading);
      cursor: pointer;
      list-style: none;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      min-height: 52px;
      user-select: none;
      transition: background 0.2s;
    }
    .faq-item summary:hover { background: var(--steel-mist); }
    .faq-item summary::-webkit-details-marker { display: none; }
    .faq-item summary::marker { display: none; content: ''; }
    .faq-chevron {
      flex-shrink: 0;
      width: 28px;
      height: 28px;
      border-radius: 50%;
      background: var(--steel-light);
      border: 1px solid var(--steel-border);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--steel);
      transition: transform 0.3s;
    }
    .faq-item[open] .faq-chevron { transform: rotate(180deg); }
    .faq-chevron svg { width: 16px; height: 16px; }
    .faq-body {
      padding: 0 1.5rem 1.25rem;
      font-size: 0.95rem;
      color: var(--text-muted);
      line-height: 1.7;
    }

    /* ===== CTA CARD ===== */
    .cta-section { padding: clamp(2.5rem, 6vw, 4.5rem) 0; }
    .cta-card {
      background: linear-gradient(135deg, #4a7088 0%, var(--steel) 50%, var(--steel-dark) 100%);
      border-radius: var(--radius-lg);
      padding: clamp(2.5rem, 5vw, 4rem);
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .cta-card::before {
      content: '';
      position: absolute;
      top: -40%;
      right: -10%;
      width: 300px;
      height: 300px;
      background: rgba(17, 17, 17, 0.06);
      border-radius: 50%;
      pointer-events: none;
    }
    .cta-card::after {
      content: '';
      position: absolute;
      bottom: -30%;
      left: -5%;
      width: 200px;
      height: 200px;
      background: rgba(17, 17, 17, 0.04);
      border-radius: 50%;
      pointer-events: none;
    }
    .cta-card > * { position: relative; z-index: 1; }
    .cta-card h2 {
      font-size: clamp(1.6rem, 4vw, 2.2rem);
