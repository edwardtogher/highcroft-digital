// Built by Highcroft Digital
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>EJ Plumbing — Emergency Plumbers, Bristol</title>
  <meta name="description" content="24/7 emergency plumbing services across Bristol. Blocked drains, boiler repairs, burst pipes, leak detection and more. Call now for fast response." />
  <meta property="og:title" content="EJ Plumbing — Your New Site" />
  <meta property="og:description" content="A modern, professional website for EJ Plumbing. 24/7 emergency plumbing services across Bristol." />
  <meta property="og:image" content="https://ejplumbing.co.uk/wp-content/uploads/2024/12/Website-LBF-Your-Story.png" />
  <meta property="og:url" content="https://highcroftdigital.com/preview/ej-plumbing" />
  <meta property="og:type" content="website" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=DM+Serif+Display&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --blue: #6EC1E4;
      --blue-deep: #13727B;
      --blue-hover: #0A5C64;
      --charcoal: #222626;
      --slate: #3a424d;
      --gray: #7A7A7A;
      --silver: #ADADAD;
      --mist: #F2F5F5;
      --cloud: #f7f8f9;
      --white: #fefefe;
      --green: #61CE70;
      --font-display: 'DM Serif Display', Georgia, serif;
      --font-body: 'DM Sans', -apple-system, sans-serif;
    }

    html {
      scroll-behavior: smooth;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    body {
      font-family: var(--font-body);
      color: var(--slate);
      background: var(--white);
      line-height: 1.6;
      overflow-x: hidden;
    }

    /* --- NAV --- */
    .nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      padding: 1.25rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: rgba(254,254,254,0.92);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(0,0,0,0.04);
      transition: padding 0.3s ease;
    }

    .nav.scrolled { padding: 0.75rem 2rem; }

    .nav-logo {
      height: 44px;
      width: auto;
      object-fit: contain;
    }

    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
      align-items: center;
    }

    .nav-links a {
      color: var(--slate);
      text-decoration: none;
      font-size: 0.875rem;
      font-weight: 500;
      letter-spacing: 0.02em;
      transition: color 0.2s;
    }

    .nav-links a:hover { color: var(--charcoal); }

    .nav-cta {
      background: var(--charcoal) !important;
      color: var(--white) !important;
      padding: 0.6rem 1.5rem !important;
      border-radius: 2px;
      font-size: 0.8rem !important;
      letter-spacing: 0.06em !important;
      text-transform: uppercase;
      font-weight: 600 !important;
      transition: background 0.2s !important;
    }

    .nav-cta:hover { background: var(--blue-deep) !important; }

    .nav-toggle {
      display: none;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.5rem;
    }

    .nav-toggle span {
      display: block;
      width: 24px;
      height: 2px;
      background: var(--charcoal);
      margin: 5px 0;
      transition: 0.3s;
    }

    /* --- HERO --- */
    .hero {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
      position: relative;
    }

    .hero-content {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: clamp(4rem, 8vw, 8rem);
      padding-top: 7rem;
    }

    .hero-est {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--blue-deep);
      margin-bottom: 2rem;
    }

    .hero-est::before {
      content: '';
      display: block;
      width: 32px;
      height: 2px;
      background: var(--blue);
    }

    .hero h1 {
      font-family: var(--font-display);
      font-size: clamp(2.5rem, 5vw, 4.2rem);
      color: var(--charcoal);
      line-height: 1.1;
      margin-bottom: 1.5rem;
      font-weight: 400;
    }

    .hero p {
      font-size: clamp(1rem, 1.2vw, 1.15rem);
      color: var(--gray);
      max-width: 420px;
      line-height: 1.7;
      margin-bottom: 2.5rem;
    }

    .hero-actions {
      display: flex;
      gap: 1rem;
      align-items: center;
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--blue-deep);
      color: var(--white);
      padding: 1rem 2rem;
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      border-radius: 2px;
      transition: background 0.25s ease, transform 0.2s ease;
    }

    .btn-primary:hover {
      background: var(--blue-hover);
      transform: translateY(-1px);
    }

    .btn-secondary {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      color: var(--charcoal);
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      padding: 1rem 0;
      transition: color 0.2s;
    }

    .btn-secondary:hover { color: var(--blue-deep); }

    .btn-secondary svg {
      transition: transform 0.2s;
    }

    .btn-secondary:hover svg {
      transform: translateX(3px);
    }

    .hero-image {
      position: relative;
      overflow: hidden;
    }

    .hero-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .hero-image::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 30%;
      background: linear-gradient(to top, rgba(19,24,32,0.15), transparent);
    }

    /* --- STATS BAR --- */
    .stats {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      background: var(--charcoal);
    }

    .stat {
      padding: 2.5rem 2rem;
      text-align: center;
      position: relative;
    }

    .stat:not(:last-child)::after {
      content: '';
      position: absolute;
      right: 0;
      top: 25%;
      height: 50%;
      width: 1px;
      background: rgba(255,255,255,0.1);
    }

    .stat-number {
      font-family: var(--font-display);
      font-size: clamp(1.8rem, 3vw, 2.5rem);
      color: var(--white);
      margin-bottom: 0.25rem;
    }

    .stat-label {
      font-size: 0.75rem;
      color: var(--silver);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-weight: 500;
    }

    /* --- SERVICES --- */
    .services {
      padding: clamp(4rem, 10vw, 8rem) clamp(2rem, 6vw, 6rem);
    }

    .section-label {
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--blue-deep);
      margin-bottom: 1rem;
    }

    .section-heading {
      font-family: var(--font-display);
      font-size: clamp(2rem, 4vw, 3.2rem);
      color: var(--charcoal);
      line-height: 1.15;
      max-width: 560px;
      margin-bottom: 1.25rem;
      font-weight: 400;
    }

    .section-sub {
      color: var(--gray);
      font-size: 1.05rem;
      max-width: 480px;
      margin-bottom: 4rem;
      line-height: 1.7;
    }

    .services-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--mist);
      border: 1px solid var(--mist);
    }

    .service-card {
      background: var(--white);
      padding: clamp(2rem, 4vw, 3.5rem);
      position: relative;
      transition: background 0.3s ease;
    }

    .service-card:hover {
      background: var(--cloud);
    }

    .service-icon {
      width: 48px;
      height: 48px;
      margin-bottom: 1.75rem;
      color: var(--blue);
    }

    .service-card h3 {
      font-family: var(--font-display);
      font-size: 1.35rem;
      color: var(--charcoal);
      margin-bottom: 1rem;
      font-weight: 400;
    }

    .service-card p {
      color: var(--gray);
      font-size: 0.925rem;
      line-height: 1.7;
    }

    .service-number {
      position: absolute;
      top: clamp(1.5rem, 3vw, 2.5rem);
      right: clamp(1.5rem, 3vw, 2.5rem);
      font-family: var(--font-display);
      font-size: 3rem;
      color: var(--mist);
      line-height: 1;
      user-select: none;
    }

    /* --- WHY CHOOSE --- */
    .why {
      background: var(--charcoal);
      padding: clamp(4rem, 10vw, 7rem) clamp(2rem, 6vw, 6rem);
      display: grid;
      grid-template-columns: 1fr 1.2fr;
      gap: clamp(3rem, 6vw, 6rem);
      align-items: center;
    }

    .why .section-label { color: var(--blue); }

    .why .section-heading {
      color: var(--white);
      margin-bottom: 1.5rem;
    }

    .why-text {
      color: var(--silver);
      font-size: 1rem;
      line-height: 1.8;
      max-width: 400px;
    }

    .trust-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }

    .trust-card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.06);
      padding: 2rem 1.75rem;
      border-radius: 2px;
      transition: background 0.3s;
    }

    .trust-card:hover {
      background: rgba(255,255,255,0.07);
    }

    .trust-icon {
      width: 32px;
      height: 32px;
      color: var(--blue);
      margin-bottom: 1rem;
    }

    .trust-card h4 {
      color: var(--white);
      font-size: 0.95rem;
      font-weight: 500;
      line-height: 1.4;
    }

    /* --- ABOUT --- */
    .about {
      display: grid;
      grid-template-columns: 1.1fr 1fr;
      min-height: 70vh;
    }

    .about-image {
      background: url('https://ejplumbing.co.uk/wp-content/uploads/2024/12/Website-LBF-Your-Story.png') center/cover;
      min-height: 400px;
    }

    .about-content {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: clamp(3rem, 6vw, 6rem);
    }

    .about-content .section-heading {
      margin-bottom: 1.5rem;
    }

    .about-content p {
      color: var(--gray);
      font-size: 1rem;
      line-height: 1.8;
      margin-bottom: 1.25rem;
      max-width: 460px;
    }

    .about-sig {
      margin-top: 1.5rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--mist);
    }

    .about-sig strong {
      display: block;
      color: var(--charcoal);
      font-size: 1rem;
    }

    .about-sig span {
      color: var(--gray);
      font-size: 0.85rem;
    }

    /* --- CONTACT CTA --- */
    .contact {
      background: var(--cloud);
      padding: clamp(4rem, 10vw, 7rem) clamp(2rem, 6vw, 6rem);
      text-align: center;
    }

    .contact .section-heading {
      max-width: 100%;
      margin-left: auto;
      margin-right: auto;
      margin-bottom: 1rem;
    }

    .contact-sub {
      color: var(--gray);
      font-size: 1.05rem;
      margin-bottom: 3rem;
      max-width: 500px;
      margin-left: auto;
      margin-right: auto;
      line-height: 1.7;
    }

    .contact-phone {
      font-family: var(--font-display);
      font-size: clamp(2rem, 4.5vw, 3.5rem);
      color: var(--charcoal);
      text-decoration: none;
      display: block;
      margin-bottom: 0.5rem;
      transition: color 0.2s;
    }

    .contact-phone:hover { color: var(--blue-deep); }

    .contact-email {
      color: var(--gray);
      font-size: 1.1rem;
      margin-bottom: 2.5rem;
    }

    .contact-email a {
      color: var(--gray);
      text-decoration: none;
      transition: color 0.2s;
    }

    .contact-email a:hover { color: var(--blue-deep); }

    .contact-areas {
      color: var(--silver);
      font-size: 0.85rem;
      letter-spacing: 0.04em;
      margin-top: 2rem;
    }

    /* --- FOOTER --- */
    .footer {
      padding: 2rem clamp(2rem, 6vw, 6rem);
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-top: 1px solid var(--mist);
      font-size: 0.8rem;
      color: var(--silver);
    }

    .footer a {
      color: var(--silver);
      text-decoration: none;
      transition: color 0.2s;
    }

    .footer a:hover { color: var(--blue-deep); }

    /* --- ANIMATIONS --- */
    .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
                  transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .reveal-delay-1 { transition-delay: 0.1s; }
    .reveal-delay-2 { transition-delay: 0.2s; }
    .reveal-delay-3 { transition-delay: 0.3s; }
    .reveal-delay-4 { transition-delay: 0.4s; }

    /* --- RESPONSIVE --- */
    @media (max-width: 1024px) {
      .hero { grid-template-columns: 1fr; min-height: auto; }
      .hero-image { height: 50vh; order: -1; }
      .hero-content { padding: 3rem 2rem 4rem; }
      .why { grid-template-columns: 1fr; }
      .about { grid-template-columns: 1fr; }
      .about-image { height: 50vh; }
      .services-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 768px) {
      .nav-links { display: none; }
      .nav-links.open {
        display: flex;
        flex-direction: column;
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: var(--white);
        padding: 1.5rem 2rem;
        border-bottom: 1px solid var(--mist);
        gap: 1rem;
      }
      .nav-toggle { display: block; }
      .stats { grid-template-columns: repeat(2, 1fr); }
      .stat:nth-child(2)::after { display: none; }
      .services-grid { grid-template-columns: 1fr; }
      .trust-grid { grid-template-columns: 1fr; }
      .footer { flex-direction: column; gap: 0.75rem; text-align: center; }
    }

    @media (max-width: 480px) {
      .stats { grid-template-columns: 1fr; }
      .stat::after { display: none !important; }
      .stat {
        padding: 1.5rem;
        border-bottom: 1px solid rgba(255,255,255,0.05);
      }
      .hero-actions { flex-direction: column; align-items: flex-start; }
    }

    @media (prefers-reduced-motion: reduce) {
      .reveal { opacity: 1; transform: none; transition: none; }
      html { scroll-behavior: auto; }
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav class="nav" id="nav">
    <img
      src="https://ejplumbing.co.uk/wp-content/uploads/2025/04/cropped-Blue-Modern-House-Plumbing-Service-Logo-2-2.png"
      alt="EJ Plumbing"
      class="nav-logo"
    />
    <ul class="nav-links" id="navLinks">
      <li><a href="#services">Services</a></li>
      <li><a href="#about">About</a></li>
      <li><a href="#contact" class="nav-cta">Call Now</a></li>
    </ul>
    <button class="nav-toggle" id="navToggle" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-content">
      <span class="hero-est reveal">24/7 Emergency Service</span>
      <h1 class="reveal reveal-delay-1">Plumbing you can rely on, day or&nbsp;night</h1>
      <p class="reveal reveal-delay-2">
        Emergency plumbing services across Bristol, 24 hours a day, 365 days a year.
        Our plumbers can be at your property within an hour to professionally diagnose and resolve the problem.
      </p>
      <div class="hero-actions reveal reveal-delay-3">
        <a href="tel:+447341741512" class="btn-primary">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          Call Now
        </a>
        <a href="#services" class="btn-secondary">
          Our services
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
    <div class="hero-image">
      <img
        src="https://ejplumbing.co.uk/wp-content/uploads/2024/12/Website-LBF-Your-Story.png"
        alt="EJ Plumbing - emergency plumbing services in Bristol"
        loading="eager"
      />
    </div>
  </section>

  <!-- STATS -->
  <div class="stats">
    <div class="stat reveal">
      <div class="stat-number">24/7</div>
      <div class="stat-label">Always Available</div>
    </div>
    <div class="stat reveal reveal-delay-1">
      <div class="stat-number">&lt;1hr</div>
      <div class="stat-label">Response Time</div>
    </div>
    <div class="stat reveal reveal-delay-2">
      <div class="stat-number">365</div>
      <div class="stat-label">Days a Year</div>
    </div>
    <div class="stat reveal reveal-delay-3">
      <div class="stat-number">100%</div>
      <div class="stat-label">Quality Guaranteed</div>
    </div>
  </div>

  <!-- SERVICES -->
  <section class="services" id="services">
    <div class="section-label reveal">What We Do</div>
    <h2 class="section-heading reveal reveal-delay-1">Round-the-clock plumbing solutions for every&nbsp;emergency</h2>
    <p class="section-sub reveal reveal-delay-2">No matter the time, no matter the problem. We handle everything from blocked drains to burst pipes across Bristol and the surrounding areas.</p>

    <div class="services-grid">
      <div class="service-card reveal">
        <span class="service-number">01</span>
        <svg class="service-icon" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 48 48">
          <circle cx="24" cy="24" r="14"/>
          <path d="M24 14v10l6 6" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M18 10l-4-4M30 10l4-4" stroke-linecap="round"/>
        </svg>
        <h3>Blocked Drain, Pipe &amp; Toilet</h3>
        <p>Fast, effective unblocking of drains, pipes and toilets. We use professional-grade equipment to clear even the most stubborn blockages quickly.</p>
      </div>

      <div class="service-card reveal reveal-delay-1">
        <span class="service-number">02</span>
        <svg class="service-icon" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 48 48">
          <rect x="12" y="8" width="24" height="32" rx="2" stroke-linejoin="round"/>
          <path d="M18 16h12M18 22h12M18 28h6" stroke-linecap="round"/>
          <circle cx="24" cy="36" r="2"/>
          <path d="M20 8V4h8v4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <h3>Boiler Repair</h3>
        <p>Expert boiler diagnostics and repair services. We work with all major brands and models to get your heating back up and running fast.</p>
      </div>

      <div class="service-card reveal reveal-delay-2">
        <span class="service-number">03</span>
        <svg class="service-icon" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 48 48">
          <path d="M24 6c-2 8-10 12-10 22a10 10 0 0020 0c0-10-8-14-10-22z" stroke-linejoin="round"/>
          <path d="M20 32a4 4 0 004 4" stroke-linecap="round"/>
        </svg>
        <h3>Burst Pipe</h3>
        <p>Emergency burst pipe repair when you need it most. We respond rapidly to minimise water damage and restore your plumbing to full working order.</p>
      </div>

      <div class="service-card reveal reveal-delay-1">
        <span class="service-number">04</span>
        <svg class="service-icon" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 48 48">
          <path d="M8 38h32" stroke-linecap="round"/>
          <path d="M12 38V20l12-10 12 10v18" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M14 30c4-2 6 2 10 0s6 2 10 0" stroke-linecap="round"/>
          <path d="M14 34c4-2 6 2 10 0s6 2 10 0" stroke-linecap="round"/>
        </svg>
        <h3>Flooded Room or Basement</h3>
        <p>Rapid response for flooded rooms and basements. We pump out standing water, identify the source and carry out repairs to prevent reoccurrence.</p>
      </div>

      <div class="service-card reveal reveal-delay-2">
        <span class="service-number">05</span>
        <svg class="service-icon" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 48 48">
          <circle cx="24" cy="24" r="16"/>
          <path d="M24 16v16M16 24h16" stroke-linecap="round"/>
          <circle cx="24" cy="24" r="6"/>
        </svg>
        <h3>Leak Detection</h3>
        <p>Advanced leak detection to pinpoint hidden leaks without unnecessary damage. We locate the problem quickly and fix it with precision.</p>
      </div>

      <div class="service-card reveal reveal-delay-3">
        <span class="service-number">06</span>
        <svg class="service-icon" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 48 48">
          <path d="M24 8v6" stroke-linecap="round"/>
