    { q: "What areas do you cover?", a: "Birmingham and the wider West Midlands including Solihull, West Bromwich, Wolverhampton, Dudley, and Sutton Coldfield." },
  ],
  hours: "Mon-Fri 7am-8pm, Sat 8am-5pm, 24/7 Emergency",
