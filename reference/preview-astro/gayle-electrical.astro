// Icon map -- inline SVGs for zero external dependencies
const icons: Record<string, string> = {
  bolt: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
  shield: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  wrench: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
  doc: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`,
  sun: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>`,
  ev: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="16" height="12" rx="2"/><line x1="20" y1="10" x2="22" y2="10"/><line x1="20" y1="14" x2="22" y2="14"/><line x1="10" y1="9" x2="8" y2="12"/><line x1="8" y1="12" x2="12" y2="12"/><line x1="12" y1="12" x2="10" y2="15"/></svg>`,
  phone: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`,
  check: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`,
  clock: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  star: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
  starFill: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="#e8a020" stroke="#e8a020" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
  plus: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>`,
  minus: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/></svg>`,
};

// Service icon map
const serviceIconMap: Record<string, string> = {
  bolt: icons.bolt,
  shield: icons.shield,
  wrench: icons.wrench,
  doc: icons.doc,
  sun: icons.sun,
  ev: icons.ev,
};

// Trust signal icon map
const trustIconMap: Record<string, string> = {
  "NICEIC": icons.bolt,
  "Insured": icons.shield,
  "Experience": icons.clock,
  "Google": icons.star,
};

function getTrustIcon(signal: string): string {
  for (const [key, icon] of Object.entries(trustIconMap)) {
    if (signal.includes(key)) return icon;
  }
  return icons.check;
}

function renderStars(count: number): string {
  return Array.from({ length: count }, () => icons.starFill).join("");
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{config.business_name} | Trusted Electricians in {config.town}</title>
  <meta name="description" content={`${config.hero_subtitle} Call ${config.phone_display} for a free quote. Serving ${config.areas_served.join(", ")}.`} />

  {/* OG Meta Tags */}
  <meta property="og:title" content={`${config.business_name} | Trusted Electricians in ${config.town}`} />
  <meta property="og:description" content={config.hero_subtitle} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="en_GB" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  {/* LocalBusiness JSON-LD */}
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": config.schema_type,
    "name": config.business_name,
    "telephone": config.phone,
    "email": config.email,
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Birmingham",
      "addressRegion": "West Midlands",
      "addressCountry": "GB",
    },
    "areaServed": config.areas_served.map(a => ({ "@type": "Place", "name": a })),
    "openingHours": config.hours,
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5",
      "reviewCount": "3",
    },
  })} />

  {/* FAQPage JSON-LD */}
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": config.faqs.map(faq => ({
      "@type": "Question",
      "name": faq.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.a,
      }
    })),
  })} />
</head>

<body>

  {/* ============================================================ */}
  {/* STICKY HEADER                                                 */}
  {/* ============================================================ */}
  <header class="site-header" id="site-header">
    <nav class="header-inner">
      <div class="header-left">
        <a href="#" class="logo-text">
          <span class="logo-gayle">GAYLE</span>
          <span class="logo-electrical">ELECTRICAL</span>
        </a>
      </div>
      <div class="header-right">
        <a href={`tel:${config.phone}`} class="header-phone-link">
          <span class="header-phone-icon" set:html={icons.phone} />
          <span class="header-phone-number">{config.phone_display}</span>
        </a>
        <button class="nav-toggle" id="nav-toggle" aria-label="Open menu" aria-expanded="false">
          <span class="bar"></span>
          <span class="bar"></span>
          <span class="bar"></span>
        </button>
      </div>
      <div class="nav-dropdown" id="nav-dropdown">
        <a href="#services" class="nav-dropdown-link">Services</a>
        <a href="#process" class="nav-dropdown-link">How It Works</a>
        <a href="#reviews" class="nav-dropdown-link">Reviews</a>
        <a href="#faq" class="nav-dropdown-link">FAQ</a>
        <a href={`tel:${config.phone}`} class="nav-dropdown-cta">
          <span set:html={icons.phone} /> Call {config.phone_display}
        </a>
      </div>
    </nav>
  </header>

  <main>

    {/* ============================================================ */}
    {/* HERO                                                         */}
    {/* ============================================================ */}
    <section class="hero">
      <div class="hero-glow"></div>
      <div class="hero-grid-lines"></div>
      <div class="container">
        <div class="hero-content">
          <span class="hero-badge">
            <span class="hero-badge-icon" set:html={icons.shield} />
            {config.certification}
          </span>
          <h1 class="hero-title">{config.hero_title}</h1>
          <p class="hero-subtitle">{config.hero_subtitle}</p>
          <div class="hero-cta-group">
            <a href={`tel:${config.phone}`} class="btn btn-primary btn-lg">
              <span set:html={icons.phone} />
              Call {config.phone_display}
            </a>
            <p class="hero-microcopy">No call-out fee for quotes. Available 7 days a week.</p>
          </div>
        </div>
      </div>
    </section>

    {/* ============================================================ */}
    {/* TRUST SIGNALS STRIP                                          */}
    {/* ============================================================ */}
    <section class="trust-strip" aria-label="Credentials">
      <div class="container">
        <div class="trust-strip-inner">
          {config.trust_signals.map((signal) => (
            <div class="trust-item">
              <span class="trust-item-icon" set:html={getTrustIcon(signal)} />
              <span class="trust-item-label">{signal}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ============================================================ */}
    {/* STATS                                                        */}
    {/* ============================================================ */}
    <section class="stats reveal" aria-label="Key statistics">
      <div class="container">
        <div class="stats-grid">
          {config.stats.map((stat, i) => (
            <div class="stat-item" style={`--delay: ${i * 0.1}s`}>
              <span class="stat-num">{stat.num}</span>
              <span class="stat-label">{stat.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ============================================================ */}
    {/* SERVICES                                                     */}
    {/* ============================================================ */}
    <section class="services reveal" id="services">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">What We Do</h2>
          <p class="section-subtitle">From emergency repairs to solar installations - traditional skills, modern technology.</p>
        </div>
        <div class="services-grid">
          {config.services.map((service, i) => (
            <div class="service-card" style={`--delay: ${i * 0.08}s`}>
              <div class="service-icon" set:html={serviceIconMap[service.icon]} />
              <h3 class="service-title">{service.title}</h3>
              <p class="service-desc">{service.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ============================================================ */}
    {/* FAMILY BUSINESS CALLOUT                                      */}
    {/* ============================================================ */}
    <section class="about reveal" id="about">
      <div class="container">
        <div class="about-card">
          <div class="about-accent"></div>
          <div class="about-content">
            <h2 class="about-title">Family-Run. NICEIC Approved. 35+ Years.</h2>
            <p class="about-text">We're a father-and-son team of electricians based in Birmingham. Between us, we've got over 35 years of hands-on experience in domestic, commercial, and industrial electrical work. We started with rewires and fuse boards - now we also install solar panels, battery storage, and EV chargers. Old school reliability meets new technology.</p>
            <div class="about-certs">
              <span class="about-cert">
                <span set:html={icons.bolt} />
                NICEIC Approved
              </span>
              <span class="about-cert">
                <span set:html={icons.shield} />
                Fully Insured
              </span>
              <span class="about-cert">
                <span set:html={icons.clock} />
                24/7 Emergency
              </span>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* ============================================================ */}
    {/* HOW IT WORKS -- TIMELINE                                     */}
    {/* ============================================================ */}
    <section class="process reveal" id="process">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">How It Works</h2>
          <p class="section-subtitle">From first call to job done - we keep it simple.</p>
        </div>
        <div class="timeline">
          {config.process.map((step, i) => (
            <div class="timeline-step" style={`--delay: ${i * 0.12}s`}>
              <div class="timeline-marker">
                <span class="timeline-number">{step.step}</span>
              </div>
              <div class="timeline-content">
                <h3 class="timeline-title">{step.title}</h3>
                <p class="timeline-desc">{step.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ============================================================ */}
    {/* TESTIMONIALS                                                 */}
    {/* ============================================================ */}
    <section class="reviews reveal" id="reviews">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">What Our Customers Say</h2>
          <p class="section-subtitle">Real reviews from real customers across the West Midlands.</p>
        </div>
        <div class="reviews-grid">
          {config.reviews.map((review, i) => (
            <div class="review-card" style={`--delay: ${i * 0.1}s`}>
              <div class="review-stars" set:html={renderStars(review.stars)} />
              <blockquote class="review-text">&ldquo;{review.text}&rdquo;</blockquote>
              <div class="review-author">
                <div class="review-avatar">{review.initials}</div>
                <div class="review-meta">
                  <span class="review-name">{review.name}</span>
                  <span class="review-location">{review.location}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ============================================================ */}
    {/* FAQ                                                          */}
    {/* ============================================================ */}
    <section class="faq reveal" id="faq">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">Frequently Asked Questions</h2>
        </div>
        <div class="faq-list">
          {config.faqs.map((faq, i) => (
            <details class="faq-item" style={`--delay: ${i * 0.08}s`}>
              <summary class="faq-question">
                <span>{faq.q}</span>
                <span class="faq-icon faq-icon-plus" set:html={icons.plus} />
                <span class="faq-icon faq-icon-minus" set:html={icons.minus} />
              </summary>
              <div class="faq-answer">
                <p>{faq.a}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    {/* ============================================================ */}
    {/* FINAL CTA                                                    */}
    {/* ============================================================ */}
    <section class="final-cta reveal">
      <div class="container">
        <div class="final-cta-card">
          <div class="final-cta-glow"></div>
          <h2 class="final-cta-title">Ready to Get Started?</h2>
          <p class="final-cta-subtitle">Call now for a free, no-obligation quote. We aim to respond within 30 minutes.</p>
          <a href={`tel:${config.phone}`} class="btn btn-primary btn-lg">
            <span set:html={icons.phone} />
            Call {config.phone_display}
          </a>
          <p class="final-cta-email">
            Or email <a href={`mailto:${config.email}`}>{config.email}</a>
          </p>
          <p class="final-cta-areas">Serving {config.areas_served.join(" / ")}</p>
        </div>
      </div>
    </section>

  </main>

  {/* ============================================================ */}
  {/* FOOTER                                                       */}
  {/* ============================================================ */}
  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-col">
          <h4 class="footer-heading">{config.business_name}</h4>
          <p class="footer-text">Family-run, NICEIC-approved electricians in Birmingham. Domestic, commercial, and industrial - plus solar PV, battery storage, and EV chargers.</p>
        </div>
        <div class="footer-col">
          <h4 class="footer-heading">Contact</h4>
          <ul class="footer-list">
            <li><a href={`tel:${config.phone}`}>{config.phone_display}</a></li>
            <li><a href={`mailto:${config.email}`}>{config.email}</a></li>
            <li>{config.address}</li>
          </ul>
        </div>
        <div class="footer-col">
          <h4 class="footer-heading">Hours</h4>
          <p class="footer-text">{config.hours}</p>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; {new Date().getFullYear()} {config.business_name}. All rights reserved.</p>
        <p class="footer-credit">Website by <a href="https://highcroftdigital.com" target="_blank" rel="noopener">Highcroft Digital</a></p>
      </div>
    </div>
  </footer>

  {/* ============================================================ */}
  {/* FLOATING PHONE BUTTON -- mobile only                         */}
  {/* ============================================================ */}
  <a href={`tel:${config.phone}`} class="floating-phone" aria-label={`Call ${config.business_name}`}>
    <span set:html={icons.phone} />
  </a>

</body>
</html>

<style>
  /* ============================================================
     RESET & BASE
     ============================================================ */
  *, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
    scroll-padding-top: 72px;
  }

  body {
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 1rem;
    line-height: 1.6;
    color: #c8cdd5;
    background: #111318;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  img {
    max-width: 100%;
    height: auto;
    display: block;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  ul {
    list-style: none;
  }

  /* ============================================================
     LAYOUT
     ============================================================ */
  .container {
    width: 100%;
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 20px;
  }

  @media (min-width: 768px) {
    .container {
      padding: 0 32px;
    }
  }

  /* ============================================================
     STICKY HEADER
     ============================================================ */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(17, 19, 24, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 20px;
    height: 64px;
    position: relative;
  }

  @media (min-width: 768px) {
    .header-inner {
      padding: 0 32px;
      height: 72px;
    }
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  /* Text logo */
  .logo-text {
    display: flex;
    align-items: baseline;
    gap: 8px;
    text-decoration: none;
    line-height: 1;
  }

  .logo-gayle {
    font-size: 1.25rem;
    font-weight: 800;
    color: #d94535;
    letter-spacing: 0.04em;
  }

  .logo-electrical {
    font-size: 1.25rem;
    font-weight: 800;
    color: #e8ecf2;
    letter-spacing: 0.04em;
  }

  @media (min-width: 768px) {
    .logo-gayle,
    .logo-electrical {
      font-size: 1.35rem;
    }
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .header-phone-link {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 700;
    font-size: 0.95rem;
    color: #d94535;
    transition: color 0.2s;
    padding: 8px 0;
  }

  .header-phone-link:hover {
    color: #ef5a4a;
  }

  .header-phone-icon {
    display: flex;
    align-items: center;
  }

  .header-phone-icon svg {
    width: 18px;
    height: 18px;
  }

  .header-phone-number {
    display: none;
  }

  @media (min-width: 480px) {
    .header-phone-number {
      display: inline;
    }
  }

  /* Nav toggle (hamburger) */
  .nav-toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    width: 44px;
    height: 44px;
  }

  @media (min-width: 768px) {
    .nav-toggle {
      display: none;
    }
  }

  .bar {
    display: block;
    width: 22px;
    height: 2px;
    background: #e8ecf2;
    border-radius: 2px;
    transition: transform 0.25s, opacity 0.25s;
  }

  .nav-toggle.is-active .bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .nav-toggle.is-active .bar:nth-child(2) {
    opacity: 0;
  }

  .nav-toggle.is-active .bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Nav dropdown (mobile) */
  .nav-dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: #1a1d24;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
    z-index: 200;
    flex-direction: column;
    padding: 8px 0;
  }

  .nav-dropdown.is-open {
    display: flex;
  }

  @media (min-width: 768px) {
    .nav-dropdown {
      display: none !important;
    }
  }

  .nav-dropdown-link {
    padding: 14px 24px;
    font-weight: 500;
    font-size: 1rem;
    color: #c8cdd5;
    transition: background 0.15s;
  }

  .nav-dropdown-link:hover {
    background: rgba(255, 255, 255, 0.04);
  }

  .nav-dropdown-cta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin: 8px 16px;
    padding: 14px 20px;
    background: #d94535;
    color: #fff;
    border-radius: 10px;
    font-weight: 700;
    font-size: 1rem;
    justify-content: center;
    transition: background 0.2s;
  }

  .nav-dropdown-cta:hover {
    background: #c23a2c;
  }

  .nav-dropdown-cta svg {
    width: 18px;
    height: 18px;
  }

  /* ============================================================
     HERO
     ============================================================ */
  .hero {
    background: #111318;
    padding: 80px 0 64px;
    position: relative;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    top: -20%;
    right: -15%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(217, 69, 53, 0.15) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-grid-lines {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }

  @media (min-width: 768px) {
    .hero {
      padding: 100px 0 80px;
    }
  }

  .hero-content {
    max-width: 660px;
    text-align: center;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(217, 69, 53, 0.1);
    border: 1px solid rgba(217, 69, 53, 0.25);
    color: #d94535;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 6px 14px;
    border-radius: 100px;
    margin-bottom: 24px;
    letter-spacing: 0.02em;
  }

  .hero-badge-icon {
    display: flex;
    align-items: center;
  }

  .hero-badge-icon svg {
    width: 14px;
    height: 14px;
    stroke: #d94535;
  }

  .hero-title {
    font-size: clamp(2.2rem, 7vw, 3.2rem);
    font-weight: 800;
    color: #f0f2f5;
    line-height: 1.12;
    margin-bottom: 18px;
    letter-spacing: -0.025em;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2.5vw, 1.15rem);
    color: #8a919e;
    line-height: 1.65;
    margin-bottom: 32px;
    max-width: 540px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-cta-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .hero-microcopy {
    font-size: 0.85rem;
    color: #5e6570;
  }

  /* ============================================================
     BUTTONS
     ============================================================ */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-family: inherit;
    font-weight: 700;
    font-size: 1rem;
    border: none;
    border-radius: 12px;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    text-decoration: none;
    line-height: 1;
  }

  .btn:active {
    transform: scale(0.97);
  }

  .btn svg {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .btn-primary {
    background: #d94535;
    color: #fff;
    box-shadow: 0 2px 12px rgba(217, 69, 53, 0.3);
  }

  .btn-primary:hover {
    background: #ef5a4a;
    box-shadow: 0 4px 20px rgba(217, 69, 53, 0.4);
  }

  .btn-lg {
    padding: 16px 32px;
    font-size: 1.05rem;
    min-height: 56px;
  }

  /* ============================================================
     TRUST STRIP
     ============================================================ */
  .trust-strip {
    background: #161920;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    padding: 16px 0;
  }

  .trust-strip-inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px 24px;
  }

  @media (min-width: 768px) {
    .trust-strip-inner {
      gap: 12px 40px;
    }
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 0;
  }

  .trust-item-icon {
    display: flex;
    align-items: center;
    color: #d94535;
  }

  .trust-item-icon svg {
    width: 18px;
    height: 18px;
  }

  .trust-item-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: #c8cdd5;
    white-space: nowrap;
  }

  /* ============================================================
     STATS
     ============================================================ */
  .stats {
    padding: 48px 0;
    background: #111318;
  }

  @media (min-width: 768px) {
    .stats {
      padding: 64px 0;
    }
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  @media (min-width: 640px) {
    .stats-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 32px;
    }
  }

  .stat-item {
    text-align: center;
    padding: 20px 8px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.02);
  }

  .stat-num {
    display: block;
    font-size: clamp(1.6rem, 4.5vw, 2.2rem);
    font-weight: 800;
    color: #d94535;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .stat-label {
    display: block;
    font-size: 0.82rem;
    font-weight: 500;
    color: #7a8190;
    margin-top: 6px;
  }

  /* ============================================================
     SECTION HEADERS (shared)
     ============================================================ */
  .section-header {
    text-align: center;
    margin-bottom: 40px;
  }

  @media (min-width: 768px) {
    .section-header {
      margin-bottom: 48px;
    }
  }

  .section-title {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 800;
    color: #f0f2f5;
    letter-spacing: -0.02em;
    margin-bottom: 10px;
  }

  .section-subtitle {
    font-size: 1rem;
    color: #7a8190;
    max-width: 540px;
    margin: 0 auto;
  }

  /* ============================================================
     SERVICES
     ============================================================ */
  .services {
    padding: 64px 0;
    background: #161920;
  }

  @media (min-width: 768px) {
    .services {
      padding: 80px 0;
    }
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  @media (min-width: 600px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
  }

  @media (min-width: 900px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .service-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 14px;
    padding: 28px 24px;
    transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s;
  }

  .service-card:hover {
    border-color: rgba(217, 69, 53, 0.4);
    box-shadow: 0 4px 24px rgba(217, 69, 53, 0.08);
    transform: translateY(-2px);
  }

  .service-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: rgba(217, 69, 53, 0.1);
    border-radius: 12px;
    color: #d94535;
    margin-bottom: 16px;
  }

  .service-icon svg {
    width: 22px;
    height: 22px;
  }

  .service-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: #e8ecf2;
    margin-bottom: 6px;
  }

  .service-desc {
    font-size: 0.92rem;
    color: #7a8190;
    line-height: 1.6;
  }

  /* ============================================================
     ABOUT / FAMILY BUSINESS
     ============================================================ */
  .about {
    padding: 64px 0;
    background: #111318;
  }

  @media (min-width: 768px) {
    .about {
      padding: 80px 0;
    }
  }

  .about-card {
    position: relative;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 18px;
    padding: 40px 28px;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .about-card {
      padding: 56px 48px;
    }
  }

  .about-accent {
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background: linear-gradient(180deg, #d94535, rgba(217, 69, 53, 0.2));
    border-radius: 4px 0 0 4px;
  }

  .about-content {
    position: relative;
    z-index: 1;
  }

  .about-title {
    font-size: clamp(1.3rem, 3.5vw, 1.75rem);
    font-weight: 800;
    color: #f0f2f5;
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }

  .about-text {
    font-size: 1rem;
    color: #8a919e;
    line-height: 1.7;
    max-width: 680px;
    margin-bottom: 24px;
  }

  .about-certs {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }

  .about-cert {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.88rem;
    font-weight: 600;
    color: #d94535;
    background: rgba(217, 69, 53, 0.08);
    padding: 8px 16px;
    border-radius: 8px;
    border: 1px solid rgba(217, 69, 53, 0.15);
  }

  .about-cert svg {
    width: 16px;
    height: 16px;
  }

  /* ============================================================
     TIMELINE / PROCESS
     ============================================================ */
  .process {
    padding: 64px 0;
    background: #161920;
  }

  @media (min-width: 768px) {
    .process {
      padding: 80px 0;
    }
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
    position: relative;
    padding-left: 28px;
  }

  /* Vertical line (mobile) */
  .timeline::before {
    content: "";
    position: absolute;
    left: 15px;
    top: 24px;
    bottom: 24px;
    width: 2px;
    background: rgba(255, 255, 255, 0.08);
  }

  .timeline-step {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    padding: 20px 0;
    position: relative;
  }

  .timeline-marker {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #d94535;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 2;
    margin-left: -28px;
    box-shadow: 0 0 0 4px #161920, 0 0 12px rgba(217, 69, 53, 0.3);
  }

  .timeline-number {
    font-size: 0.85rem;
    font-weight: 800;
    color: #fff;
  }

  .timeline-content {
    padding-top: 4px;
  }

  .timeline-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: #e8ecf2;
    margin-bottom: 2px;
  }

  .timeline-desc {
    font-size: 0.92rem;
    color: #7a8190;
  }

  /* Desktop: horizontal timeline */
  @media (min-width: 768px) {
    .timeline {
      flex-direction: row;
      padding-left: 0;
      justify-content: space-between;
    }

    .timeline::before {
      left: calc(18px + 12px);
      right: calc(18px + 12px);
      top: 18px;
      bottom: auto;
      height: 2px;
      width: auto;
    }

    .timeline-step {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 16px;
      flex: 1;
      padding: 0 12px;
    }

    .timeline-marker {
      margin-left: 0;
      box-shadow: 0 0 0 4px #161920, 0 0 12px rgba(217, 69, 53, 0.3);
    }

    .timeline-content {
      padding-top: 0;
    }
  }

  /* ============================================================
     REVIEWS
     ============================================================ */
  .reviews {
    padding: 64px 0;
    background: #111318;
  }

  @media (min-width: 768px) {
    .reviews {
      padding: 80px 0;
    }
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  @media (min-width: 640px) {
    .reviews-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 900px) {
    .reviews-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .review-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 14px;
    padding: 28px 24px;
  }

  .review-stars {
    display: flex;
    gap: 2px;
    margin-bottom: 16px;
  }

  .review-text {
    font-size: 0.95rem;
    color: #b0b7c3;
    line-height: 1.65;
    margin-bottom: 20px;
    font-style: normal;
  }

  .review-author {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .review-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #d94535;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight: 700;
    flex-shrink: 0;
    letter-spacing: 0.02em;
  }

  .review-meta {
    display: flex;
    flex-direction: column;
  }

  .review-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: #e0e4ea;
  }

  .review-location {
    font-size: 0.8rem;
    color: #5e6570;
  }

  /* ============================================================
     FAQ
     ============================================================ */
  .faq {
    padding: 64px 0;
    background: #161920;
  }

  @media (min-width: 768px) {
    .faq {
      padding: 80px 0;
    }
  }

  .faq-list {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .faq-item {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .faq-item[open] {
    border-color: rgba(217, 69, 53, 0.4);
  }

  .faq-question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 20px;
    font-weight: 600;
    font-size: 1rem;
    color: #e0e4ea;
    cursor: pointer;
    list-style: none;
    user-select: none;
    min-height: 44px;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-question::marker {
    content: "";
  }

  .faq-icon {
    flex-shrink: 0;
    color: #5e6570;
    display: flex;
    align-items: center;
  }

  .faq-icon-minus {
    display: none;
  }

  .faq-item[open] .faq-icon-plus {
    display: none;
  }

  .faq-item[open] .faq-icon-minus {
    display: flex;
    color: #d94535;
  }

  .faq-answer {
    padding: 0 20px 20px;
    font-size: 0.95rem;
    color: #8a919e;
    line-height: 1.65;
  }

  /* ============================================================
     FINAL CTA
     ============================================================ */
  .final-cta {
    padding: 64px 0;
    background: #111318;
  }

  @media (min-width: 768px) {
    .final-cta {
      padding: 80px 0;
    }
  }

  .final-cta-card {
    background: linear-gradient(135deg, #1a1d24 0%, #1f1215 100%);
    border: 1px solid rgba(217, 69, 53, 0.2);
    border-radius: 20px;
    padding: 48px 24px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .final-cta-card {
      padding: 64px 48px;
    }
  }

  .final-cta-glow {
    position: absolute;
    bottom: -30%;
    left: 50%;
    transform: translateX(-50%);
    width: 500px;
    height: 400px;
    background: radial-gradient(circle, rgba(217, 69, 53, 0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .final-cta-title {
    font-size: clamp(1.5rem, 5vw, 2.2rem);
    font-weight: 800;
    color: #f0f2f5;
    margin-bottom: 12px;
    letter-spacing: -0.02em;
    position: relative;
    z-index: 1;
  }

  .final-cta-subtitle {
    font-size: 1rem;
    color: #8a919e;
    margin-bottom: 28px;
    max-width: 440px;
    margin-left: auto;
    margin-right: auto;
    position: relative;
    z-index: 1;
  }

  .final-cta .btn {
    position: relative;
    z-index: 1;
  }

  .final-cta-email {
    margin-top: 16px;
    font-size: 0.9rem;
    color: #7a8190;
    position: relative;
    z-index: 1;
  }

  .final-cta-email a {
    color: #d94535;
    font-weight: 600;
    transition: color 0.15s;
  }

  .final-cta-email a:hover {
    color: #ef5a4a;
  }

  .final-cta-areas {
    margin-top: 16px;
    font-size: 0.82rem;
    color: #5e6570;
    position: relative;
    z-index: 1;
  }

  /* ============================================================
     FOOTER
     ============================================================ */
  .site-footer {
    background: #0c0e12;
    color: #7a8190;
    padding: 48px 0 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
  }

  @media (min-width: 768px) {
    .site-footer {
      padding: 64px 0 32px;
    }
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    margin-bottom: 40px;
  }

  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .footer-heading {
    font-size: 0.95rem;
    font-weight: 700;
    color: #e0e4ea;
    margin-bottom: 12px;
  }

  .footer-text {
    font-size: 0.9rem;
    line-height: 1.55;
  }

  .footer-list li {
    font-size: 0.9rem;
    margin-bottom: 6px;
  }

  .footer-list a {
    transition: color 0.15s;
  }

  .footer-list a:hover {
    color: #d94535;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding-top: 20px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    text-align: center;
    font-size: 0.82rem;
  }

  @media (min-width: 640px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .footer-credit a {
    color: #d94535;
    font-weight: 600;
    transition: color 0.15s;
  }

  .footer-credit a:hover {
    color: #ef5a4a;
  }

  /* ============================================================
     FLOATING PHONE BUTTON (mobile only)
     ============================================================ */
  .floating-phone {
    display: flex;
    align-items: center;
    justify-content: center;
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #d94535;
    color: #fff;
    box-shadow: 0 4px 20px rgba(217, 69, 53, 0.4), 0 0 0 4px rgba(217, 69, 53, 0.15);
    z-index: 90;
    transition: background 0.2s, transform 0.15s;
  }

  .floating-phone:hover {
    background: #ef5a4a;
  }

  .floating-phone:active {
    transform: scale(0.92);
  }

  .floating-phone svg {
    width: 24px;
    height: 24px;
  }

  @media (min-width: 768px) {
    .floating-phone {
      display: none;
    }
  }

  /* ============================================================
     SCROLL REVEAL ANIMATIONS
     ============================================================ */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Staggered children */
  .reveal.is-visible .stat-item,
  .reveal.is-visible .service-card,
  .reveal.is-visible .timeline-step,
  .reveal.is-visible .review-card,
  .reveal.is-visible .faq-item {
    animation: revealUp 0.5s ease forwards;
    animation-delay: var(--delay, 0s);
    opacity: 0;
  }

  @keyframes revealUp {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .reveal.is-visible .stat-item,
    .reveal.is-visible .service-card,
    .reveal.is-visible .timeline-step,
    .reveal.is-visible .review-card,
    .reveal.is-visible .faq-item {
      animation: none;
      opacity: 1;
    }

    .service-card:hover {
      transform: none;
    }
  }
</style>

<script>
  // ============================================================
  // NAV TOGGLE
  // ============================================================
  const navToggle = document.getElementById("nav-toggle");
  const navDropdown = document.getElementById("nav-dropdown");

  if (navToggle && navDropdown) {
    navToggle.addEventListener("click", () => {
      const isOpen = navDropdown.classList.toggle("is-open");
      navToggle.classList.toggle("is-active", isOpen);
      navToggle.setAttribute("aria-expanded", String(isOpen));
    });

    // Close dropdown when a link is clicked
    navDropdown.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        navDropdown.classList.remove("is-open");
        navToggle.classList.remove("is-active");
        navToggle.setAttribute("aria-expanded", "false");
      });
    });

    // Close dropdown on outside click
    document.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      if (!navToggle.contains(target) && !navDropdown.contains(target)) {
        navDropdown.classList.remove("is-open");
        navToggle.classList.remove("is-active");
        navToggle.setAttribute("aria-expanded", "false");
      }
    });
  }

  // ============================================================
  // SCROLL REVEAL -- IntersectionObserver
  // ============================================================
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!prefersReducedMotion) {
    const revealElements = document.querySelectorAll(".reveal");

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        });
      },
      {
        threshold: 0.12,
        rootMargin: "0px 0px -40px 0px",
      }
    );

    revealElements.forEach((el) => observer.observe(el));
  } else {
    // If reduced motion preferred, show everything
    document.querySelectorAll(".reveal").forEach((el) => {
      el.classList.add("is-visible");
    });
  }

  // ============================================================
  // HEADER SHADOW ON SCROLL
  // ============================================================
  const header = document.getElementById("site-header");

  if (header) {
    const onScroll = () => {
      if (window.scrollY > 8) {
        header.style.boxShadow = "0 2px 16px rgba(0, 0, 0, 0.3)";
      } else {
        header.style.boxShadow = "none";
      }
    };

    window.addEventListener("scroll", onScroll, { passive: true });
  }
</script>
