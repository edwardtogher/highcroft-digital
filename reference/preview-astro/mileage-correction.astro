---
// ============================================================
// HM AUTOS — Bespoke Preview Site
// ============================================================
// Aggressive, racing-themed design for Leicester automotive specialist
// Red (#cc2233) + Navy (#1a3a6e) + Orbitron + Rajdhani
// White canvas with fire gradient accents and clipped race shapes
// ============================================================
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>HM Autos — ECU Remapping, Diagnostics & Security | Leicester</title>
  <meta name="description" content="Expert ECU remapping, advanced diagnostics, CAN-Phantom immobilisers, and accurate mileage correction for cars, bikes, and vans in Leicester." />

  <!-- OG Tags -->
  <meta property="og:title" content="HM Autos — Your New Website" />
  <meta property="og:description" content="Expert ECU remapping, advanced diagnostics, CAN-Phantom immobilisers, and mileage correction across Leicester." />
  <meta property="og:url" content="https://highcroftdigital.com/preview/mileage-correction" />
  <meta property="og:type" content="website" />
  <meta property="og:image" content="https://highcroftdigital.com/images/preview/mileage-correction/hm-autos-logo.png" />
  <meta property="og:image:width" content="355" />
  <meta property="og:image:height" content="167" />
  <meta name="twitter:card" content="summary_large_image" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;800;900&family=Rajdhani:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  <!-- JSON-LD Schema -->
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "AutomotiveBusiness",
    "name": "HM Autos",
    "telephone": "+447873300553",
    "email": "info@mileagecontrol.co.uk",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Leicester",
      "postalCode": "LE2 6JQ",
      "addressRegion": "Leicestershire",
      "addressCountry": "GB"
    },
    "url": "https://highcroftdigital.com/preview/mileage-correction",
    "description": "Expert ECU remapping, advanced diagnostics, CAN-Phantom immobilisers, and accurate mileage correction for cars, bikes, and vans in Leicester.",
    "areaServed": ["Leicester", "Loughborough", "Hinckley", "Market Harborough", "Melton Mowbray", "Coalville"],
    "priceRange": "$$",
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5.0",
      "reviewCount": "47"
    }
  }</script>

  <style is:global>
    /* ===== RESET & BASE ===== */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --red: #cc2233;
      --red-hot: #ff1a1a;
      --navy: #1a3a6e;
      --charcoal: #1a1a2e;
      --charcoal-deep: #12121f;
      --white: #ffffff;
      --grey-light: #f5f5f7;
      --grey-mid: #f0f0f2;
      --border-light: #eeeeee;
      --text-body: #1a1a2e;
      --text-muted: #5a5a6e;
      --gold: #f5a623;
      --gradient-fire: linear-gradient(90deg, #ff1a1a 0%, #cc2233 40%, #1a3a6e 100%);
      --gradient-fade: linear-gradient(90deg, transparent, var(--red), var(--navy), transparent);
    }

    html { scroll-behavior: smooth; scroll-padding-top: 80px; }

    body {
      font-family: 'Rajdhani', -apple-system, BlinkMacSystemFont, sans-serif;
      color: var(--text-body);
      background: var(--white);
      line-height: 1.65;
      font-weight: 500;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }

    .container {
      width: 100%;
      max-width: 1140px;
      margin: 0 auto;
      padding: 0 clamp(1.25rem, 4vw, 2.5rem);
    }

    /* ===== TYPOGRAPHY ===== */
    h1, h2, h3, h4, h5, h6 {
      font-family: 'Orbitron', sans-serif;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      line-height: 1.15;
    }

    /* ===== SCROLL REVEAL ===== */
    .rv {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .rv.visible {
      opacity: 1;
      transform: translateY(0);
    }
    @media (prefers-reduced-motion: reduce) {
      .rv { opacity: 1; transform: none; transition: none; }
    }

    /* ===== SECTION LABEL ===== */
    .section-label {
      font-family: 'Orbitron', sans-serif;
      font-size: 0.55rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.25em;
      color: var(--red);
      border-left: 3px solid var(--red);
      padding-left: 0.75rem;
      margin-bottom: 1rem;
      display: inline-block;
    }

    /* ===== SECTION HEADING ===== */
    .section-heading {
      font-size: clamp(1.5rem, 3vw, 2.2rem);
      color: var(--charcoal);
      margin-bottom: 1rem;
      position: relative;
      display: inline-block;
    }
    .section-heading::after {
      content: '';
      position: absolute;
      bottom: -8px;
      left: 0;
      width: 50px;
      height: 3px;
      background: var(--red);
    }

    /* ===== GRADIENT HEADING ===== */
    .gradient-heading {
      background: var(--gradient-fire);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* ===== BUTTONS ===== */
    .btn-race {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      font-family: 'Orbitron', sans-serif;
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      padding: 0.85rem 2rem;
      color: var(--white);
      background: var(--gradient-fire);
      clip-path: polygon(0 0, calc(100% - 8px) 0, 100% 100%, 8px 100%);
      border: none;
      cursor: pointer;
      transition: transform 0.2s, box-shadow 0.2s;
      min-height: 44px;
      text-decoration: none;
    }
    .btn-race:hover { transform: translateY(-2px); box-shadow: 0 6px 24px rgba(204, 34, 51, 0.3); }

    .btn-race-red {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      font-family: 'Orbitron', sans-serif;
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      padding: 0.85rem 2rem;
      color: var(--white);
      background: var(--red);
      clip-path: polygon(0 0, calc(100% - 8px) 0, 100% 100%, 8px 100%);
      border: none;
      cursor: pointer;
      transition: transform 0.2s, box-shadow 0.2s;
      min-height: 44px;
      text-decoration: none;
    }
    .btn-race-red:hover { transform: translateY(-2px); box-shadow: 0 6px 24px rgba(204, 34, 51, 0.3); }

    .btn-race-outline {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      font-family: 'Orbitron', sans-serif;
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      padding: 0.85rem 2rem;
      color: var(--white);
      background: var(--navy);
      border: none;
      clip-path: polygon(0 0, calc(100% - 8px) 0, 100% 100%, 8px 100%);
      cursor: pointer;
      transition: transform 0.2s, opacity 0.2s;
      min-height: 44px;
      text-decoration: none;
    }
    .btn-race-outline:hover { opacity: 0.85; transform: translateY(-2px); }

    /* ===== FADE DIVIDER ===== */
    .fade-divider {
      height: 1px;
      background: var(--gradient-fade);
      border: none;
      margin: 0;
    }

    /* ===== NAV ===== */
    .nav {
      position: sticky;
      top: 0;
      z-index: 1000;
      background: rgba(255, 255, 255, 0.92);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    }
    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 70px;
    }
    .nav-logo img {
      height: 42px;
      width: auto;
    }
    .nav-links {
      display: flex;
      align-items: center;
      gap: 2rem;
      list-style: none;
    }
    .nav-links a {
      font-family: 'Orbitron', sans-serif;
      font-size: 0.55rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--charcoal);
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--red); }
    .nav-cta {
      font-family: 'Orbitron', sans-serif;
      font-size: 0.6rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      padding: 0.6rem 1.4rem;
      color: var(--white);
      background: var(--red);
      clip-path: polygon(0 0, calc(100% - 6px) 0, 100% 100%, 6px 100%);
      text-decoration: none;
      transition: background 0.2s, transform 0.2s;
      min-height: 44px;
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
    }
    .nav-cta:hover { background: var(--red-hot); transform: translateY(-1px); }
    .nav-cta svg { width: 14px; height: 14px; }

    /* Hamburger */
    .hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 8px;
      min-width: 44px;
      min-height: 44px;
      align-items: center;
      justify-content: center;
    }
    .bar {
      display: block;
      width: 24px;
      height: 2px;
      background: var(--charcoal);
      border-radius: 2px;
      transition: transform 0.3s, opacity 0.3s;
    }
    .hamburger.active .bar:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
    .hamburger.active .bar:nth-child(2) { opacity: 0; }
    .hamburger.active .bar:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

    .mobile-menu {
      display: none;
      position: fixed;
      top: 70px;
      left: 0;
      right: 0;
      background: var(--white);
      padding: 2rem 1.5rem;
      border-bottom: 1px solid var(--border-light);
      box-shadow: 0 8px 32px rgba(0,0,0,0.1);
      z-index: 999;
    }
    .mobile-menu.open { display: flex; flex-direction: column; gap: 1.5rem; }
    .mobile-menu a {
      font-family: 'Orbitron', sans-serif;
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--charcoal);
      padding: 0.5rem 0;
    }

    /* ===== HERO ===== */
    .hero {
      position: relative;
      background: var(--white);
      overflow: hidden;
      padding: clamp(4rem, 10vw, 7rem) 0 clamp(3rem, 8vw, 5rem);
      text-align: center;
    }
    .hero-content {
      position: relative;
      z-index: 2;
    }
    .hero-logo {
      height: clamp(100px, 15vw, 160px);
      width: auto;
      margin: 0 auto 2rem;
    }
    .hero .section-label {
      margin-bottom: 1.5rem;
    }
    .hero h1 {
      font-size: clamp(1.8rem, 5vw, 3.4rem);
      margin-bottom: 1.25rem;
    }
    .hero-sub {
      font-family: 'Rajdhani', sans-serif;
      font-size: clamp(1rem, 2vw, 1.25rem);
      font-weight: 500;
      color: var(--text-muted);
      max-width: 640px;
      margin: 0 auto 2.5rem;
      line-height: 1.6;
    }
    .hero-btns {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    /* ===== TRUST STRIP ===== */
    .trust-strip {
      background: var(--grey-light);
      padding: clamp(2rem, 4vw, 3rem) 0;
    }
    .trust-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
      text-align: center;
    }
    .trust-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
    }
    .trust-icon {
      width: 48px;
      height: 48px;
      background: var(--white);
      border: 1px solid var(--border-light);
      clip-path: polygon(0 0, calc(100% - 6px) 0, 100% 6px, 100% 100%, 6px 100%, 0 calc(100% - 6px));
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--red);
    }
    .trust-icon svg { width: 22px; height: 22px; }
    .trust-label {
      font-family: 'Orbitron', sans-serif;
      font-size: 0.55rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--charcoal);
    }

    /* ===== SERVICES ===== */
    .services {
      padding: clamp(3rem, 6vw, 5rem) 0;
      background: var(--white);
    }
    .services-header {
      text-align: center;
      margin-bottom: 3rem;
    }
    .services-header .section-heading { margin-bottom: 1.5rem; }
    .services-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
    .service-card {
      background: var(--white);
      border: 1px solid var(--border-light);
      clip-path: polygon(0 0, calc(100% - 16px) 0, 100% 16px, 100% 100%, 16px 100%, 0 calc(100% - 16px));
      padding: 2rem 1.5rem;
      transition: box-shadow 0.3s, transform 0.3s;
    }
    .service-card:hover {
      box-shadow: 0 8px 32px rgba(26, 26, 46, 0.08);
      transform: translateY(-3px);
    }
    .service-card-icon {
      width: 48px;
      height: 48px;
      background: var(--red);
      clip-path: polygon(0 0, calc(100% - 6px) 0, 100% 6px, 100% 100%, 6px 100%, 0 calc(100% - 6px));
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1.25rem;
    }
    .service-card-icon svg { width: 22px; height: 22px; color: var(--white); stroke: var(--white); fill: none; }
    .service-card h3 {
      font-size: 0.75rem;
      letter-spacing: 0.06em;
      color: var(--charcoal);
      margin-bottom: 0.75rem;
    }
    .service-card p {
      font-size: 0.95rem;
      color: var(--text-muted);
      line-height: 1.6;
    }

    /* ===== FEATURE SECTION ===== */
    .feature {
      padding: clamp(3rem, 6vw, 5rem) 0;
    }
    .feature-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(2rem, 4vw, 4rem);
      align-items: center;
    }
    .feature-img {
      border-radius: 4px;
      overflow: hidden;
    }
    .feature-img img {
      width: 100%;
      height: auto;
      object-fit: cover;
    }
    .feature-text h2 {
      font-size: clamp(1.3rem, 2.5vw, 1.8rem);
      color: var(--charcoal);
      margin-bottom: 1rem;
      position: relative;
      display: inline-block;
    }
    .feature-text h2::after {
      content: '';
      position: absolute;
      bottom: -8px;
      left: 0;
      width: 50px;
      height: 3px;
      background: var(--red);
    }
    .feature-body {
      font-size: 1rem;
      color: var(--text-muted);
      line-height: 1.7;
      margin: 1.5rem 0;
    }
    .feature-checklist {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .feature-checklist li {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-family: 'Rajdhani', sans-serif;
      font-size: 1rem;
      font-weight: 600;
      color: var(--charcoal);
    }
    .feature-checklist li svg {
      width: 20px;
      height: 20px;
      color: var(--red);
      flex-shrink: 0;
    }

    /* ===== STATS ===== */
    .stats {
      padding: clamp(2.5rem, 5vw, 4rem) 0;
      background: var(--white);
    }
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 2rem;
      text-align: center;
    }
    .stat-number {
      font-family: 'Orbitron', sans-serif;
      font-weight: 900;
      font-size: clamp(1.8rem, 3vw, 2.2rem);
      color: var(--red);
      margin-bottom: 0.4rem;
    }
    .stat-label {
      font-family: 'Orbitron', sans-serif;
      font-size: 0.5rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--text-muted);
    }

    /* ===== PROCESS ===== */
    .process {
      padding: clamp(3rem, 6vw, 5rem) 0;
      background: var(--grey-light);
    }
    .process-header {
      text-align: center;
      margin-bottom: 3rem;
    }
    .process-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
      align-items: start;
    }
    .process-step {
      background: var(--grey-mid);
      padding: 2rem 1.5rem;
      text-align: center;
      position: relative;
    }
    .process-num {
      font-family: 'Orbitron', sans-serif;
      font-weight: 900;
      font-size: 1.8rem;
      color: var(--red);
      margin-bottom: 0.75rem;
    }
    .process-title {
      font-family: 'Orbitron', sans-serif;
      font-size: 0.65rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--charcoal);
    }
    .process-arrow {
      position: absolute;
      right: -18px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--red);
      z-index: 2;
    }
    .process-arrow svg { width: 20px; height: 20px; }

    /* ===== REVIEWS ===== */
    .reviews {
      padding: clamp(3rem, 6vw, 5rem) 0;
      background: var(--grey-light);
    }
    .reviews-header {
      text-align: center;
      margin-bottom: 3rem;
    }
    .reviews-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }
    .review-card {
      background: var(--white);
      border-left: 3px solid var(--red);
      padding: 1.75rem;
    }
    .review-stars {
      display: flex;
      gap: 3px;
      margin-bottom: 0.75rem;
    }
    .review-stars svg { width: 16px; height: 16px; fill: var(--gold); }
    .review-quote {
      font-style: italic;
      font-size: 0.95rem;
      color: var(--text-muted);
      line-height: 1.65;
      margin-bottom: 1rem;
    }
    .review-cite {
      font-family: 'Orbitron', sans-serif;
      font-size: 0.5rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--red);
    }

    /* ===== FAQ ===== */
    .faq {
      padding: clamp(3rem, 6vw, 5rem) 0;
      background: var(--white);
    }
    .faq-header {
      text-align: center;
      margin-bottom: 3rem;
    }
    .faq-list {
      max-width: 740px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .faq-item {
      border: 1px solid var(--border-light);
      clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 10px 100%, 0 calc(100% - 10px));
    }
    .faq-item summary {
      font-family: 'Orbitron', sans-serif;
      font-size: 0.65rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--charcoal);
      padding: 1.25rem 1.5rem;
      cursor: pointer;
      list-style: none;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      min-height: 44px;
    }
    .faq-item summary::-webkit-details-marker { display: none; }
    .faq-item summary::after {
      content: '+';
      font-family: 'Orbitron', sans-serif;
      font-size: 1rem;
      font-weight: 400;
      color: var(--red);
      flex-shrink: 0;
      transition: transform 0.3s;
    }
    .faq-item[open] summary::after {
      content: '-';
    }
    .faq-answer {
      padding: 0 1.5rem 1.25rem;
      font-size: 0.95rem;
      color: var(--text-muted);
      line-height: 1.65;
    }

    /* ===== CTA BLOCK ===== */
    .cta-block {
      background: var(--charcoal);
      border-top: 3px solid var(--red);
      border-bottom: 3px solid var(--red);
      padding: clamp(3rem, 6vw, 4.5rem) 0;
      text-align: center;
    }
    .cta-block h2 {
      font-size: clamp(1.2rem, 2.5vw, 1.8rem);
      color: var(--white);
      margin-bottom: 1.5rem;
    }
    .cta-phone {
      font-family: 'Orbitron', sans-serif;
      font-size: clamp(1.5rem, 4vw, 2.5rem);
      font-weight: 900;
      color: var(--white);
      display: block;
      margin-bottom: 2rem;
      text-decoration: none;
    }
    .cta-phone:hover { color: var(--red-hot); }
    .cta-areas {
      font-family: 'Orbitron', sans-serif;
      font-size: 0.5rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: rgba(255,255,255,0.5);
      margin-top: 2rem;
    }

    /* ===== FOOTER ===== */
    .footer {
      background: var(--charcoal-deep);
      padding: 2rem 0;
      text-align: center;
    }
    .footer p {
      font-family: 'Orbitron', sans-serif;
      font-size: 0.45rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: rgba(255,255,255,0.4);
    }
    .footer a {
      color: rgba(255,255,255,0.6);
      transition: color 0.2s;
    }
    .footer a:hover { color: var(--red); }

    /* ===== FLOATING PHONE ===== */
    .floating-phone {
      display: none;
      position: fixed;
