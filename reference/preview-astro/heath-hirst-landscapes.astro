---
// Heath Hirst Landscapes & Plant Hire — Preview Page
// Built by Highcroft Digital
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Heath Hirst Landscapes & Plant Hire — Leeds, West Yorkshire</title>
  <meta name="description" content="Professional landscaping, groundworks and plant hire in Leeds and West Yorkshire. Over 8 years experience. Driveways, garden renovations, patios, fencing and more." />
  <meta property="og:title" content="Heath Hirst Landscapes & Plant Hire — Your New Site" />
  <meta property="og:description" content="A modern, professional website for Heath Hirst Landscapes. Landscaping, groundworks & plant hire across Leeds and West Yorkshire." />
  <meta property="og:image" content="https://cdn.prod.website-files.com/652d8e8bc6c49e94d8172858/68581c0015e028bdef53dd24_Artboard%2011.jpg" />
  <meta property="og:url" content="https://highcroftdigital.com/preview/heath-hirst-landscapes" />
  <meta property="og:type" content="website" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=DM+Serif+Display&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --green: #2e6b3a;
      --green-light: #3d8a4d;
      --green-pale: #e8f0e4;
      --earth: #5c4a32;
      --charcoal: #1a2118;
      --slate: #3a4238;
      --gray: #5e6960;
      --silver: #94a098;
      --mist: #eef2ec;
      --cloud: #f5f7f4;
      --white: #fefefe;
      --sand: #f0ebe3;
      --font-display: 'DM Serif Display', Georgia, serif;
      --font-body: 'DM Sans', -apple-system, sans-serif;
    }

    html {
      scroll-behavior: smooth;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    body {
      font-family: var(--font-body);
      color: var(--slate);
      background: var(--white);
      line-height: 1.6;
      overflow-x: hidden;
    }

    /* --- NAV --- */
    .nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      padding: 1.25rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: rgba(254,254,254,0.92);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(0,0,0,0.04);
      transition: padding 0.3s ease;
    }

    .nav.scrolled { padding: 0.75rem 2rem; }

    .nav-logo {
      height: 48px;
      width: auto;
      object-fit: contain;
    }

    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
      align-items: center;
    }

    .nav-links a {
      color: var(--slate);
      text-decoration: none;
      font-size: 0.875rem;
      font-weight: 500;
      letter-spacing: 0.02em;
      transition: color 0.2s;
    }

    .nav-links a:hover { color: var(--charcoal); }

    .nav-cta {
      background: var(--green) !important;
      color: var(--white) !important;
      padding: 0.6rem 1.5rem !important;
      border-radius: 2px;
      font-size: 0.8rem !important;
      letter-spacing: 0.06em !important;
      text-transform: uppercase;
      font-weight: 600 !important;
      transition: background 0.2s !important;
    }

    .nav-cta:hover { background: var(--green-light) !important; }

    .nav-toggle {
      display: none;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.5rem;
    }

    .nav-toggle span {
      display: block;
      width: 24px;
      height: 2px;
      background: var(--charcoal);
      margin: 5px 0;
      transition: 0.3s;
    }

    /* --- HERO --- */
    .hero {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
      position: relative;
    }

    .hero-content {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: clamp(4rem, 8vw, 8rem);
      padding-top: 7rem;
    }

    .hero-est {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--green);
      margin-bottom: 2rem;
    }

    .hero-est::before {
      content: '';
      display: block;
      width: 32px;
      height: 2px;
      background: var(--green);
    }

    .hero h1 {
      font-family: var(--font-display);
      font-size: clamp(2.5rem, 5vw, 4.2rem);
      color: var(--charcoal);
      line-height: 1.1;
      margin-bottom: 1.5rem;
      font-weight: 400;
    }

    .hero p {
      font-size: clamp(1rem, 1.2vw, 1.15rem);
      color: var(--gray);
      max-width: 440px;
      line-height: 1.7;
      margin-bottom: 2.5rem;
    }

    .hero-actions {
      display: flex;
      gap: 1rem;
      align-items: center;
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--green);
      color: var(--white);
      padding: 1rem 2rem;
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      border-radius: 2px;
      transition: background 0.25s ease, transform 0.2s ease;
    }

    .btn-primary:hover {
      background: var(--green-light);
      transform: translateY(-1px);
    }

    .btn-secondary {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      color: var(--charcoal);
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      padding: 1rem 0;
      transition: color 0.2s;
    }

    .btn-secondary:hover { color: var(--green); }

    .btn-secondary svg {
      transition: transform 0.2s;
    }

    .btn-secondary:hover svg {
      transform: translateX(3px);
    }

    .hero-image {
      position: relative;
      overflow: hidden;
    }

    .hero-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .hero-image::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 30%;
      background: linear-gradient(to top, rgba(26,33,24,0.2), transparent);
    }

    /* --- STATS BAR --- */
    .stats {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      background: var(--charcoal);
    }

    .stat {
      padding: 2.5rem 2rem;
      text-align: center;
      position: relative;
    }

    .stat:not(:last-child)::after {
      content: '';
      position: absolute;
      right: 0;
      top: 25%;
      height: 50%;
      width: 1px;
      background: rgba(255,255,255,0.1);
    }

    .stat-number {
      font-family: var(--font-display);
      font-size: clamp(1.8rem, 3vw, 2.5rem);
      color: var(--white);
      margin-bottom: 0.25rem;
    }

    .stat-label {
      font-size: 0.75rem;
      color: var(--silver);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-weight: 500;
    }

    /* --- SERVICES --- */
    .services {
      padding: clamp(4rem, 10vw, 8rem) clamp(2rem, 6vw, 6rem);
    }

    .section-label {
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--green);
      margin-bottom: 1rem;
    }

    .section-heading {
      font-family: var(--font-display);
      font-size: clamp(2rem, 4vw, 3.2rem);
      color: var(--charcoal);
      line-height: 1.15;
      max-width: 560px;
      margin-bottom: 1.25rem;
      font-weight: 400;
    }

    .section-sub {
      color: var(--gray);
      font-size: 1.05rem;
      max-width: 520px;
      margin-bottom: 4rem;
      line-height: 1.7;
    }

    .services-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--mist);
      border: 1px solid var(--mist);
    }

    .service-card {
      background: var(--white);
      padding: clamp(2rem, 4vw, 3rem);
      position: relative;
      transition: background 0.3s ease;
    }

    .service-card:hover {
      background: var(--cloud);
    }

    .service-icon {
      width: 48px;
      height: 48px;
      margin-bottom: 1.75rem;
      color: var(--green);
    }

    .service-card h3 {
      font-family: var(--font-display);
      font-size: 1.3rem;
      color: var(--charcoal);
      margin-bottom: 1rem;
      font-weight: 400;
    }

    .service-card p {
      color: var(--gray);
      font-size: 0.925rem;
      line-height: 1.7;
    }

    .service-number {
      position: absolute;
      top: clamp(1.5rem, 3vw, 2.5rem);
      right: clamp(1.5rem, 3vw, 2.5rem);
      font-family: var(--font-display);
      font-size: 3rem;
      color: var(--mist);
      line-height: 1;
      user-select: none;
    }

    /* --- GALLERY --- */
    .gallery {
      padding: clamp(4rem, 10vw, 7rem) clamp(2rem, 6vw, 6rem);
      background: var(--cloud);
    }

    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: auto auto;
      gap: 0.75rem;
    }

    .gallery-grid .gallery-item:first-child {
      grid-column: span 2;
      grid-row: span 2;
    }

    .gallery-item {
      overflow: hidden;
      border-radius: 2px;
      position: relative;
    }

    .gallery-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .gallery-item:hover img {
      transform: scale(1.04);
    }

    .gallery-item::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(26,33,24,0.15), transparent 50%);
      pointer-events: none;
    }

    /* --- WHY CHOOSE --- */
    .why {
      background: var(--charcoal);
      padding: clamp(4rem, 10vw, 7rem) clamp(2rem, 6vw, 6rem);
      display: grid;
      grid-template-columns: 1fr 1.2fr;
      gap: clamp(3rem, 6vw, 6rem);
      align-items: center;
    }

    .why .section-label { color: var(--green-light); }

    .why .section-heading {
      color: var(--white);
      margin-bottom: 1.5rem;
    }

    .why-text {
      color: var(--silver);
      font-size: 1rem;
      line-height: 1.8;
      max-width: 400px;
    }

    .trust-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }

    .trust-card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.06);
      padding: 2rem 1.75rem;
      border-radius: 2px;
      transition: background 0.3s;
    }

    .trust-card:hover {
      background: rgba(255,255,255,0.07);
    }

    .trust-icon {
      width: 32px;
      height: 32px;
      color: var(--green-light);
      margin-bottom: 1rem;
    }

    .trust-card h4 {
      color: var(--white);
      font-size: 0.95rem;
      font-weight: 500;
      line-height: 1.4;
    }

    /* --- ABOUT --- */
    .about {
      display: grid;
      grid-template-columns: 1.1fr 1fr;
      min-height: 70vh;
    }

    .about-image {
      background: url('https://cdn.prod.website-files.com/652d8e8bc6c49e94d8172858/68581bff9f5738464b26cd1c_Artboard%201.jpg') center/cover;
      min-height: 400px;
    }

    .about-content {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: clamp(3rem, 6vw, 6rem);
    }

    .about-content .section-heading {
      margin-bottom: 1.5rem;
    }

    .about-content p {
      color: var(--gray);
      font-size: 1rem;
      line-height: 1.8;
      margin-bottom: 1.25rem;
      max-width: 460px;
    }

    .about-sig {
      margin-top: 1.5rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--mist);
    }

    .about-sig strong {
      display: block;
      color: var(--charcoal);
      font-size: 1rem;
    }

    .about-sig span {
      color: var(--gray);
      font-size: 0.85rem;
    }

    /* --- REVIEWS --- */
    .reviews {
      background: var(--green-pale);
      padding: clamp(4rem, 10vw, 6rem) clamp(2rem, 6vw, 6rem);
      text-align: center;
    }

    .reviews-row {
      display: flex;
      justify-content: center;
      gap: 3rem;
      margin-top: 3rem;
      flex-wrap: wrap;
    }

    .review-badge {
      background: var(--white);
      padding: 2rem 3rem;
      border-radius: 2px;
      text-align: center;
      box-shadow: 0 2px 12px rgba(0,0,0,0.04);
    }

    .review-stars {
      color: #e5a100;
      font-size: 1.4rem;
      letter-spacing: 0.1em;
      margin-bottom: 0.5rem;
    }

    .review-score {
      font-family: var(--font-display);
      font-size: 2rem;
      color: var(--charcoal);
      margin-bottom: 0.25rem;
    }

    .review-source {
      font-size: 0.8rem;
      color: var(--gray);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-weight: 600;
    }

    .review-count {
      font-size: 0.8rem;
      color: var(--silver);
      margin-top: 0.25rem;
    }

    /* --- CONTACT CTA --- */
    .contact {
      background: var(--cloud);
      padding: clamp(4rem, 10vw, 7rem) clamp(2rem, 6vw, 6rem);
      text-align: center;
    }

    .contact .section-heading {
      max-width: 100%;
      margin-left: auto;
      margin-right: auto;
      margin-bottom: 1rem;
    }

    .contact-sub {
      color: var(--gray);
      font-size: 1.05rem;
      margin-bottom: 3rem;
      max-width: 500px;
      margin-left: auto;
      margin-right: auto;
      line-height: 1.7;
    }

    .contact-phone {
      font-family: var(--font-display);
      font-size: clamp(2rem, 4.5vw, 3.5rem);
      color: var(--charcoal);
      text-decoration: none;
      display: block;
      margin-bottom: 0.75rem;
      transition: color 0.2s;
    }

    .contact-phone:hover { color: var(--green); }

    .contact-email {
      color: var(--gray);
      font-size: 1.1rem;
      margin-bottom: 2.5rem;
    }

    .contact-email a {
      color: var(--gray);
      text-decoration: none;
      transition: color 0.2s;
    }

    .contact-email a:hover { color: var(--green); }

    .contact-areas {
      color: var(--silver);
      font-size: 0.85rem;
      letter-spacing: 0.04em;
      margin-top: 2rem;
    }

    /* --- FOOTER --- */
    .footer {
      padding: 2rem clamp(2rem, 6vw, 6rem);
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-top: 1px solid var(--mist);
      font-size: 0.8rem;
      color: var(--silver);
    }

    .footer a {
      color: var(--silver);
      text-decoration: none;
      transition: color 0.2s;
    }

    .footer a:hover { color: var(--green); }

    /* --- ANIMATIONS --- */
    .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
                  transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .reveal-delay-1 { transition-delay: 0.1s; }
    .reveal-delay-2 { transition-delay: 0.2s; }
    .reveal-delay-3 { transition-delay: 0.3s; }
    .reveal-delay-4 { transition-delay: 0.4s; }

    /* --- RESPONSIVE --- */
    @media (max-width: 1024px) {
      .hero { grid-template-columns: 1fr; min-height: auto; }
      .hero-image { height: 50vh; order: -1; }
      .hero-content { padding: 3rem 2rem 4rem; }
      .services-grid { grid-template-columns: repeat(2, 1fr); }
      .why { grid-template-columns: 1fr; }
      .about { grid-template-columns: 1fr; }
      .about-image { height: 50vh; }
      .gallery-grid { grid-template-columns: repeat(2, 1fr); }
      .gallery-grid .gallery-item:first-child { grid-column: span 2; grid-row: span 1; }
    }

    @media (max-width: 768px) {
      .nav-links { display: none; }
      .nav-links.open {
        display: flex;
        flex-direction: column;
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: var(--white);
        padding: 1.5rem 2rem;
        border-bottom: 1px solid var(--mist);
        gap: 1rem;
      }
      .nav-toggle { display: block; }
      .stats { grid-template-columns: repeat(2, 1fr); }
      .stat:nth-child(2)::after { display: none; }
      .services-grid { grid-template-columns: 1fr; }
      .trust-grid { grid-template-columns: 1fr; }
      .gallery-grid { grid-template-columns: 1fr 1fr; }
      .gallery-grid .gallery-item:first-child { grid-column: span 2; }
      .footer { flex-direction: column; gap: 0.75rem; text-align: center; }
    }

    @media (max-width: 480px) {
      .stats { grid-template-columns: 1fr; }
      .stat::after { display: none !important; }
      .stat {
        padding: 1.5rem;
        border-bottom: 1px solid rgba(255,255,255,0.05);
      }
      .hero-actions { flex-direction: column; align-items: flex-start; }
      .gallery-grid { grid-template-columns: 1fr; }
      .gallery-grid .gallery-item:first-child { grid-column: span 1; }
    }

    @media (prefers-reduced-motion: reduce) {
      .reveal { opacity: 1; transform: none; transition: none; }
      html { scroll-behavior: auto; }
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav class="nav" id="nav">
    <img
      src="https://cdn.prod.website-files.com/652d8e8bc6c49e94d8172858/660da988d248b8d3ee4982f1_HHL%20Logo%20Web%202-18.avif"
      alt="Heath Hirst Landscapes"
      class="nav-logo"
    />
    <ul class="nav-links" id="navLinks">
      <li><a href="#services">Services</a></li>
      <li><a href="#gallery">Gallery</a></li>
      <li><a href="#about">About</a></li>
      <li><a href="#contact" class="nav-cta">Free Quote</a></li>
    </ul>
    <button class="nav-toggle" id="navToggle" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-content">
      <span class="hero-est reveal">Leeds &amp; West Yorkshire</span>
      <h1 class="reveal reveal-delay-1">Elevate your outdoor&nbsp;space</h1>
      <p class="reveal reveal-delay-2">
        Professional landscaping, groundworks and plant hire across Leeds and West Yorkshire. From garden transformations to driveway installations, we bring your outdoor vision to life.
      </p>
      <div class="hero-actions reveal reveal-delay-3">
        <a href="tel:07948349821" class="btn-primary">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          Call Now
        </a>
        <a href="#services" class="btn-secondary">
          Our services
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
    <div class="hero-image">
      <img
        src="https://cdn.prod.website-files.com/652d8e8bc6c49e94d8172858/68581c0015e028bdef53dd24_Artboard%2011.jpg"
        alt="Heath Hirst Landscapes - professional landscaping in Leeds"
        loading="eager"
      />
    </div>
  </section>

  <!-- STATS -->
  <div class="stats">
    <div class="stat reveal">
      <div class="stat-number">8+</div>
      <div class="stat-label">Years Experience</div>
    </div>
    <div class="stat reveal reveal-delay-1">
      <div class="stat-number">5/5</div>
      <div class="stat-label">Facebook Rating</div>
    </div>
    <div class="stat reveal reveal-delay-2">
      <div class="stat-number">12+</div>
      <div class="stat-label">Services Offered</div>
    </div>
    <div class="stat reveal reveal-delay-3">
      <div class="stat-number">100%</div>
      <div class="stat-label">Customer Satisfaction</div>
    </div>
  </div>

  <!-- SERVICES -->
  <section class="services" id="services">
    <div class="section-label reveal">What We Do</div>
    <h2 class="section-heading reveal reveal-delay-1">Comprehensive landscaping &amp; groundwork&nbsp;services</h2>
    <p class="section-sub reveal reveal-delay-2">From concept to completion, we deliver top-quality landscaping across Leeds and West Yorkshire. Domestic and commercial projects of every size.</p>

    <div class="services-grid">
      <div class="service-card reveal">
        <span class="service-number">01</span>
        <svg class="service-icon" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 48 48">
          <path d="M6 42h36" stroke-linecap="round"/>
          <path d="M12 42V22l12-8 12 8v20" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M20 42V32h8v10" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M18 26h12" stroke-linecap="round"/>
